<% content_for :title, "Notificações" %>

<div class="flex-1 flex flex-col w-full">
  <div class="flex items-center justify-between p-8">
    <h1 class="font-bold text-4xl">Notificações</h1>
    <div class="flex items-center gap-4">
      <% if @notificacoes.unread.any? %>
        <%= button_to "Marcar todas como lidas",
          read_all_notificacoes_path,
          method: :post,
          class: "btn btn-outline btn-secondary btn-sm md:btn-md" %>
      <% end %>
      <% if current_user.root? %>
        <%= link_to "Enviar para todos",
          new_notificacao_path,
          class: "btn btn-primary btn-sm md:btn-md" %>
      <% end %>
    </div>
  </div>

  <div id="notificacoes" class="divide-y divide-gray-200 space-y-5 p-4">
    <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
      <ul class="list bg-base-100 rounded-box shadow-md w-full p-8">

        <% if @notificacoes.any? %>
          <% @notificacoes.order(created_at: :desc).each do |notificacao| %>

            <li class="list-row hover:bg-base-300/50! cursor-pointer
                      <%= 'opacity-70' if notificacao.read? %>">

              <%= link_to notificacao_path(notificacao),
                  class: "flex items-start justify-between w-full p-4" do %>

                <div class="flex flex-col sm:flex-row sm:items-center w-full gap-4">

                  <div class="flex items-center shrink-0">
                    <div class="avatar avatar-placeholder">
                      <div class="bg-base-300 text-neutral-content w-12 rounded-full">
                        <span>
                          <%= notificacao.tipo.to_s.first.upcase %>
                        </span>
                      </div>
                    </div>
                  </div>

                  <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6 flex-1 min-w-0">
                    <div class="font-medium break-words text-sm sm:text-base">
                      <%= notificacao.texto %>
                    </div>

                    <div class="text-xs uppercase font-semibold opacity-60">
                      <%= time_ago_in_words(notificacao.created_at) %> atrás
                    </div>
                  </div>

                </div>

              <% end %>

            </li>


          <% end %>

        <% else %>
          <p class="text-center my-10">Você não possui notificações.</p>
        <% end %>

      </ul>
    </div>
  </div>
</div>
