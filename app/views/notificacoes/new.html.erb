<% content_for :title, "Enviar notificação" %>

<div class="flex-1 w-full p-6 md:p-8">
  <div class="max-w-3xl">
    <div class="mb-8">
      <p class="text-sm uppercase font-bold opacity-60">Administrador</p>
      <h1 class="font-bold text-3xl md:text-4xl mt-1">Enviar notificação</h1>
      <p class="opacity-70 mt-3">
        Crie uma mensagem única para aparecer na área de notificações de todos os usuários.
      </p>
    </div>

    <div class="bg-base-100 border border-base-300 rounded-box shadow-md p-6">
      <%= render "form", notificacao: @notificacao %>
    </div>
  </div>
</div>
