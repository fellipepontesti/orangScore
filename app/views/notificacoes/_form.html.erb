<%= form_with(model: notificacao, class: "contents") do |form| %>
  <% if notificacao.errors.any? %>
    <div class="alert alert-error mb-6">
      <div>
        <p class="font-bold">Não foi possível enviar a notificação.</p>
        <ul class="list-disc ml-5 mt-2">
          <% notificacao.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="form-control">
    <%= form.label :texto, "Mensagem", class: "label font-semibold" %>
    <%= form.text_area :texto,
      rows: 6,
      required: true,
      maxlength: 600,
      placeholder: "Digite a mensagem que será enviada para todos os usuários.",
      class: "textarea textarea-bordered w-full text-base resize-y #{'textarea-error' if notificacao.errors[:texto].any?}" %>
    <div class="label">
      <span class="label-text-alt opacity-70">Todos os usuários receberão essa mensagem como notificação do sistema.</span>
    </div>
  </div>

  <div class="mt-6 flex flex-col sm:flex-row gap-3">
    <%= form.submit "Enviar para todos",
      class: "btn btn-primary" %>

    <%= link_to "Cancelar",
      notificacoes_path,
      class: "btn btn-ghost" %>
  </div>
<% end %>
