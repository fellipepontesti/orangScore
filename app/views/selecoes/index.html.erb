<% content_for :title, "Seleções" %>

<div class="w-full max-w-7xl mx-auto px-4 py-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Seleções</span>
        <span>/</span>
        <span>Lista</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Seleções
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Visualize a tabela, pontuação e elenco de cada seleção na Copa 2026.</p>
    </div>

    <div class="flex flex-wrap gap-2 items-center">
      <button class="btn btn-outline btn-sm sm:btn-md rounded-2xl" onclick="modal_filtros_selecoes.showModal()">
        Filtros
      </button>
      
      <% if current_user.root? %>
        <%= link_to "Cadastrar seleção",
          new_selecao_path,
          class: "btn btn-primary btn-sm sm:btn-md font-bold text-white rounded-2xl"
        %>
      <% end %>

      <%= link_to authenticated_root_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl shrink-0" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
        </svg>
        Voltar
      <% end %>
    </div>
  </div>

  <dialog id="modal_filtros_selecoes" class="modal">
    <div class="modal-box max-w-lg">
      <h3 class="font-bold text-lg mb-4 text-center">Filtrar Seleções</h3>
      <%= form_with url: selecoes_path, method: :get, local: true do |f| %>
        <div class="space-y-4">
          <div class="form-control">
            <label class="label"><span class="label-text">Nome</span></label>
            <%= f.text_field :nome, value: params[:nome], class: "input input-bordered w-full rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500", placeholder: "Buscar por nome..." %>
          </div>
          <div class="form-control">
            <label class="label"><span class="label-text">Grupo</span></label>
            <%= f.select :grupo_id, options_from_collection_for_select(Grupo.order(:nome), :id, :nome, params[:grupo_id]), { include_blank: "Todos os Grupos" }, class: "select select-bordered w-full rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500" %>
          </div>
        </div>
        <div class="modal-action flex justify-between mt-6">
          <%= link_to "Limpar", selecoes_path, class: "btn btn-ghost bg-error text-white rounded-2xl" %>
          <div class="flex gap-2">
            <button type="button" class="btn rounded-2xl" onclick="modal_filtros_selecoes.close()">Cancelar</button>
            <%= f.submit "Aplicar", class: "btn btn-primary rounded-2xl" %>
          </div>
        </div>
      <% end %>
    </div>
  </dialog>

  <% if @selecoes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @selecoes.each do |selecao| %>
        <div class="card bg-base-100 shadow-lg border border-base-200 hover:shadow-xl transition cursor-pointer group" onclick="window.location='<%= selecao_path(selecao) %>'">
          <div class="card-body p-5">
            
            <div class="flex justify-between items-start mb-2">
              <div class="flex items-center gap-4 min-w-0">
                <div class="avatar shrink-0">
                  <div class="mask mask-squircle h-14 w-14 bg-base-200 flex items-center justify-center overflow-hidden transition duration-200 group-hover:scale-105">
                    <% if selecao.logo.present? %>
                      <%= image_tag "selecoes/#{selecao.logo}", class: "object-cover w-full h-full" %>
                    <% else %>
                      <span class="text-sm font-bold opacity-40">?</span>
                    <% end %>
                  </div>
                </div>
                <div class="min-w-0">
                  <h2 class="card-title text-lg leading-tight truncate group-hover:underline"><%= selecao.nome %></h2>
                  <div class="flex flex-wrap gap-1.5 items-center mt-1">
                    <div class="badge badge-primary badge-outline text-[10px] font-bold py-2">
                      Grupo <%= selecao.grupo&.nome&.last || "—" %>
                    </div>
                  </div>
                </div>
              </div>
              
              <% if current_user.root? %>
                <div class="flex gap-1 shrink-0" onclick="event.stopPropagation();">
                  <%= button_to sync_squads_selecoes_path(selecao_id: selecao.id, api_name: (selecao.nome_en.presence || selecao.nome), year: '2026'),
                      method: :post,
                      class: "btn btn-ghost btn-xs btn-square text-sky-500 hover:bg-sky-500/10 flex items-center justify-center transition-all duration-200",
                      title: "Sincronizar Elenco e Gols" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transition-transform hover:rotate-180 duration-500">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                    </svg>
                  <% end %>
                  <%= link_to edit_selecao_path(selecao), class: "btn btn-ghost btn-xs btn-square hover:bg-base-300 flex items-center justify-center" do %>
                    <div class="h-4 w-4 invert"><%= image_tag "icons/editar.png", class: "object-contain w-full h-full" %></div>
                  <% end %>
                  <%= button_to selecao, method: :delete, form: { data: { turbo_confirm: "Excluir esta seleção?" } }, class: "btn btn-ghost btn-xs btn-square hover:bg-error/20 flex items-center justify-center" do %>
                    <div class="h-4 w-4 invert"><%= image_tag "icons/delete.png", class: "object-contain w-full h-full" %></div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <div class="grid grid-cols-5 gap-1.5 text-center my-4 bg-base-200 rounded-box p-3">
              <div class="flex flex-col">
                <span class="text-[10px] font-black opacity-60 text-warning">P</span>
                <span class="font-bold text-warning"><%= selecao.pontos %></span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] font-bold opacity-60">J</span>
                <span class="font-bold"><%= selecao.qtd_jogos %></span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] font-bold opacity-60 text-success">V</span>
                <span class="font-bold text-success"><%= selecao.vitorias %></span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] font-bold opacity-60 text-warning">E</span>
                <span class="font-bold text-warning"><%= selecao.empates %></span>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] font-bold opacity-60 text-error">D</span>
                <span class="font-bold text-error"><%= selecao.derrotas %></span>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-2 text-center text-sm">
              <div class="flex flex-col border border-base-200 rounded-box py-1">
                <span class="text-[10px] font-bold opacity-60">GP</span>
                <span class="font-bold"><%= selecao.gols %></span>
              </div>
              <div class="flex flex-col border border-base-200 rounded-box py-1">
                <span class="text-[10px] font-bold opacity-60">GC</span>
                <span class="font-bold"><%= selecao.gols_sofridos %></span>
              </div>
              <div class="flex flex-col border border-base-200 rounded-box py-1 bg-base-200">
                <span class="text-[10px] font-bold opacity-60">SG</span>
                <span class="font-bold"><%= selecao.gols.to_i - selecao.gols_sofridos.to_i %></span>
              </div>
            </div>

            <div class="mt-4 flex justify-between items-center text-sm border-t border-base-200 pt-3">
              <div class="flex items-center gap-2 opacity-70 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                Torcedores
              </div>
              <div class="font-bold bg-base-200 px-2 rounded-full"><%= selecao.qtd_torcedores %></div>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-gray-500 mt-10">
      Nenhuma seleção encontrada com os filtros aplicados.
    </p>
  <% end %>
</div>