<div id="<%= dom_id selecao %>" class="w-full max-w-5xl mx-auto space-y-6 px-4">
  
  <div class="card bg-base-100 shadow-xl border border-base-200 overflow-hidden">
    <div class="card-body p-6 sm:p-8 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
        <div class="avatar">
          <div class="mask mask-squircle h-20 w-20 bg-base-200 p-2 shadow-inner flex items-center justify-center overflow-hidden">
            <% if selecao.logo.present? %>
              <%= image_tag "selecoes/#{selecao.logo}", class: "object-cover w-full h-full" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center font-bold text-xl">?</div>
            <% end %>
          </div>
        </div>
        <div>
          <h1 class="text-3xl font-black tracking-tight"><%= selecao.nome %></h1>
          <p class="text-sm opacity-60 font-medium uppercase tracking-wider mt-1">
            Grupo <%= selecao.grupo&.nome&.last || "Sem Grupo" %>
          </p>
        </div>
      </div>

      <% if current_user.root? %>
        <div class="flex flex-wrap gap-2 w-full sm:w-auto justify-center">
          <button type="button" class="btn btn-outline btn-info btn-sm sm:btn-md font-bold gap-2 shadow-sm" onclick="modal_sync_squads.showModal()">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Sincronizar Elenco
          </button>
          <%= button_to sync_players_data_selecoes_path(selecao_id: selecao.id),
              method: :post,
              class: "btn btn-outline btn-success btn-sm sm:btn-md font-bold gap-2 shadow-sm" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Sincronizar Gols
          <% end %>
          <%= link_to edit_selecao_path(selecao), class: "btn btn-warning btn-sm sm:btn-md font-bold gap-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
            Editar
          <% end %>
          <%= button_to selecao_path(selecao), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "btn btn-error btn-outline btn-sm sm:btn-md font-bold gap-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            Excluir
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <div class="lg:col-span-2 space-y-6">
      
      <div class="grid grid-cols-5 gap-2 w-full mt-4">
        <div class="bg-base-200 rounded-box text-center flex flex-col justify-center items-center shadow-md p-2">
          <span class="text-[9px] uppercase font-black tracking-wider opacity-60 text-slate-400">Pontos</span>
          <span class="text-lg sm:text-2xl font-black text-warning mt-0.5"><%= selecao.pontos %></span>
        </div>

        <div class="bg-base-200 rounded-box p-2 text-center flex flex-col justify-center items-center shadow-md">
          <span class="text-[9px] uppercase font-black tracking-wider opacity-60 text-slate-400">Jogos</span>
          <span class="text-lg sm:text-2xl font-black text-info mt-0.5"><%= selecao.qtd_jogos %></span>
        </div>

        <div class="bg-base-200 rounded-box p-2 text-center flex flex-col justify-center items-center shadow-md">
          <span class="text-[9px] uppercase font-black tracking-wider opacity-60 text-success">Vitórias</span>
          <span class="text-lg sm:text-2xl font-black text-success mt-0.5"><%= selecao.vitorias %></span>
        </div>

        <div class="bg-base-200 rounded-box p-2 text-center flex flex-col justify-center items-center shadow-md">
          <span class="text-[9px] uppercase font-black tracking-wider opacity-60 text-slate-400">Empates</span>
          <span class="text-lg sm:text-2xl font-black text-slate-300 mt-0.5"><%= selecao.empates %></span>
        </div>

        <div class="bg-base-200 rounded-box p-2 text-center flex flex-col justify-center items-center shadow-md">
          <span class="text-[9px] uppercase font-black tracking-wider opacity-60 text-error">Derrotas</span>
          <span class="text-lg sm:text-2xl font-black text-error mt-0.5"><%= selecao.derrotas %></span>
        </div>
      </div>

      <% if selecao.grupo.present? %>
        <div class="card bg-base-100 border border-base-200 shadow-xl overflow-hidden">
          <div class="p-5 border-b border-base-200 bg-base-200/20">
            <h2 class="font-bold text-lg flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
              Classificação do Grupo <%= selecao.grupo.nome.last %>
            </h2>
          </div>
          <div class="overflow-x-auto w-full">
            <table class="table table-sm sm:table-md w-full">
              <thead>
                <tr class="bg-base-200/30 text-xs opacity-60 uppercase font-black">
                  <th class="w-12 text-center">Pos</th>
                  <th>Seleção</th>
                  <th class="text-center w-12">P</th>
                  <th class="text-center w-12">J</th>
                  <th class="text-center w-12 hidden sm:table-cell">V</th>
                  <th class="text-center w-12 hidden sm:table-cell">E</th>
                  <th class="text-center w-12 hidden sm:table-cell">D</th>
                </tr>
              </thead>
              <tbody>
                <% selecao.grupo.selecoes.order(pontos: :desc, vitorias: :desc).each_with_index do |s, idx| %>
                  <tr class="hover:bg-base-200/40 transition <%= 'bg-primary/5 font-bold' if s.id == selecao.id %>">
                    <td class="text-center font-mono font-bold"><%= idx + 1 %>º</td>
                    <td>
                      <%= link_to selecao_path(s), class: "flex items-center gap-2 group" do %>
                        <div class="avatar shrink-0">
                          <div class="mask mask-squircle w-6 h-6 bg-base-200 flex items-center justify-center overflow-hidden">
                            <%= image_tag "selecoes/#{s.logo}", class: "object-cover w-full h-full" if s.logo.present? %>
                          </div>
                        </div>
                        <span class="truncate max-w-[120px] sm:max-w-none group-hover:underline"><%= s.nome %></span>
                        <% if s.id == selecao.id %>
                          <span class="badge badge-primary badge-xs ml-1 font-black">Atual</span>
                        <% end %>
                      <% end %>
                    </td>
                    <td class="text-center font-bold font-mono text-primary"><%= s.pontos %></td>
                    <td class="text-center font-mono"><%= s.qtd_jogos %></td>
                    <td class="text-center text-success font-mono hidden sm:table-cell"><%= s.vitorias %></td>
                    <td class="text-center opacity-60 font-mono hidden sm:table-cell"><%= s.empates %></td>
                    <td class="text-center text-error font-mono hidden sm:table-cell"><%= s.derrotas %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <!-- Card do Elenco Oficial -->
      <div class="card bg-base-100 border border-base-200 shadow-xl overflow-hidden mt-6">
        <div class="p-5 border-b border-base-200 bg-base-200/20 flex justify-between items-center">
          <h2 class="font-bold text-lg flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Elenco Oficial
          </h2>
          <span class="badge badge-primary font-bold text-xs"><%= selecao.jogadores.count %> Convocados</span>
        </div>
        
        <div class="p-5">
          <% if current_user.premium? || current_user.root? || current_user.semi_root? %>
            <% if selecao.jogadores.any? %>
              <div class="space-y-6">
                <%
                  pos_keys = {
                    'GK' => 'Goleiros',
                    'DF' => 'Defensores',
                    'MF' => 'Meio-campistas',
                    'FW' => 'Atacantes'
                  }
                %>
                <% ['GK', 'DF', 'MF', 'FW'].each do |pos_key| %>
                  <% pos_players = selecao.jogadores.where(posicao: pos_key) %>
                  <% if pos_players.any? %>
                    <div>
                      <h3 class="font-bold text-sm uppercase opacity-60 tracking-wider mb-2 border-b border-base-200 pb-1">
                        <%= pos_keys[pos_key] %>
                      </h3>
                      <div class="overflow-x-auto w-full">
                        <table class="table table-sm w-full">
                          <thead>
                            <tr class="text-[10px] uppercase font-black opacity-50">
                              <th class="w-10 text-center">Nº</th>
                              <th>Jogador</th>
                              <th>Clube</th>
                              <th class="text-center w-16">Idade</th>
                              <th class="text-center w-16">Gols</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% pos_players.order(Arel.sql('numero ASC NULLS LAST, nome ASC')).each do |jogador| %>
                              <tr class="hover:bg-base-200/40 transition">
                                <td class="text-center font-mono font-bold text-xs">
                                  <%= jogador.numero.presence || "—" %>
                                </td>
                                <td class="font-bold flex items-center gap-1.5 min-w-[150px]">
                                  <span><%= jogador.nome %></span>
                                  <% if jogador.capitao? %>
                                    <span class="badge badge-warning badge-xs font-black text-[8px] text-white" title="Capitão">C</span>
                                  <% end %>
                                </td>
                                <td class="text-xs max-w-[200px] truncate">
                                  <%= jogador.clube %>
                                  <% if jogador.clube_pais.present? %>
                                    <span class="opacity-50 text-[10px] ml-1">(<%= jogador.clube_pais %>)</span>
                                  <% end %>
                                </td>
                                <td class="text-center font-mono text-xs">
                                  <%= jogador.idade_torneio.presence || "—" %>
                                </td>
                                <td class="text-center font-mono text-xs font-bold <%= 'text-success' if jogador.gols > 0 %>">
                                  <%= jogador.gols %>
                                </td>
                              </tr>
                            <% end %>
                          </tbody>
                        </table>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-6">
                <p class="opacity-60 text-sm mb-4">Nenhum jogador cadastrado para esta seleção ainda.</p>
                <% if current_user.root? %>
                  <button class="btn btn-primary btn-sm font-bold" onclick="modal_sync_squads.showModal()">
                    Sincronizar Elenco da API
                  </button>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="text-center py-8 px-4 flex flex-col items-center justify-center space-y-4">
              <div class="w-16 h-16 bg-yellow-500/10 border border-yellow-500 text-yellow-500 rounded-full flex items-center justify-center animate-pulse">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
                  <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7 0v3h7Z" clip-rule="evenodd" />
                </svg>
              </div>
              <h3 class="font-extrabold text-xl text-slate-200">Elenco Exclusivo</h3>
              <p class="text-xs text-slate-400 max-w-sm leading-relaxed text-center">
                A visualização das escalações e elenco oficial com dados dos jogadores é exclusiva para membros do plano **Premium** por apenas R$ 4,99.
              </p>
              <%= link_to "Liberar Elencos com Premium ➔", planos_path, class: "btn btn-warning btn-sm font-bold shadow-lg shadow-yellow-500/20 rounded-xl px-6" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% if current_user.root? %>
      <dialog id="modal_sync_squads" class="modal">
        <div class="modal-box max-w-lg">
          <h3 class="font-bold text-lg mb-4 text-center">Sincronizar Elenco via API</h3>
          <%= form_with url: sync_squads_selecoes_path, method: :post, local: true do |f| %>
            <div class="space-y-4">
              <div class="form-control">
                <label class="label"><span class="label-text font-bold">Seleção no Sistema</span></label>
                <%= f.select :selecao_id, 
                  options_from_collection_for_select(Selecao.order(:nome), :id, :nome, selecao.id), 
                  { prompt: "Selecione a seleção local..." }, 
                  class: "select select-bordered w-full", id: "show_sync_selecao_id", required: true %>
              </div>
              
              <div class="form-control">
                <label class="label"><span class="label-text font-bold">Nome da Seleção na API (em Inglês)</span></label>
                <%= f.text_field :api_name, value: (selecao.nome_en.presence || selecao.nome), class: "input input-bordered w-full", id: "show_sync_api_name", placeholder: "Ex: Brazil, Canada, Ghana, France...", required: true %>
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-bold">Ano do Torneio</span></label>
                <%= f.select :year, options_for_select([["2026", "2026"], ["1986", "1986"]], "2026"), {}, class: "select select-bordered w-full" %>
              </div>
            </div>
            
            <div class="modal-action flex justify-between mt-6">
              <button type="button" class="btn btn-ghost bg-base-300" onclick="modal_sync_squads.close()">Cancelar</button>
              <%= f.submit "Sincronizar", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </dialog>

      <%
        mapping_json = Selecao.all.each_with_object({}) do |s, hash|
          hash[s.id] = s.nome_en
        end.to_json
      %>
      <script>
        (function() {
          function initShowAutocomplete() {
            const teamMapping = <%= mapping_json.html_safe %>;
            const select = document.getElementById("show_sync_selecao_id");
            const input = document.getElementById("show_sync_api_name");
            
            if (select && input) {
              select.removeEventListener("change", handleShowSelectChange);
              select.addEventListener("change", handleShowSelectChange);
            }

            function handleShowSelectChange() {
              const selectedId = select.value;
              const apiName = teamMapping[selectedId];
              if (apiName) {
                input.value = apiName;
              } else {
                input.value = "";
              }
            }
          }

          document.addEventListener("DOMContentLoaded", initShowAutocomplete);
          document.addEventListener("turbo:load", initShowAutocomplete);
        })();
      </script>
    <% end %>

    <div class="space-y-4">
      <h2 class="text-xl font-bold flex items-center gap-2 px-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        Partidas e Palpites
      </h2>

      <% proximas_partidas = Jogo.where(mandante_id: selecao.id).or(Jogo.where(visitante_id: selecao.id)).order(data: :asc) %>
      <% palpites_do_usuario = current_user.palpites.where(jogo_id: proximas_partidas.map(&:id)).index_by(&:jogo_id) %>
      <% pontos_do_usuario = current_user.user_points.where(jogo_id: proximas_partidas.map(&:id)).index_by(&:jogo_id) %>
      
      <% if proximas_partidas.any? %>
        <div class="flex flex-col gap-3">
          <% proximas_partidas.each do |jogo| %>
            <% palpite = palpites_do_usuario[jogo.id] %>
            <% ponto = pontos_do_usuario[jogo.id] %>

            <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-xl transition overflow-hidden cursor-pointer" onclick="window.location='<%= jogo_path(jogo) %>'">
              <div class="p-4 space-y-3">
                <div class="flex justify-between items-center text-[10px] uppercase font-bold opacity-50">
                  <span><%= horario_jogo(jogo, "%d/%m/%Y às %H:%M") %></span>
                  <span class="badge badge-xs <%= jogo.em_andamento? ? 'badge-success text-white' : 'badge-neutral' %> font-black p-1.5 uppercase">
                    <%= jogo.status.humanize %>
                  </span>
                </div>
                
                <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 bg-base-200/40 p-2.5 rounded-xl text-xs">
                  
                  <div class="min-w-0">
                    <% if jogo.mandante.present? %>
                      <%= link_to selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "flex items-center gap-2 min-w-0 group" do %>
                        <div class="avatar shrink-0">
                          <div class="mask mask-squircle w-6 h-6 bg-base-100 flex items-center justify-center overflow-hidden">
                            <%= image_tag "selecoes/#{jogo.mandante.logo}", class: "object-cover w-full h-full" if jogo.mandante.logo.present? %>
                          </div>
                        </div>
                        <span class="font-bold truncate group-hover:underline <%= 'text-primary' if jogo.mandante_id == selecao.id %>"><%= jogo.mandante.nome %></span>
                      <% end %>
                    <% else %>
                      <div class="flex items-center gap-2 min-w-0 opacity-60">
                        <div class="avatar shrink-0">
                          <div class="mask mask-squircle w-6 h-6 bg-base-100 flex items-center justify-center font-bold text-[8px]">?</div>
                        </div>
                        <span class="font-bold truncate">A definir</span>
                      </div>
                    <% end %>
                  </div>

                  <div class="px-2 font-mono font-black text-center text-sm tracking-wider whitespace-nowrap bg-base-300/40 rounded py-0.5">
                    <% if jogo.finalizado? || jogo.em_andamento? %>
                      <%= jogo.gols_mandante %>-<%= jogo.gols_visitante %>
                    <% else %>
                      VS
                    <% end %>
                  </div>

                  <div class="min-w-0">
                    <% if jogo.visitante.present? %>
                      <%= link_to selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "flex items-center gap-2 justify-end text-right min-w-0 group" do %>
                        <span class="font-bold truncate group-hover:underline <%= 'text-primary' if jogo.visitante_id == selecao.id %>"><%= jogo.visitante.nome %></span>
                        <div class="avatar shrink-0">
                          <div class="mask mask-squircle w-6 h-6 bg-base-100 flex items-center justify-center overflow-hidden">
                            <%= image_tag "selecoes/#{jogo.visitante.logo}", class: "object-cover w-full h-full" if jogo.visitante.logo.present? %>
                          </div>
                        </div>
                      <% end %>
                    <% else %>
                      <div class="flex items-center gap-2 justify-end text-right min-w-0 opacity-60">
                        <span class="font-bold truncate">A definir</span>
                        <div class="avatar shrink-0">
                          <div class="mask mask-squircle w-6 h-6 bg-base-100 flex items-center justify-center font-bold text-[8px]">?</div>
                        </div>
                      </div>
                    <% end %>
                  </div>

                </div>

                <% if jogo.prob_mandante.present? && !current_user.esconder_odds %>
                  <div class="w-full mt-2 pt-1" onclick="event.stopPropagation()">
                    <div class="flex justify-between text-[9px] font-black uppercase tracking-wider text-slate-500 mb-1">
                      <span class="text-success"><%= jogo.mandante&.nome&.truncate(10) || 'Mandante' %>: <%= jogo.prob_mandante %>%</span>
                      <span class="text-slate-400">Empate: <%= jogo.prob_empate %>%</span>
                      <span class="text-error"><%= jogo.visitante&.nome&.truncate(10) || 'Visitante' %>: <%= jogo.prob_visitante %>%</span>
                    </div>
                    <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-300 shadow-inner">
                      <div class="bg-success" style="width: <%= jogo.prob_mandante %>%;"></div>
                      <div class="bg-slate-400" style="width: <%= jogo.prob_empate %>%;"></div>
                      <div class="bg-error" style="width: <%= jogo.prob_visitante %>%;"></div>
                    </div>
                  </div>
                <% end %>

                <div class="pt-1.5 border-t border-dashed border-base-300 flex items-center justify-between text-xs min-h-[36px]" onclick="event.stopPropagation();">
                  <% if palpite.present? %>
                    <div class="flex flex-col items-start gap-0.5">
                      <div class="flex items-center gap-1.5 opacity-70">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-primary"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <span>Palpite: <strong class="font-mono bg-base-200 px-1 rounded"><%= palpite.gols_casa %> x <%= palpite.gols_fora %></strong></span>
                      </div>
                      
                      <% if jogo.finalizado? && ponto.present? %>
                        <span class="text-[9px] opacity-50 block pl-5 truncate max-w-[150px]"><%= ponto.motivo %></span>
                      <% end %>
                    </div>

                    <div>
                      <% if jogo.programado? %>
                        <%= link_to edit_palpite_path(palpite), class: "btn btn-warning btn-xs font-bold normal-case shadow-sm gap-1" do %>
                          Editar ✎
                        <% end %>
                      <% elsif jogo.finalizado? %>
                        <% if ponto.present? %>
                          <div class="badge badge-success text-[10px] text-white font-black uppercase tracking-wider py-2">
                            +<%= ponto.pontos %> pts
                          </div>
                        <% else %>
                          <div class="badge badge-ghost text-[10px] opacity-50 font-black uppercase tracking-wider py-2">
                            0 pts
                          </div>
                        <% end %>
                      <% end %>
                    </div>

                  <% else %>
                    <div class="flex items-center gap-1.5 opacity-40 italic">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
                      <span>Sem palpite</span>
                    </div>
                    
                    <% if jogo.programado? || jogo.times_a_definir? %>
                      <%= link_to new_palpite_path(jogo_id: jogo.uuid), class: "btn btn-primary btn-xs font-bold normal-case shadow-sm" do %>
                        Palpitar ➔
                      <% end %>
                    <% else %>
                      <span class="text-[10px] opacity-40 font-bold uppercase">Encerrado</span>
                    <% end %>
                  <% end %>
                </div>

                <p class="text-[10px] opacity-50 truncate"><%= jogo.estadio.presence || "Estádio não definido" %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-base-100 border border-base-200 rounded-box p-6 text-center opacity-60 text-sm shadow-sm">
          Nenhuma partida agendada.
        </div>
      <% end %>
    </div>

  </div>
</div>