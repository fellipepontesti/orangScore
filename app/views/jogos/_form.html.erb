<div class="w-full mx-auto px-4">
  <div class="rounded-box shadow-lg bg-base-100 p-8">
    <%= form_with(model: jogo, class: "space-y-6") do |form| %>

      <% if jogo.errors.any? %>
        <div class="alert alert-error text-sm">
          <ul class="list-disc ml-5">
            <% jogo.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :tipo, "Fase", class: "label font-medium p-2" %>
        <%= form.select :tipo,
          [
            ["Fase de grupos", "grupo"],
            ["Segunda fase", "segunda_fase"],
            ["Oitavas de final", "oitavas"],
            ["Quartas de final", "quartas"],
            ["Semifinal", "semi"],
            ["Final", "final"]
          ],
          { prompt: "Selecione a fase" },
          {
            class: "select select-ghost select-bordered bg-base-300 w-full #{jogo.errors[:tipo].any? ? 'select-error' : ''}",
            id: "jogo_tipo"
          } %>
      </div>

      <div id="campo_grupo" class="<%= jogo.tipo == 'grupo' ? '' : 'hidden' %>">
        <%= form.label :grupo_id, "Grupo", class: "label font-medium p-2" %>
        <%= form.collection_select :grupo_id,
          @grupos,
          :id,
          :nome,
          { prompt: "Selecione o grupo" },
          {
            class: "select select-ghost select-bordered bg-base-300 w-full #{jogo.errors[:grupo_id].any? ? 'select-error' : ''}",
            id: "jogo_grupo_id"
          } %>
      </div>

      <div id="campo_definir" class="<%= 'hidden' if jogo.tipo == 'grupo' %>">
        <label class="label cursor-pointer justify-start gap-3">
          <%= form.check_box :definir, class: "checkbox checkbox-primary", id: "jogo_definir" %>
          <span class="label-text font-medium">
            Jogo ainda a definir
          </span>
        </label>
      </div>

      <div id="campo_mandante" class="<%= 'hidden' if jogo.definir? %>">
        <%= form.label :mandante_id, "Mandante", class: "label font-medium p-2" %>
        <%= form.select :mandante_id,
          options_for_select(@selecoes.map { |s| [s.nome, s.id, { "data-grupo-id": s.grupo_id }] }),
          { prompt: "Selecione o mandante" },
          {
            class: "select select-ghost select-bordered bg-base-300 w-full",
            id: "jogo_mandante_id"
          } %>
      </div>

      <div id="campo_visitante" class="<%= 'hidden' if jogo.definir? %>">
        <%= form.label :visitante_id, "Visitante", class: "label font-medium p-2" %>
        <%= form.select :visitante_id,
          options_for_select(@selecoes.map { |s| [s.nome, s.id, { "data-grupo-id": s.grupo_id }] }),
          { prompt: "Selecione o visitante" },
          {
            class: "select select-ghost select-bordered bg-base-300 w-full",
            id: "jogo_visitante_id"
          } %>
      </div>

      <div id="campo_nome_provisorio_mandante" class="<%= jogo.definir? ? '' : 'hidden' %>">
        <%= form.label :nome_provisorio_mandante, "Nome provisório do mandante", class: "label font-medium p-2" %>
        <%= form.text_field :nome_provisorio_mandante,
          placeholder: "Ex.: Vencedor jogo 1",
          class: "input input-ghost bg-base-300 w-full #{jogo.errors[:nome_provisorio_mandante].any? ? 'input-error' : ''}",
          id: "jogo_nome_provisorio_mandante" %>
      </div>

      <div id="campo_nome_provisorio_visitante" class="<%= jogo.definir? ? '' : 'hidden' %>">
        <%= form.label :nome_provisorio_visitante, "Nome provisório do visitante", class: "label font-medium p-2" %>
        <%= form.text_field :nome_provisorio_visitante,
          placeholder: "Ex.: Vencedor jogo 2",
          class: "input input-ghost bg-base-300 w-full #{jogo.errors[:nome_provisorio_visitante].any? ? 'input-error' : ''}",
          id: "jogo_nome_provisorio_visitante" %>
      </div>

      <div>
        <%= form.label :estadio, "Estádio", class: "label font-medium p-2" %>
        <%= form.select :estadio,
          [
            "MetLife Stadium (New York/New Jersey, EUA)",
            "SoFi Stadium (Los Angeles, EUA)",
            "AT&T Stadium (Dallas, EUA)",
            "NRG Stadium (Houston, EUA)",
            "Mercedes-Benz Stadium (Atlanta, EUA)",
            "Hard Rock Stadium (Miami, EUA)",
            "Lincoln Financial Field (Philadelphia, EUA)",
            "Lumen Field (Seattle, EUA)",
            "Levi's Stadium (San Francisco Bay Area, EUA)",
            "Gillette Stadium (Boston, EUA)",
            "Arrowhead Stadium (Kansas City, EUA)",
            "BC Place (Vancouver, Canadá)",
            "BMO Field (Toronto, Canadá)",
            "Estadio Azteca (Cidade do México, México)",
            "Estadio BBVA (Monterrey, México)",
            "Estadio Akron (Guadalajara, México)"
          ],
          { prompt: "Selecione o estádio" },
          {
            class: "select select-ghost select-bordered bg-base-300 w-full #{jogo.errors[:estadio].any? ? 'select-error' : ''}"
          } %>
      </div>

      <div>
        <%= form.label :data, "Data e hora", class: "label font-medium p-2" %>
        <%= form.datetime_field :data,
          class: "input input-ghost bg-base-300 w-full #{jogo.errors[:data].any? ? 'input-error' : ''}" %>
      </div>

      <% if jogo.persisted? %>
        <div>
          <%= form.label :status, "Status", class: "label font-medium p-2" %>
          <%= form.select :status,
            [
              ["Programado", "programado"],
              ["Em andamento", "em_andamento"],
              ["Finalizado", "finalizado"],
              ["A definir", "times_a_definir"]
            ],
            {},
            {
              class: "select select-ghost select-bordered bg-base-300 w-full #{jogo.errors[:status].any? ? 'select-error' : ''}"
            } %>
        </div>
      <% end %>

      <div class="flex justify-between gap-4 pt-6">
        <%= link_to "Voltar",
          jogos_path,
          class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-error hover:bg-error/90 font-medium text-white" %>

        <%= form.submit "Salvar jogo",
          class: "rounded-md px-6 py-3 bg-primary hover:bg-primary/90 font-medium text-white" %>
      </div>

    <% end %>
  </div>
</div>

<script>
  function toggleCamposJogo() {
    const campoGrupo = document.getElementById('campo_grupo')
    const grupoSelect = document.getElementById('jogo_grupo_id')
    const tipo = document.getElementById('jogo_tipo')
    const definir = document.getElementById('jogo_definir')
    const campoDefinir = document.getElementById('campo_definir')
    const campoMandante = document.getElementById('campo_mandante')
    const campoVisitante = document.getElementById('campo_visitante')
    const campoNomeProvisorioMandante = document.getElementById('campo_nome_provisorio_mandante')
    const campoNomeProvisorioVisitante = document.getElementById('campo_nome_provisorio_visitante')

    if (!tipo) return

    const ehGrupo = tipo.value === 'grupo'
    const podeDefinir = !ehGrupo

    if (campoGrupo) {
      if (ehGrupo) campoGrupo.classList.remove('hidden')
      else {
        campoGrupo.classList.add('hidden')
        if (grupoSelect) grupoSelect.value = ''
      }
    }

    if (campoDefinir) {
      if (podeDefinir) campoDefinir.classList.remove('hidden')
      else {
        campoDefinir.classList.add('hidden')
        if (definir) definir.checked = false
      }
    }

    const estaADefinir = podeDefinir && definir && definir.checked

    if (estaADefinir) {
      campoMandante.classList.add('hidden')
      campoVisitante.classList.add('hidden')
      campoNomeProvisorioMandante.classList.remove('hidden')
      campoNomeProvisorioVisitante.classList.remove('hidden')
    } else {
      campoMandante.classList.remove('hidden')
      campoVisitante.classList.remove('hidden')
      campoNomeProvisorioMandante.classList.add('hidden')
      campoNomeProvisorioVisitante.classList.add('hidden')
    }
  }

  function filtrarSelecoesPorGrupo() {
    const grupoSelect = document.getElementById('jogo_grupo_id')
    const mandanteSelect = document.getElementById('jogo_mandante_id')
    const visitanteSelect = document.getElementById('jogo_visitante_id')

    if (!grupoSelect) return

    const grupoId = grupoSelect.value

    function filtrar(select) {
      Array.from(select.options).forEach(option => {
        if (!option.value) return
        const grupoOption = option.getAttribute('data-grupo-id')

        option.hidden = grupoId && grupoOption !== grupoId
      })

      select.value = ''
    }

    if (mandanteSelect) filtrar(mandanteSelect)
    if (visitanteSelect) filtrar(visitanteSelect)
  }

  function bindCamposJogo() {
    const tipo = document.getElementById('jogo_tipo')
    const definir = document.getElementById('jogo_definir')
    const grupo = document.getElementById('jogo_grupo_id')

    if (tipo) tipo.addEventListener('change', toggleCamposJogo)
    if (definir) definir.addEventListener('change', toggleCamposJogo)
    if (grupo) grupo.addEventListener('change', filtrarSelecoesPorGrupo)

    toggleCamposJogo()
    filtrarSelecoesPorGrupo()
  }

  document.addEventListener('DOMContentLoaded', bindCamposJogo)
  document.addEventListener('turbo:load', bindCamposJogo)
</script>