<% content_for :title, "Finalizar Jogo" %>

<div class="w-full max-w-3xl mx-auto px-4 pb-8 pt-8">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold">Placar Oficial</h1>
    <p class="opacity-70 mt-2">Defina o placar final para este jogo.</p>
  </div>

  <div class="card bg-base-100 shadow-2xl border border-base-200">
    <div class="card-body p-8 md:p-12">
      <%= form_with(model: @jogo, url: finish_jogo_path(@jogo), method: :patch, class: "space-y-10") do |form| %>

        <% if @jogo.errors.any? %>
          <div class="alert alert-error shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <ul class="list-disc ml-5 text-sm font-medium">
              <% @jogo.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="text-center mb-8">
          <div class="badge badge-primary badge-outline text-xs mb-4"><%= horario_jogo(@jogo, "%d/%m/%Y às %H:%M") %></div>
          <% if @jogo.estadio.present? %>
            <div class="text-xs opacity-50 mt-1"><%= @jogo.estadio %></div>
          <% end %>
        </div>

        <!-- VERSUS BOARD -->
        <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-12 relative">
          
          <!-- Mandante -->
          <%= render "components/score_input",
              input_id: "gols_mandante",
              input_name: "jogo[gols_mandante]",
              value: @jogo.gols_mandante,
              avatar_class: "ring ring-primary",
              image_path: @jogo.mandante&.logo.present? ? "selecoes/#{@jogo.mandante.logo}" : nil,
              team_name: @jogo.mandante&.nome || @jogo.nome_provisorio_mandante.presence || "Mandante" %>

          <!-- VS Badge -->
          <div class="hidden md:flex flex-col items-center justify-center">
            <div class="w-12 h-12 rounded-full bg-base-300 flex items-center justify-center shadow-inner font-black text-xl opacity-70 z-10">
              X
            </div>
          </div>

          <div class="md:hidden w-full flex justify-center py-2">
            <div class="badge badge-neutral">VS</div>
          </div>

          <!-- Visitante -->
          <%= render "components/score_input",
              input_id: "gols_visitante",
              input_name: "jogo[gols_visitante]",
              value: @jogo.gols_visitante,
              avatar_class: "ring ring-secondary",
              image_path: @jogo.visitante&.logo.present? ? "selecoes/#{@jogo.visitante.logo}" : nil,
              team_name: @jogo.visitante&.nome || @jogo.nome_provisorio_visitante.presence || "Visitante" %>

        </div>

          <% unless @jogo.grupo? %>
          <!-- Container de Detalhes dos Pênaltis para o Admin -->
          <div id="vencedor-penaltis-container" class="<%= 'hidden' unless @jogo.gols_mandante.present? && @jogo.gols_visitante.present? && @jogo.gols_mandante.to_i == @jogo.gols_visitante.to_i %> bg-warning/5 border border-warning/20 rounded-3xl p-6 max-w-2xl mx-auto text-center space-y-6 shadow-inner">
            <div class="flex items-center justify-center gap-2 text-warning font-black text-xs uppercase tracking-wider">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 21l8.982-2.246M18 19.086L18 21M21 15v4.5m-3-12h.008v.008H18V7.5Zm-3 3h.008v.008H15v-.008Zm6 0h.008v.008H21v-.008Zm-3 3h.008v.008H18v-.008Zm-3 3h.008v.008H15v-.008Z" />
              </svg>
              Decisão nos Pênaltis (Mata-Mata)
            </div>
            
            <p class="text-xs opacity-75">O placar informado é de empate! Preencha o placar e a sequência das cobranças de pênaltis:</p>
            
            <!-- Placar Numérico dos Pênaltis -->
            <div class="flex items-center justify-center gap-6 max-w-md mx-auto bg-base-200/50 p-4 rounded-2xl border border-base-300">
              <div class="flex-1 flex flex-col items-center">
                <span class="text-xs font-bold text-slate-400 mb-1"><%= @jogo.mandante&.nome || 'Mandante' %></span>
                <%= form.number_field :gols_penaltis_mandante, id: 'gols_penaltis_mandante', min: 0, class: "input input-bordered w-20 text-center font-black text-lg", placeholder: "0" %>
              </div>
              <span class="text-xl font-bold opacity-40">x</span>
              <div class="flex-1 flex flex-col items-center">
                <span class="text-xs font-bold text-slate-400 mb-1"><%= @jogo.visitante&.nome || 'Visitante' %></span>
                <%= form.number_field :gols_penaltis_visitante, id: 'gols_penaltis_visitante', min: 0, class: "input input-bordered w-20 text-center font-black text-lg", placeholder: "0" %>
              </div>
            </div>

            <!-- Construtor Sequência de Pênaltis -->
            <div class="space-y-4 text-left border-t border-warning/10 pt-4">
              <h4 class="text-xs uppercase font-extrabold text-warning tracking-wider text-center">Sequência de Cobranças (Bolinhas e X)</h4>
              
              <!-- Hidden fields para salvar as strings -->
              <%= form.hidden_field :sequencia_penaltis_mandante, id: 'hidden_sequencia_mandante', value: @jogo.sequencia_penaltis_mandante %>
              <%= form.hidden_field :sequencia_penaltis_visitante, id: 'hidden_sequencia_visitante', value: @jogo.sequencia_penaltis_visitante %>

              <!-- Time Mandante Cobranças -->
              <div class="bg-base-200/40 p-4 rounded-2xl border border-base-300 space-y-2">
                <div class="flex items-center justify-between">
                  <span class="text-xs font-black text-white"><%= @jogo.mandante&.nome || 'Mandante' %></span>
                  <button type="button" onclick="adicionarCobranca('mandante')" class="btn btn-xs btn-outline btn-warning rounded-lg">+ Chute</button>
                </div>
                <div id="cobrancas_mandante" class="flex flex-wrap gap-2 min-h-10 items-center">
                  <!-- Inseridos por JS -->
                </div>
              </div>

              <!-- Time Visitante Cobranças -->
              <div class="bg-base-200/40 p-4 rounded-2xl border border-base-300 space-y-2">
                <div class="flex items-center justify-between">
                  <span class="text-xs font-black text-white"><%= @jogo.visitante&.nome || 'Visitante' %></span>
                  <button type="button" onclick="adicionarCobranca('visitante')" class="btn btn-xs btn-outline btn-warning rounded-lg">+ Chute</button>
                </div>
                <div id="cobrancas_visitante" class="flex flex-wrap gap-2 min-h-10 items-center">
                  <!-- Inseridos por JS -->
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="divider my-4"></div>

        <script>
          (function() {
            let sequencias = {
              mandante: [],
              visitante: []
            };

            function setupPenaltis() {
              const inputCasa = document.getElementById('gols_mandante');
              const inputFora = document.getElementById('gols_visitante');
              const container = document.getElementById('vencedor-penaltis-container');
              if (!inputCasa || !inputFora || !container) return;

              function checkValues() {
                const valCasa = inputCasa.value;
                const valFora = inputFora.value;

                if (valCasa !== '' && valFora !== '' && parseInt(valCasa) === parseInt(valFora)) {
                  container.classList.remove('hidden');
                } else {
                  container.classList.add('hidden');
                  // Limpa os campos se não for empate
                  const golsM = document.getElementById('gols_penaltis_mandante');
                  const golsV = document.getElementById('gols_penaltis_visitante');
                  if (golsM) golsM.value = '';
                  if (golsV) golsV.value = '';
                  const hiddenM = document.getElementById('hidden_sequencia_mandante');
                  const hiddenV = document.getElementById('hidden_sequencia_visitante');
                  if (hiddenM) hiddenM.value = '';
                  if (hiddenV) hiddenV.value = '';
                  sequencias.mandante = [];
                  sequencias.visitante = [];
                  renderizarCobrancas('mandante');
                  renderizarCobrancas('visitante');
                }
              }

              inputCasa.addEventListener('input', checkValues);
              inputFora.addEventListener('input', checkValues);

              // Inicializa sequências a partir dos valores dos campos ocultos
              const hiddenM = document.getElementById('hidden_sequencia_mandante');
              const hiddenV = document.getElementById('hidden_sequencia_visitante');
              
              if (hiddenM && hiddenM.value) {
                sequencias.mandante = hiddenM.value.split(',').map(Number);
              } else {
                sequencias.mandante = [];
              }

              if (hiddenV && hiddenV.value) {
                sequencias.visitante = hiddenV.value.split(',').map(Number);
              } else {
                sequencias.visitante = [];
              }

              renderizarCobrancas('mandante');
              renderizarCobrancas('visitante');

              // Executa inicialmente
              checkValues();
            }

            function renderizarCobrancas(time) {
              const container = document.getElementById('cobrancas_' + time);
              if (!container) return;

              container.innerHTML = '';
              
              sequencias[time].forEach((val, idx) => {
                const wrapper = document.createElement('div');
                wrapper.className = 'relative flex items-center';

                const btn = document.createElement('button');
                btn.type = 'button';
                if (val === 1) {
                  btn.className = 'w-9 h-9 rounded-full bg-emerald-500 hover:bg-emerald-600 text-white flex items-center justify-center text-sm font-bold shadow-md cursor-pointer transition';
                  btn.innerHTML = '🟢';
                } else {
                  btn.className = 'w-9 h-9 rounded-full bg-rose-500 hover:bg-rose-600 text-white flex items-center justify-center text-sm font-bold shadow-md cursor-pointer transition';
                  btn.innerHTML = '❌';
                }

                btn.onclick = () => {
                  sequencias[time][idx] = sequencias[time][idx] === 1 ? 0 : 1;
                  salvarEAtualizar(time);
                };

                const delBtn = document.createElement('span');
                delBtn.className = 'absolute -top-1.5 -right-1.5 w-4 h-4 bg-neutral text-neutral-content hover:bg-neutral-focus rounded-full flex items-center justify-center text-[10px] font-black cursor-pointer shadow border border-base-100 transition';
                delBtn.innerHTML = '×';
                delBtn.onclick = (e) => {
                  e.stopPropagation();
                  sequencias[time].splice(idx, 1);
                  salvarEAtualizar(time);
                };

                wrapper.appendChild(btn);
                wrapper.appendChild(delBtn);
                container.appendChild(wrapper);
              });

              if (sequencias[time].length === 0) {
                const placeholder = document.createElement('span');
                placeholder.className = 'text-xs opacity-40 font-medium italic';
                placeholder.innerHTML = 'Nenhum chute adicionado';
                container.appendChild(placeholder);
              }
            }

            function salvarEAtualizar(time) {
              const hiddenInput = document.getElementById('hidden_sequencia_' + time);
              if (hiddenInput) {
                hiddenInput.value = sequencias[time].join(',');
              }
              
              const totalGols = sequencias[time].filter(val => val === 1).length;
              const placarInput = document.getElementById('gols_penaltis_' + time);
              if (placarInput) {
                placarInput.value = totalGols;
              }

              renderizarCobrancas(time);
            }

            // Disponibilizar globalmente no escopo do IIFE para os botões do HTML
            window.adicionarCobranca = function(time) {
              sequencias[time].push(1);
              salvarEAtualizar(time);
            };

            document.addEventListener("turbo:load", setupPenaltis);
            setupPenaltis();
          })();
        </script>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
          <%= link_to "Cancelar",
            jogo_path(@jogo),
            class: "btn btn-ghost" %>

          <%= form.submit "Finalizar e Pontuar",
            class: "btn btn-primary btn-lg px-12 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
