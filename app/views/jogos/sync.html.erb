<% content_for :title, "Sincronizar Jogos" %>

<div class="w-full max-w-5xl mx-auto px-4 py-8">
  <h1 class="font-bold text-4xl mb-6">Sincronizar jogos com API Football</h1>

  <% if @sync_report[:error].present? %>
    <div class="alert alert-error mb-6">
      <span><%= @sync_report[:error] %></span>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">
    <div class="card bg-base-100 shadow-lg p-5">
      <p class="text-sm uppercase opacity-70">Jogos atualizados</p>
      <p class="text-3xl font-bold mt-2"><%= @sync_report[:updated].size %></p>
    </div>
    <div class="card bg-base-100 shadow-lg p-5">
      <p class="text-sm uppercase opacity-70">Não encontrados</p>
      <p class="text-3xl font-bold mt-2"><%= @sync_report[:skipped].size %></p>
    </div>
    <div class="card bg-base-100 shadow-lg p-5">
      <p class="text-sm uppercase opacity-70">Erros</p>
      <p class="text-3xl font-bold mt-2"><%= @sync_report[:errors].size %></p>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6 mb-8">
    <div class="card bg-base-100 shadow-lg p-5">
      <h2 class="font-bold text-xl mb-4">Artilheiros</h2>
      <% if @sync_report[:scorers].any? %>
        <ol class="list-decimal list-inside space-y-2">
          <% @sync_report[:scorers].sort_by { |_, count| -count }.first(6).each do |name, count| %>
            <li class="flex justify-between gap-4">
              <span><%= name %></span>
              <span class="font-bold"><%= count %> gol(s)</span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-sm opacity-70">Nenhuma informação de gols encontrada.</p>
      <% end %>
    </div>

    <div class="card bg-base-100 shadow-lg p-5">
      <h2 class="font-bold text-xl mb-4">Assistências</h2>
      <% if @sync_report[:assists].any? %>
        <ol class="list-decimal list-inside space-y-2">
          <% @sync_report[:assists].sort_by { |_, count| -count }.first(6).each do |name, count| %>
            <li class="flex justify-between gap-4">
              <span><%= name %></span>
              <span class="font-bold"><%= count %> assist(s)</span>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-sm opacity-70">Nenhuma informação de assistência encontrada.</p>
      <% end %>
    </div>
  </div>

  <div class="space-y-6">
    <% @sync_report[:updated].each do |entry| %>
      <div class="card bg-base-100 shadow-lg p-5">
        <div class="flex flex-col gap-2">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="font-semibold"><%= entry[:jogo].mandante&.nome || entry[:jogo].nome_provisorio_mandante %> x <%= entry[:jogo].visitante&.nome || entry[:jogo].nome_provisorio_visitante %></p>
              <p class="text-sm opacity-70">Status API: <%= entry[:api_status] %> · Local: <%= entry[:jogo].data.strftime('%d/%m/%Y %H:%M') %></p>
            </div>
            <span class="badge badge-primary">Placar: <%= entry[:gols_mandante] %> - <%= entry[:gols_visitante] %></span>
          </div>
          <p class="text-sm opacity-60">Antes: <%= entry[:old_status].humanize %> · Agora: <%= entry[:new_status].humanize %></p>
        </div>
      </div>
    <% end %>
  </div>

  <% if @sync_report[:skipped].any? %>
    <div class="card bg-base-100 shadow-lg p-5 mt-8">
      <h2 class="font-bold text-xl mb-4">Jogos não sincronizados</h2>
      <ul class="list-disc list-inside space-y-2">
        <% @sync_report[:skipped].each do |entry| %>
          <li><strong><%= entry[:jogo].mandante&.nome || entry[:jogo].nome_provisorio_mandante %> x <%= entry[:jogo].visitante&.nome || entry[:jogo].nome_provisorio_visitante %></strong> — <%= entry[:reason] %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @sync_report[:errors].any? %>
    <div class="card bg-red-50 border border-red-200 shadow-lg p-5 mt-8">
      <h2 class="font-bold text-xl text-red-600 mb-4">Erros encontrados</h2>
      <ul class="list-disc list-inside space-y-2 text-sm text-red-700">
        <% @sync_report[:errors].each do |entry| %>
          <li><strong><%= entry[:jogo].mandante&.nome || entry[:jogo].nome_provisorio_mandante %> x <%= entry[:jogo].visitante&.nome || entry[:jogo].nome_provisorio_visitante %></strong> — <%= entry[:message] %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
