<% content_for :title, "Jogos" %>

<div class="w-full max-w-6xl mx-auto px-4">
  <h1 class="font-bold text-4xl text-center mb-8 p-4 pb-8 pt-8">
    Jogos
  </h1>

  <div class="flex justify-center items-center gap-2 mb-6 flex-wrap">
    <%= link_to "Fase de grupos",
      jogos_path(tipo: :grupo),
      class: "btn #{ @tipo_ativo == 'grupo' ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>

    <%= link_to "Segunda fase",
      jogos_path(tipo: :segunda_fase),
      class: "btn #{ @tipo_ativo == 'segunda_fase' ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>

    <%= link_to "Oitavas",
      jogos_path(tipo: :oitavas),
      class: "btn #{ @tipo_ativo == 'oitavas' ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>

    <%= link_to "Quartas",
      jogos_path(tipo: :quartas),
      class: "btn #{ @tipo_ativo == 'quartas' ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>

    <%= link_to "Semi",
      jogos_path(tipo: :semi),
      class: "btn #{ @tipo_ativo == 'semi' ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>

    <%= link_to "Terceiro lugar",
      jogos_path(tipo: :terceiro_lugar),
      class: "btn #{ @tipo_ativo == 'terceiro_lugar' ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>

    <%= link_to "Final",
      jogos_path(tipo: :final),
      class: "btn #{ @tipo_ativo == 'final' ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>

    <% if current_user.root? %>
      <button class="btn btn-outline" onclick="modal_filtros_jogos.showModal()">
        Filtros
      </button>
    <% end %>
  </div>

  <dialog id="modal_filtros_jogos" class="modal">
    <div class="modal-box max-w-lg">
      <h3 class="font-bold text-lg mb-4 text-center">Filtrar Jogos</h3>
      <%= form_with url: jogos_path, method: :get, local: true do |f| %>
        <%= f.hidden_field :tipo, value: @tipo_ativo %>
        <%= f.hidden_field :grupo, value: @grupo_ativo %>
        
        <div class="space-y-4">
          <div class="form-control">
            <label class="label"><span class="label-text">Status</span></label>
            <%= f.select :status, Jogo.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "Todos os Status", selected: params[:status] }, class: "select select-bordered w-full" %>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="form-control">
              <label class="label"><span class="label-text">Data Início</span></label>
              <%= f.date_field :start_date, value: params[:start_date], class: "input input-bordered w-full" %>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">Data Fim</span></label>
              <%= f.date_field :end_date, value: params[:end_date], class: "input input-bordered w-full" %>
            </div>
          </div>
        </div>

        <div class="modal-action flex justify-between mt-6">
          <%= link_to "Limpar", jogos_path(tipo: @tipo_ativo, grupo: @grupo_ativo), class: "btn btn-ghost bg-error text-white" %>
          <div class="flex gap-2">
            <button type="button" class="btn" onclick="modal_filtros_jogos.close()">Cancelar</button>
            <%= f.submit "Aplicar", class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </dialog>

  <% if @tipo_ativo == 'grupo' %>
    <div class="flex justify-center items-center gap-2 mb-6 flex-wrap">
      <% Grupo.order(:nome).each do |grupo| %>
        <%= link_to grupo.nome,
          jogos_path(tipo: :grupo, grupo: grupo.id),
          class: "btn btn-sm #{ @grupo_ativo.to_s == grupo.id.to_s ? 'bg-primary text-white border-primary' : 'btn-outline btn-white hover:bg-primary' }" %>
      <% end %>
    </div>
  <% end %>

  <div id="tab-grupos">
    <% if @jogos.any? %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 w-full">
        <% @jogos.each do |jogo| %>
          <% palpite = jogo.palpites.find { |p| p.user_id == current_user.id } %>
          <div class="card bg-base-100 shadow-lg hover:shadow-xl transition cursor-pointer border border-base-200" onclick="window.location='<%= jogo_path(jogo) %>'">
            <div class="card-body p-4 sm:p-6">
              
              <div class="flex justify-between items-start mb-4">
                <div class="text-xs font-semibold opacity-70">
                  <div><%= jogo.data.strftime("%d/%m/%Y %H:%M") %></div>
                  <div><%= jogo.estadio %></div>
                </div>

                <div class="uppercase text-[10px] sm:text-xs font-bold">
                  <div class="flex items-center gap-2 justify-end">
                    <div class="inline-grid *:[grid-area:1/1]">
                      <% if jogo.programado? %>
                        <div class="status status-info animate-ping"></div>
                        <div class="status status-info"></div>
                      <% elsif jogo.em_andamento? %>
                        <div class="status status-success animate-ping"></div>
                        <div class="status status-success"></div>
                      <% elsif jogo.finalizado? %>
                        <div class="status status-error animate-ping"></div>
                        <div class="status status-error"></div>
                      <% elsif jogo.times_a_definir? %>
                        <div class="status status-primary animate-ping"></div>
                        <div class="status status-primary"></div>
                      <% end %>
                    </div>
                    <span>
                      <%= jogo.status.humanize %>
                    </span>
                  </div>
                </div>
              </div>

              <div class="flex justify-between items-center bg-base-200/50 rounded-box p-3 sm:p-4 mb-4">
                <div class="flex flex-col items-center flex-1 w-1/3">
                  <div class="avatar mb-2">
                    <div class="mask mask-squircle h-10 w-10 sm:h-12 sm:w-12">
                      <% if jogo.mandante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.mandante.logo}" %>
                      <% else %>
                        <div class="w-full h-full flex items-center justify-center bg-base-300 text-lg font-bold">?</div>
                      <% end %>
                    </div>
                  </div>
                  <div class="font-bold text-center text-xs sm:text-sm leading-tight">
                    <%= jogo.mandante&.nome || jogo.nome_provisorio_mandante.presence || "[ A definir ]" %>
                  </div>
                </div>

                <div class="flex flex-col items-center justify-center px-2 sm:px-4">
                  <% if palpite.present? %>
                    <div class="text-[10px] sm:text-xs uppercase font-bold text-primary mb-1">
                      Palpite: <%= palpite.gols_casa %> - <%= palpite.gols_fora %>
                    </div>
                  <% end %>
                  <div class="text-2xl sm:text-3xl font-black font-mono tracking-widest whitespace-nowrap">
                    <%= jogo.gols_mandante %> - <%= jogo.gols_visitante %>
                  </div>
                </div>

                <div class="flex flex-col items-center flex-1 w-1/3">
                  <div class="avatar mb-2">
                    <div class="mask mask-squircle h-10 w-10 sm:h-12 sm:w-12">
                      <% if jogo.visitante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.visitante.logo}" %>
                      <% else %>
                        <div class="w-full h-full flex items-center justify-center bg-base-300 text-lg font-bold">?</div>
                      <% end %>
                    </div>
                  </div>
                  <div class="font-bold text-center text-xs sm:text-sm leading-tight">
                    <%= jogo.visitante&.nome || jogo.nome_provisorio_visitante.presence || "[ A definir ]" %>
                  </div>
                </div>
              </div>

              <div class="card-actions justify-center mt-auto" onclick="event.stopPropagation()">
                <% if jogo.finalizado? || jogo.em_andamento? %>
                  <span class="badge badge-neutral p-3 sm:p-4 font-bold w-full">Fechado</span>
                <% elsif jogo.times_a_definir? || jogo.definir? %>
                  <span class="badge badge-neutral p-3 sm:p-4 font-bold w-full">Indisponível</span>
                <% elsif palpite.present? %>
                  <%= link_to "Editar palpite",
                    edit_palpite_path(palpite),
                    class: "btn btn-sm btn-warning w-full font-bold" %>
                <% else %>
                  <%= link_to "Palpitar",
                    new_palpite_path(jogo_id: jogo.id),
                    class: "btn btn-sm btn-primary w-full font-bold" %>
                <% end %>
              </div>

            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-center text-gray-500 mt-10">
        Nenhum jogo encontrado.
      </p>
    <% end %>
  </div>

  <div class="mt-10 flex justify-center gap-4">
    <% if current_user.root? %>
      <%= link_to "Novo jogo",
        new_jogo_path,
        class: "rounded-md px-5 py-3 bg-primary hover:bg-primary/90 text-white font-medium" %>
    <% end %>
  </div>

  <script>
    function showTab(tab) {
      const tabs = ['grupos', 'oitavas', 'quartas', 'semi', 'final']

      tabs.forEach(t => {
        const element = document.getElementById(`tab-${t}`)

        if (element) {
          element.classList.add('hidden')
        }
      })

      const selectedTab = document.getElementById(`tab-${tab}`)

      if (selectedTab) {
        selectedTab.classList.remove('hidden')
      }

      document.querySelectorAll('[data-tab]').forEach(button => {
        button.classList.remove('bg-primary', 'text-white', 'border-primary')
        button.classList.add('btn-outline', 'btn-white')
      })

      const activeButton = document.querySelector(`[data-tab="${tab}"]`)

      if (activeButton) {
        activeButton.classList.remove('btn-outline', 'btn-white')
        activeButton.classList.add('bg-primary', 'text-white', 'border-primary')
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      showTab('grupos')
    })
  </script>
</div>