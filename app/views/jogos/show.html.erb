<% content_for :title, "Detalhes do Jogo" %>

<div class="max-w-3xl mx-auto px-4 py-8 space-y-6">
  <div class="items-center border-b border-base-200 pb-4">
    <!-- Lado Central: Badge Perfeitamente Centralizada -->
    <div class="flex justify-center text-center">
      <span class="badge badge-outline badge-md uppercase tracking-wider font-semibold opacity-70 whitespace-nowrap">
        <%=
          case @jogo.tipo
          when "grupo"
            @jogo.mandante&.grupo.present? ? "Grupo #{@jogo.mandante.grupo.nome.last}" : "Fase de Grupos"
          else
            @jogo.tipo.humanize
          end
        %>
      </span>
    </div>

    <!-- Lado Direito: Vazio para equilibrar o Grid e manter o centro perfeito -->
    <div></div>
  </div>

  <div class="bg-base-100 rounded-3xl border border-base-200 p-6 sm:p-8 shadow-sm text-center space-y-6">
    <div class="text-xs opacity-60 font-medium space-y-1">
      <p><%= @jogo.data.present? ? l(@jogo.data, format: :long) : "Data a definir" %></p>
      <p class="opacity-40"><%= @jogo.estadio.presence || "Estádio a definir" %></p>
    </div>

    <div class="flex flex-row items-center justify-center gap-1 sm:gap-6 py-4 w-full min-w-0">
      
      <% if @jogo.mandante.present? %>
        <%= link_to selecao_path(@jogo.mandante), class: "flex items-center justify-end gap-1.5 sm:gap-3 flex-1 min-w-0 group" do %>
          <span class="font-extrabold text-sm sm:text-2xl text-base-content leading-tight truncate text-right group-hover:underline">
            <%= @jogo.mandante.nome %>
          </span>
          <div class="mask mask-squircle h-8 w-8 sm:h-12 sm:w-12 bg-base-200 flex items-center justify-center shrink-0 overflow-hidden shadow-inner transition duration-300 group-hover:scale-105">
            <% if @jogo.mandante.logo.present? %>
              <%= image_tag "selecoes/#{@jogo.mandante.logo}", class: "object-cover w-full h-full" %>
            <% else %>
              <span class="text-xs sm:text-xl font-bold">?</span>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="flex items-center justify-end gap-1.5 sm:gap-3 flex-1 min-w-0 opacity-60">
          <span class="font-extrabold text-sm sm:text-2xl text-base-content/70 leading-tight truncate text-right">
            <%= @jogo.nome_provisorio_mandante.presence || "Mandante" %>
          </span>
          <div class="mask mask-squircle h-8 w-8 sm:h-12 sm:w-12 bg-base-200 flex items-center justify-center shrink-0 overflow-hidden shadow-inner text-xs sm:text-xl font-bold">
            ?
          </div>
        </div>
      <% end %>

      <div class="flex items-center justify-center gap-1 sm:gap-3 shrink-0 px-1 select-none">
        <% if @jogo.programado? || @jogo.times_a_definir? %>
          <span class="text-sm sm:text-2xl font-black opacity-30 px-3 py-1 bg-base-200 rounded-xl">VS</span>
        <% else %>
          <span class="text-xl sm:text-4xl font-black px-2.5 sm:px-4 bg-base-200 rounded-xl sm:rounded-2xl py-1 sm:py-2 shadow-inner min-w-[2.2rem] sm:min-w-[3.5rem] text-center">
            <%= @jogo.gols_mandante %>
          </span>
          <span class="text-sm sm:text-xl opacity-40 font-bold">:</span>
          <span class="text-xl sm:text-4xl font-black px-2.5 sm:px-4 bg-base-200 rounded-xl sm:rounded-2xl py-1 sm:py-2 shadow-inner min-w-[2.2rem] sm:min-w-[3.5rem] text-center">
            <%= @jogo.gols_visitante %>
          </span>
        <% end %>
      </div>

      <% if @jogo.visitante.present? %>
        <%= link_to selecao_path(@jogo.visitante), class: "flex items-center justify-start gap-1.5 sm:gap-3 flex-1 min-w-0 group" do %>
          <div class="mask mask-squircle h-8 w-8 sm:h-12 sm:w-12 bg-base-200 flex items-center justify-center shrink-0 overflow-hidden shadow-inner transition duration-300 group-hover:scale-105">
            <% if @jogo.visitante.logo.present? %>
              <%= image_tag "selecoes/#{@jogo.visitante.logo}", class: "object-cover w-full h-full" %>
            <% else %>
              <span class="text-xs sm:text-xl font-bold">?</span>
            <% end %>
          </div>
          <span class="font-extrabold text-sm sm:text-2xl text-base-content leading-tight truncate text-left group-hover:underline">
            <%= @jogo.visitante.nome %>
          </span>
        <% end %>
      <% else %>
        <div class="flex items-center justify-start gap-1.5 sm:gap-3 flex-1 min-w-0 opacity-60">
          <div class="mask mask-squircle h-8 w-8 sm:h-12 sm:w-12 bg-base-200 flex items-center justify-center shrink-0 overflow-hidden shadow-inner text-xs sm:text-xl font-bold">
            ?
          </div>
          <span class="font-extrabold text-sm sm:text-2xl text-base-content/70 leading-tight truncate text-left">
            <%= @jogo.nome_provisorio_visitante.presence || "Visitante" %>
          </span>
        </div>
      <% end %>

    </div>

    <div class="flex justify-center">
      <% if @jogo.em_andamento? %>
        <span class="badge badge-success gap-1.5 font-bold animate-pulse">
          <span class="w-2 h-2 rounded-full bg-white"></span>
          Em Andamento
        </span>
      <% elsif @jogo.finalizado? %>
        <span class="badge badge-error gap-1.5 font-bold text-white">
          Finalizado
        </span>
      <% else %>
        <span class="badge badge-info gap-1.5 font-bold text-white">
          Programado
        </span>
      <% end %>
    </div>
  </div>

  <% if @jogo.prob_mandante.present? && !current_user.esconder_odds %>
    <div class="bg-base-100 rounded-2xl border border-base-200 p-5 space-y-3">
      <h3 class="text-xs font-bold uppercase tracking-wider text-base-content/60 text-center">Probabilidades do System</h3>
      <div class="flex items-center justify-between text-sm font-semibold">
        <span class="text-success"><%= @jogo.mandante&.nome || 'Casa' %>: <%= @jogo.prob_mandante %>%</span>
        <span class="text-base-content/70">Empate: <%= @jogo.prob_empate %>%</span>
        <span class="text-error"><%= @jogo.visitante&.nome || 'Fora' %>: <%= @jogo.prob_visitante %>%</span>
      </div>
      <div class="flex h-3 w-full rounded-full overflow-hidden bg-base-200">
        <div class="bg-success" style="width: <%= @jogo.prob_mandante %>%;" title="Vitória <%= @jogo.mandante&.nome %>"></div>
        <div class="bg-base-content/25" style="width: <%= @jogo.prob_empate %>%;" title="Empate"></div>
        <div class="bg-error" style="width: <%= @jogo.prob_visitante %>%;" title="Vitória <%= @jogo.visitante&.nome %>"></div>
      </div>
    </div>
  <% end %>

  <div class="bg-base-100 rounded-3xl border border-base-200 p-6 shadow-sm space-y-4">
    <div class="flex items-center justify-between border-b border-base-200 pb-3">
      <h3 class="font-extrabold text-lg flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-primary">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.504-1.125-1.125-1.125h-2.25a1.125 1.125 0 0 0-1.125 1.125V18.75m9 0h-9M12 2.25a3 3 0 0 0-3 3v1.5a3 3 0 0 0 6 0v-1.5a3 3 0 0 0-3-3Z" />
        </svg>
        Seu Palpite
      </h3>

      <% if @palpite && @jogo.programado? %>
        <%= link_to "Editar Palpite", edit_palpite_path(@palpite), class: "btn btn-outline btn-xs btn-primary font-bold" %>
      <% end %>
    </div>

    <% if @palpite %>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-2">
        <div class="flex items-center gap-4 text-center">
          <!-- Links nos nomes e imagens dentro da seção de palpites -->
          <% if @jogo.mandante.present? %>
            <%= link_to @jogo.mandante.nome, selecao_path(@jogo.mandante), class: "text-sm font-semibold opacity-70 hover:underline hover:text-primary" %>
          <% else %>
            <span class="text-sm font-semibold opacity-70">Casa</span>
          <% end %>
          
          <span class="text-2xl font-black px-3 py-1 bg-base-200 rounded-xl"><%= @palpite.gols_casa %></span>
          <span class="opacity-40">x</span>
          <span class="text-2xl font-black px-3 py-1 bg-base-200 rounded-xl"><%= @palpite.gols_fora %></span>
          
          <% if @jogo.visitante.present? %>
            <%= link_to @jogo.visitante.nome, selecao_path(@jogo.visitante), class: "text-sm font-semibold opacity-70 hover:underline hover:text-primary" %>
          <% else %>
            <span class="text-sm font-semibold opacity-70">Fora</span>
          <% end %>
        </div>

        <div class="text-center sm:text-right">
          <% if @jogo.finalizado? %>
            <% if @user_point %>
              <div class="space-y-1">
                <span class="badge badge-success text-white font-bold py-3 px-4 text-sm">
                  +<%= @user_point.pontos %> Pontos
                </span>
                <p class="text-xs opacity-60"><%= @user_point.motivo %></p>
              </div>
            <% else %>
              <span class="badge badge-ghost font-bold py-3 px-4 text-xs opacity-60">
                0 Pontos acumulados
              </span>
            <% end %>
          <% else %>
            <span class="badge badge-outline font-bold text-xs opacity-60 py-3 px-4">
              Aguardando resultado
            </span>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="py-4 text-center space-y-3">
        <p class="text-sm opacity-60">Você ainda não registrou palpite para este jogo.</p>
        <% if @jogo.programado? %>
          <%= link_to new_palpite_path(jogo_id: @jogo.uuid), class: "btn btn-primary btn-sm font-bold shadow-md shadow-primary/20" do %>
            Registrar Palpite
          <% end %>
        <% else %>
          <span class="badge badge-ghost opacity-50 py-3 px-4 font-bold text-xs">Palpites encerrados</span>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @jogo.finalizado? %>
    <% info = @jogo.informacao_jogo %>
    <div class="bg-base-100 rounded-3xl border border-base-200 p-6 shadow-sm space-y-6">
      <div class="flex items-center justify-between border-b border-base-200 pb-3">
        <h3 class="font-extrabold text-lg flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
          </svg>
          Estatísticas da Partida
        </h3>

        <% if current_user.root? && (info.nil? || info.dados.blank?) %>
          <%= button_to sync_statistics_jogo_path(@jogo), method: :post, class: "btn btn-outline btn-xs btn-primary font-bold gap-1 flex items-center" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Sincronizar
          <% end %>
        <% end %>
      </div>

      <% if info && info.dados.present? %>
        <%
          h_stats = info.dados['home'] || {}
          a_stats = info.dados['away'] || {}
        %>
        
        <div class="space-y-4">
          <!-- Item: Posse de bola -->
          <% if h_stats['possessionPct'].present? %>
            <div class="space-y-1">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
                <span><%= h_stats['possessionPct'] %>%</span>
                <span>Posse de Bola</span>
                <span><%= a_stats['possessionPct'] %>%</span>
              </div>
              <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-200">
                <div class="bg-primary" style="width: <%= h_stats['possessionPct'] %>%;"></div>
                <div class="bg-accent" style="width: <%= a_stats['possessionPct'] %>%;"></div>
              </div>
            </div>
          <% end %>

          <!-- Item: Chutes no gol -->
          <% if h_stats['shotsOnGoal'].present? %>
            <div class="space-y-1">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
                <span><%= h_stats['shotsOnGoal'] %></span>
                <span>Chutes no Gol</span>
                <span><%= a_stats['shotsOnGoal'] %></span>
              </div>
              <%
                total_sog = h_stats['shotsOnGoal'].to_f + a_stats['shotsOnGoal'].to_f
                pct_h_sog = total_sog > 0 ? (h_stats['shotsOnGoal'].to_f / total_sog * 100).round : 50
                pct_a_sog = 100 - pct_h_sog
              %>
              <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-200">
                <div class="bg-primary" style="width: <%= pct_h_sog %>%;"></div>
                <div class="bg-accent" style="width: <%= pct_a_sog %>%;"></div>
              </div>
            </div>
          <% end %>

          <!-- Item: Chutes totais -->
          <% if h_stats['shotsTotal'].present? %>
            <div class="space-y-1">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
                <span><%= h_stats['shotsTotal'] %></span>
                <span>Finalizações</span>
                <span><%= a_stats['shotsTotal'] %></span>
              </div>
              <%
                total_shots = h_stats['shotsTotal'].to_f + a_stats['shotsTotal'].to_f
                pct_h_shots = total_shots > 0 ? (h_stats['shotsTotal'].to_f / total_shots * 100).round : 50
                pct_a_shots = 100 - pct_h_shots
              %>
              <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-200">
                <div class="bg-primary" style="width: <%= pct_h_shots %>%;"></div>
                <div class="bg-accent" style="width: <%= pct_a_shots %>%;"></div>
              </div>
            </div>
          <% end %>

          <!-- Item: Faltas -->
          <% if h_stats['fouls'].present? %>
            <div class="space-y-1">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
                <span><%= h_stats['fouls'] %></span>
                <span>Faltas</span>
                <span><%= a_stats['fouls'] %></span>
              </div>
              <%
                total_fouls = h_stats['fouls'].to_f + a_stats['fouls'].to_f
                pct_h_fouls = total_fouls > 0 ? (h_stats['fouls'].to_f / total_fouls * 100).round : 50
                pct_a_fouls = 100 - pct_h_fouls
              %>
              <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-200">
                <div class="bg-primary" style="width: <%= pct_h_fouls %>%;"></div>
                <div class="bg-accent" style="width: <%= pct_a_fouls %>%;"></div>
              </div>
            </div>
          <% end %>

          <!-- Item: Escanteios -->
          <% if h_stats['corners'].present? %>
            <div class="space-y-1">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
                <span><%= h_stats['corners'] %></span>
                <span>Escanteios</span>
                <span><%= a_stats['corners'] %></span>
              </div>
              <%
                total_corners = h_stats['corners'].to_f + a_stats['corners'].to_f
                pct_h_corners = total_corners > 0 ? (h_stats['corners'].to_f / total_corners * 100).round : 50
                pct_a_corners = 100 - pct_h_corners
              %>
              <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-200">
                <div class="bg-primary" style="width: <%= pct_h_corners %>%;"></div>
                <div class="bg-accent" style="width: <%= pct_a_corners %>%;"></div>
              </div>
            </div>
          <% end %>

          <!-- Item: Impedimentos -->
          <% if h_stats['offsides'].present? %>
            <div class="space-y-1">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
                <span><%= h_stats['offsides'] %></span>
                <span>Impedimentos</span>
                <span><%= a_stats['offsides'] %></span>
              </div>
              <%
                total_offsides = h_stats['offsides'].to_f + a_stats['offsides'].to_f
                pct_h_offsides = total_offsides > 0 ? (h_stats['offsides'].to_f / total_offsides * 100).round : 50
                pct_a_offsides = 100 - pct_h_offsides
              %>
              <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-200">
                <div class="bg-primary" style="width: <%= pct_h_offsides %>%;"></div>
                <div class="bg-accent" style="width: <%= pct_a_offsides %>%;"></div>
              </div>
            </div>
          <% end %>

          <!-- Item: Precisão de passes -->
          <% if h_stats['passesPct'].present? %>
            <div class="space-y-1">
              <div class="flex justify-between text-xs font-bold uppercase tracking-wider text-slate-400">
                <span><%= h_stats['passesPct'] %>% (<%= h_stats['passesAccurate'] %>/<%= h_stats['passesTotal'] %>)</span>
                <span>Precisão de Passes</span>
                <span><%= a_stats['passesPct'] %>% (<%= a_stats['passesAccurate'] %>/<%= a_stats['passesTotal'] %>)</span>
              </div>
              <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-200">
                <div class="bg-primary" style="width: <%= h_stats['passesPct'] %>%;"></div>
                <div class="bg-accent" style="width: <%= a_stats['passesPct'] %>%;"></div>
              </div>
            </div>
          <% end %>
        </div>

      <% else %>
        <div class="py-4 text-center space-y-2">
          <p class="text-sm opacity-60">Estatísticas da partida não sincronizadas.</p>
          <% if current_user.root? %>
            <%= button_to sync_statistics_jogo_path(@jogo), method: :post, class: "btn btn-primary btn-sm font-bold shadow-md shadow-primary/20" do %>
              Sincronizar Estatísticas
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if current_user.root? %>
    <div class="bg-base-200/50 rounded-2xl border border-base-200 p-4 space-y-3">
      <h4 class="text-xs font-bold uppercase tracking-wider text-base-content/60 text-center">Ferramentas de Administrador</h4>
      <div class="flex flex-wrap gap-2 justify-center">
        <%= link_to "Editar Jogo", edit_jogo_path(@jogo), class: "btn btn-warning btn-sm font-bold" %>
        
        <%= button_to "Excluir Jogo", @jogo, method: :delete, class: "btn btn-error btn-sm font-bold text-white", data: { turbo_confirm: "Tem certeza?" } %>

        <% if @jogo.programado? %>
          <%= button_to "Iniciar Partida", start_jogo_path(@jogo), method: :patch, class: "btn btn-success btn-sm font-bold text-white", data: { turbo_confirm: "Deseja iniciar a partida? Todos os palpiteiros serão notificados." } %>
        <% elsif @jogo.em_andamento? %>
          <%= link_to "Finalizar Partida", finalize_jogo_path(@jogo), class: "btn btn-info btn-sm font-bold text-white" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>