<div class="min-h-screen flex items-center justify-center bg-base-300 px-4">
  <div class="card w-full max-w-md bg-base-100 shadow-xl p-16">
    <div class="card-body">
      <h1 class="text-2xl font-bold text-center mb-6">
        Redefinir senha
      </h1>

      <%= form_with model: @user,
        url: edit_password_path(params[:token]),
        method: :patch,
        class: "space-y-4" do |f| %>

        <div class="form-control">
          <%= f.label :password, 'Nova senha', class: "label pb-2" %>
          <%= f.password_field :password,
            required: true,
            class: "input input-bordered input-ghost bg-base-200 w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :password_confirmation, 'Confirmar senha', class: "label pb-2" %>
          <%= f.password_field :password_confirmation,
            required: true,
            class: "input input-bordered input-ghost bg-base-200 w-full" %>
        </div>

        <div class="form-control mt-6">
          <%= f.submit 'Redefinir senha',
            class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
