<div class="w-full max-w-4xl mx-auto px-4 py-8" data-controller="checkout-status" data-checkout-status-id-value="<%= @cobranca.id %>">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Assinatura</span>
        <span>/</span>
        <span>Pagamento</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Checkout Pix
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Finalize o pagamento para ativar o OrangScore Premium.</p>
    </div>

    <%= link_to assinaturas_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <div class="flex justify-center items-center py-4">
    <div class="bg-[#1a2236] p-10 rounded-[3rem] text-center max-w-lg w-full border border-primary/20 shadow-2xl relative overflow-hidden">
      <!-- Efeito de Luz -->
      <div class="absolute -top-24 -left-24 w-48 h-48 bg-primary/20 blur-3xl rounded-full"></div>
      
      <div class="relative">
        <div class="w-20 h-20 bg-emerald-500/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>

        <h2 class="text-2xl font-black text-white mb-2 uppercase tracking-tighter">
          Pagamento via Pix
        </h2>
        <p class="text-slate-400 mb-8 font-medium">Escaneie o QR Code abaixo para finalizar</p>

        <!-- QR Code -->
        <div class="bg-white p-4 rounded-3xl inline-block mb-8 shadow-xl border-4 border-primary/10">
          <img src="data:image/png;base64,<%= @cobranca.pix_qr_code_base64 %>" class="w-64 h-64 mx-auto" alt="QR Code Pix" />
        </div>

        <div class="space-y-4">
          <div class="bg-white/5 p-4 rounded-2xl border border-white/10 text-left">
            <span class="block text-[10px] uppercase font-black text-primary tracking-widest mb-1">Código Pix</span>
            <div class="flex items-center gap-3">
              <input type="text" value="<%= @cobranca.pix_qr_code %>" id="pix-code" readonly class="bg-transparent border-none text-white text-xs w-full focus:ring-0 font-mono" />
              <button onclick="copyPixCode()" class="btn btn-primary btn-sm rounded-xl px-4">Copiar</button>
            </div>
          </div>

          <div class="flex items-center justify-center gap-3 py-4 text-emerald-500">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
            </span>
            <span class="text-sm font-bold animate-pulse">Aguardando confirmação...</span>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-white/5 flex flex-col gap-3">
          <%= link_to "Já paguei, voltar para o Dashboard", root_path, class: "btn btn-ghost text-slate-400 hover:text-white rounded-2xl" %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function copyPixCode() {
    const copyText = document.getElementById("pix-code");
    copyText.select();
    copyText.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(copyText.value);
    
    // Feedback visual do botão
    const btn = event.target;
    const originalText = btn.innerText;
    btn.innerText = "Copiado!";
    btn.classList.replace('btn-primary', 'btn-success');
    setTimeout(() => {
      btn.innerText = originalText;
      btn.classList.replace('btn-success', 'btn-primary');
    }, 2000);
  }

  // Polling simples para verificar o status (opcional, já que temos Webhook)
  // Mas ajuda na experiência do usuário
  // Polling para verificar o status
  const pollingInterval = setInterval(() => {
    fetch('<%= checkout_pix_path(@cobranca, format: :json) %>?t=' + Date.now())
      .then(response => response.json())
      .then(data => {
        if (data.status === 'approved' || data.status === 'pago') {
          clearInterval(pollingInterval);
          <% if @cobranca.plano == "doacao" %>
            window.location.href = '<%= checkout_obrigado_path %>';
          <% else %>
            window.location.href = '<%= checkout_sucesso_path %>';
          <% end %>
        }
      })
      .catch(err => console.error("Erro no polling:", err));
  }, 3000);
</script>