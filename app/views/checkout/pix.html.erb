<div class="max-w-md mx-auto card bg-base-200 shadow-xl mt-10">
  <div class="card-body items-center text-center gap-4">
    <h2 class="card-title text-2xl font-bold text-white">Pagamento via Pix</h2>
    
    <div class="bg-white p-4 rounded-2xl mb-2">
      <img
        class="w-64 h-64 object-contain"
        src="data:image/png;base64,<%= @cobranca.pix_qr_code_base64 %>"
        alt="QR Code Pix"
      >
    </div>

    <div class="w-full text-left">
      <label class="label">
        <span class="label-text font-semibold text-white">Pix Copia e Cola</span>
      </label>
      <div class="relative">
        <textarea
          id="pix-code"
          readonly
          class="textarea textarea-bordered w-full h-24 text-xs font-mono leading-tight pr-12 bg-gray-800 text-white"><%= @cobranca.pix_qr_code %></textarea>
        <button
          id="copy-pix-code"
          class="btn btn-ghost btn-sm absolute right-2 top-2"
          title="Copiar código">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
        </button>
      </div>
    </div>

    <div class="flex items-center gap-3 text-sm opacity-80 mt-2 text-white">
      <span class="loading loading-spinner loading-xs text-primary"></span>
      Aguardando confirmação...
    </div>

    <div class="card-actions w-full mt-6">
      <%= link_to "Voltar para planos", planos_path, class: "btn btn-outline btn-sm w-full" %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', () => {
    // Lógica de copiar
    const copyBtn = document.getElementById('copy-pix-code');
    if (copyBtn) {
      copyBtn.onclick = () => {
        const code = document.getElementById('pix-code');
        code.select();
        document.execCommand('copy');
        alert('Código copiado!');
      };
    }

    // Polling de status
    const interval = setInterval(() => {
      fetch("<%= checkout_pix_path(@cobranca) %>", { headers: { "Accept": "application/json" } })
        .then(r => r.json())
        .then(data => {
          if (data.status === "pago") {
            window.location.href = "<%= checkout_sucesso_path %>";
          }
        })
        .catch(err => console.error("Erro no polling:", err));
    }, 5000);

    document.addEventListener('turbo:before-visit', () => clearInterval(interval), { once: true });
  });
</script>