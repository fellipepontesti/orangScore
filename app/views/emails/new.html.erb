<% content_for :title, "Enviar email" %>

<div class="w-full max-w-3xl mx-auto px-4 py-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>E-mails</span>
        <span>/</span>
        <span>Enviar</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Enviar E-mails
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Envie um email personalizado para todos os usuários do sistema. Somente administradores têm acesso.</p>
    </div>

    <%= link_to authenticated_root_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <% if flash[:alert].present? %>
    <div class="alert alert-error mb-6">
      <div>
        <p class="font-bold">Não foi possível enviar o email.</p>
        <p><%= flash[:alert] %></p>
      </div>
    </div>
  <% end %>

  <div class="bg-base-100 border border-base-300 rounded-box shadow-lg p-8">
    <%= form_with url: emails_path, method: :post, local: true, class: "contents" do |form| %>
      <div class="form-control mb-6">
        <%= form.label :assunto, "Assunto", class: "label font-semibold" %>
        <%= form.text_field :assunto,
          value: params[:assunto],
          required: true,
          maxlength: 120,
          placeholder: "Digite o assunto do email",
          class: "input input-bordered w-full text-base" %>
      </div>

      <div class="form-control mb-6">
        <%= form.label :mensagem, "Mensagem", class: "label font-semibold" %>
        <%= form.text_area :mensagem,
          value: params[:mensagem],
          rows: 10,
          required: true,
          maxlength: 2000,
          placeholder: "Digite a mensagem que será enviada para todos os usuários",
          class: "textarea textarea-bordered w-full text-base resize-y" %>
        <div class="label">
          <span class="label-text-alt opacity-70">A mensagem será enviada por email para todos os usuários cadastrados.</span>
        </div>
      </div>

      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <%= form.submit "Enviar email para todos", class: "btn btn-primary font-bold rounded-2xl" %>
        <%= link_to "Cancelar", authenticated_root_path, class: "btn btn-ghost rounded-2xl" %>
      </div>
    <% end %>
  </div>
</div>
