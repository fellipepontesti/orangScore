<div class="w-full max-w-6xl mx-auto px-4 py-8">
  <% content_for :title, "Planos" %>
  
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Assinatura</span>
        <span>/</span>
        <span>Planos</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Escolha seu Plano
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Eleve o nível da sua competição e apoie o OrangScore.</p>
    </div>

    <%= link_to perfil_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <div class="w-full max-w-4xl mx-auto mb-10 px-4">
    <div class="flex items-start gap-4 p-4 rounded-2xl bg-blue-500/5 border border-blue-500/10 shadow-sm">
      <div class="shrink-0 text-blue-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <div class="flex flex-col">
        <span class="text-sm font-bold text-slate-200">
          Nota sobre a vigência dos planos
        </span>
        <p class="text-xs text-slate-400 leading-relaxed mt-1">
          Estes pacotes são válidos exclusivamente para a <strong>Copa do Mundo 2026</strong>. Torneios futuros não estão inclusos nestas assinaturas e estarão sujeitos a novas cobranças para participação.
        </p>
      </div>
    </div>
  </div>
    <% plano_do_usuario = current_user.assinatura.plano %> 
    <% is_fellipe = current_user.name.to_s.downcase.include?("fellipe") %>

    <% if current_user.assinatura.premium? %>
      <div class="max-w-3xl mx-auto text-center space-y-8 py-12">
        <div class="relative inline-block">
          <div class="absolute inset-0 bg-yellow-500 blur-3xl opacity-20 animate-pulse"></div>
          <div class="relative bg-[#1a2236] border-2 border-yellow-500/50 p-12 rounded-[3rem] shadow-2xl">
            <div class="w-24 h-24 bg-yellow-500 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-yellow-500/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            
            <h2 class="text-4xl font-black text-white mb-4 uppercase tracking-tighter">Você é Premium!</h2>
            <p class="text-slate-400 text-lg max-w-md mx-auto leading-relaxed">
              Você já possui o melhor plano disponível e acesso ilimitado a todas as funcionalidades do <span class="text-yellow-500 font-bold">OrangScore</span>.
            </p>

            <div class="grid grid-cols-2 gap-4 mt-10">
              <div class="p-4 bg-white/5 rounded-2xl border border-white/10">
                <span class="block text-2xl font-black text-yellow-500">∞</span>
                <span class="text-xs uppercase font-bold text-slate-500">Ligas</span>
              </div>
              <div class="p-4 bg-white/5 rounded-2xl border border-white/10">
                <span class="block text-2xl font-black text-yellow-500">∞</span>
                <span class="text-xs uppercase font-bold text-slate-500">Membros</span>
              </div>
            </div>

            <div class="mt-10">
              <%= link_to "Voltar ao Dashboard", root_path, class: "btn btn-outline border-yellow-500/50 text-yellow-500 hover:bg-yellow-500 hover:text-black rounded-2xl px-12" %>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <%= form_tag "#", id: "form-planos", class: "grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch max-w-4xl mx-auto", data: { turbo: false } do %>
        <%= hidden_field_tag :payment_method, "pix", id: "payment_method" %>

        <% # --- BÁSICO --- %>
        <label class="cursor-pointer group flex">
          <input type="radio" name="plano" value="basic" class="peer hidden" <%= "checked" if plano_do_usuario == "basic" %> />
          <div class="relative flex flex-col w-full bg-[#1a2236]/50 border-2 border-white/5 p-8 rounded-3xl transition-all duration-300 
                      peer-checked:border-orange-500 peer-checked:bg-[#1a2236] peer-checked:shadow-[0_0_30px_-10px_rgba(249,115,22,0.4)]
                      group-hover:border-white/20">
            
            <h2 class="text-xl font-bold text-slate-300">Básico</h2>
            <div class="my-6">
              <span class="text-4xl font-black text-orange-500">Grátis</span>
            </div>
            
            <ul class="space-y-4 mb-8 flex-1">
              <%= render "plano", text: "1 Liga" %>
              <%= render "plano", text: "Até 15 membros na liga" %>
              <%= render "plano", text: "Participe de quantas ligas quiser" %>
            </ul>

            <button type="button" 
                    data-plan="basic" 
                    data-level="0"
                    data-current="<%= plano_do_usuario == 'basic' %>" 
                    data-user-level="<%= Assinatura.planos[plano_do_usuario] %>"
                    class="btn-plano btn btn-block border-none text-white rounded-xl bg-slate-700">
              <%= plano_do_usuario == 'basic' ? 'Plano Atual' : 'Mudar para Básico' %>
            </button>
          </div>
        </label>

        <% # --- PREMIUM --- %>
        <label class="cursor-pointer group flex">
          <input type="radio" name="plano" value="premium" class="peer hidden" <%= "checked" if plano_do_usuario == "premium" %> />
          <div class="relative flex flex-col w-full bg-[#1a2236]/50 border-2 border-white/5 p-8 rounded-3xl transition-all duration-300 
                      peer-checked:border-orange-500 peer-checked:bg-[#1a2236] peer-checked:shadow-[0_0_30px_-10px_rgba(249,115,22,0.4)]
                      group-hover:border-white/20">
            
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-orange-500 text-black text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest">
              Recomendado
            </div>

            <h2 class="text-xl font-bold text-slate-300">Premium</h2>
            <div class="my-6">
              <span class="text-4xl font-black text-white">
                <%= is_fellipe ? "R$ 0" : "R$ 9" %><span class="text-lg"><%= is_fellipe ? ",50" : ",99" %></span>
              </span>
              <% if is_fellipe %>
                <span class="block text-xs text-yellow-500 font-bold mt-1">Desconto de Teste Aplicado</span>
              <% end %>
            </div>
            
            <ul class="space-y-4 mb-8 flex-1">
              <%= render "plano", text: "Ligas ilimitadas" %>
              <%= render "plano", text: "Membros ilimitados" %>
              <%= render "plano", text: "Participe de quantas ligas quiser" %>
              <%= render "plano", text: "Acesso completo aos elencos das seleções" %>
              <%= render "plano", text: "Convite por link, Whatsapp" %>
              <%= render "plano", text: "Acesso ao ranking geral" %>
              <%= render "plano", text: "Prioridade em novas funções" %>
            </ul>

            <button type="button" 
                    data-plan="premium" 
                    data-level="2"
                    data-current="<%= plano_do_usuario == 'premium' %>" 
                    data-user-level="<%= Assinatura.planos[plano_do_usuario] %>"
                    class="btn-plano btn btn-block border-none text-white rounded-xl bg-slate-700">
              <%= plano_do_usuario == 'premium' ? 'Plano Atual' : 'Assinar Premium' %>
            </button>
          </div>
        </label>
      <% end %>
    <% end %>

  <% # MODAL PIX DIRETO MERCADO PAGO %>
  <div id="payment-modal" class="fixed inset-0 bg-black/70 hidden items-center justify-center z-50">
    <div class="relative bg-[#1a2236] p-8 rounded-3xl w-full max-w-md border border-primary/20 shadow-2xl">
      <h2 class="text-2xl font-bold text-white mb-2">
        Gerar Pix para Upgrade
      </h2>
      <p class="text-xs opacity-60 mb-6">
        Insira seu CPF para que o Mercado Pago gere o QR Code Pix de <%= is_fellipe ? "R$ 0,50" : "R$ 9,99" %> com segurança.
      </p>

      <button id="close-payment-modal" type="button" class="absolute top-4 right-4 text-slate-400 hover:text-white transition">
        ✕
      </button>

      <div class="flex flex-col gap-4">
        <div class="form-control">
          <input type="text" id="user-cpf" placeholder="000.000.000-00" class="input input-bordered bg-base-300 w-full text-center font-bold text-lg text-primary" maxlength="14" />
        </div>
        <button id="btn-pix-direto" type="button" class="btn btn-primary btn-block shadow-lg shadow-primary/20 font-bold">
          Gerar QR Code Pix
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', () => {
    const form = document.getElementById('form-planos');
    if (!form) return;

    const radios = form.querySelectorAll('input[type="radio"]');
    const buttons = form.querySelectorAll('.btn-plano');
    let currentPlan = null;

    const modal = document.getElementById('payment-modal');

    function updateButtons() {
      radios.forEach(radio => {
        const card = radio.closest('label');
        const btn = card.querySelector('.btn-plano');
        const planValue = radio.value;
        const isCurrent = btn.getAttribute('data-current') === 'true';
        const planLevel = parseInt(btn.getAttribute('data-level'));
        const userLevel = parseInt(btn.getAttribute('data-user-level'));

        if (radio.checked) {
          btn.classList.remove('bg-slate-700');
          btn.classList.add('bg-orange-500', 'text-black');

          if (isCurrent) {
            btn.innerText = "Plano Atual";
            btn.disabled = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');
          } else if (planLevel < userLevel) {
            btn.innerText = "Indisponível";
            btn.disabled = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');
          } else {
            btn.innerText = planValue === 'basic' ? "Mudar para Básico" : "Assinar Premium";
            btn.disabled = false;
            btn.classList.remove('opacity-50', 'cursor-not-allowed');
          }
        } else {
          btn.classList.remove('bg-orange-500', 'text-black', 'opacity-50', 'cursor-not-allowed');
          btn.classList.add('bg-slate-700', 'text-white');

          if (isCurrent) {
            btn.innerText = "Plano Atual";
            btn.disabled = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');
          } else if (planLevel < userLevel) {
            btn.innerText = "Indisponível";
            btn.disabled = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');
          } else {
            btn.innerText = "Selecionar";
            btn.disabled = false;
          }
        }
      });
    }

    updateButtons();

    radios.forEach(r => {
      r.addEventListener('change', updateButtons);
    });

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        currentPlan = btn.dataset.plan;

        if (btn.dataset.current === 'true') return;

        const radio = document.querySelector(`input[value="${currentPlan}"]`);
        radio.checked = true;
        updateButtons();

        if (currentPlan === 'basic') {
          // Upgrade grátis/básico não precisa de Pix
          submitPayment('<%= checkout_mercado_pago_pix_direto_path %>', 'pix', btn);
        } else {
          // Premium abre modal do Pix solicitando CPF
          modal.classList.remove('hidden');
          modal.classList.add('flex');
        }
      });
    });

    // MÁSCARA CPF
    const cpfInput = document.getElementById('user-cpf');
    if (cpfInput) {
      cpfInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\D/g, '');
        if (value.length > 11) value = value.slice(0, 11);
        
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
        
        e.target.value = value;
      });
    }

    // EVENTO PIX DIRETO
    const pixDiretoBtn = document.getElementById('btn-pix-direto');
    if (pixDiretoBtn) {
      pixDiretoBtn.addEventListener('click', () => {
        const cpf = cpfInput.value.replace(/\D/g, '');
        if (cpf.length < 11) {
          alert("Por favor, informe um CPF válido.");
          return;
        }
        submitPayment('<%= checkout_mercado_pago_pix_direto_path %>', 'pix', pixDiretoBtn, { cpf: cpf });
      });
    }

    const closeModal = document.getElementById('close-payment-modal');
    if (closeModal) {
      closeModal.addEventListener('click', () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      });
    }

    modal.addEventListener('click', (event) => {
      if (event.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });

    function submitPayment(url, paymentMethod, button, extraParams = {}) {
      const originalText = button.innerText;
      button.disabled = true;
      button.innerText = 'Processando...';

      const formData = new FormData();
      formData.append('plano', currentPlan);
      formData.append('payment_method', paymentMethod);
      formData.append('authenticity_token', '<%= form_authenticity_token %>');
      
      for (const key in extraParams) {
        formData.append(key, extraParams[key]);
      }

      fetch(url, {
        method: 'POST',
        body: formData,
        headers: {
          'X-CSRF-Token': '<%= form_authenticity_token %>',
          'Accept': 'application/json'
        }
      })
      .then(async response => {
        if (response.redirected) {
          window.location.href = response.url;
        } else {
          const data = await response.json();
          if (!response.ok) {
            throw new Error(data.error || 'Erro desconhecido no servidor');
          }
          if (data.redirect_url) {
            window.location.href = data.redirect_url;
          }
        }
      })
      .catch(error => {
        console.error('Error:', error);
        button.disabled = false;
        button.innerText = originalText;
        alert('Erro: ' + error.message);
      });
    }
  });
</script>
