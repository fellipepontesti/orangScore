<% compact_mobile = local_assigns.fetch(:compact_mobile, false) %>

<div class="flex flex-col items-center <%= compact_mobile ? 'gap-2 sm:gap-4 min-w-0 w-full md:w-1/3' : 'gap-4 w-full md:w-1/3' %>">
  <div class="avatar">
    <div class="<%= avatar_class %> <%= compact_mobile ? 'w-16 h-16 sm:w-24 sm:h-24 ring-offset-2 sm:ring-offset-4' : 'w-24 h-24 ring-offset-4' %> rounded-full ring ring-offset-base-100 shadow-xl bg-base-200 flex items-center justify-center overflow-hidden">
      <% if image_path.present? %>
        <%= image_tag image_path, class: "object-cover w-full h-full" %>
      <% else %>
        <span class="text-3xl font-black opacity-30">?</span>
      <% end %>
    </div>
  </div>
  
  <span class="<%= compact_mobile ? 'text-sm sm:text-xl leading-tight min-h-10 sm:min-h-0 max-w-full' : 'text-xl max-w-[150px]' %> font-bold text-center">
    <%= team_name %>
  </span>

  <!-- Score Input Component -->
  <div class="flex flex-col items-center <%= compact_mobile ? 'gap-2 sm:gap-3' : 'gap-3' %> w-full">
    <!-- Display Value -->
    <div class="<%= compact_mobile ? 'text-5xl sm:text-6xl min-h-[56px] sm:min-h-[80px]' : 'text-6xl min-h-[80px]' %> font-black tabular-nums tracking-tight text-center flex items-center justify-center cursor-pointer transition-all duration-200 select-none hover:scale-105 active:scale-95"
         id="<%= input_id %>_display_container"
         onclick="focusScoreInput('<%= input_id %>')"
         title="Clique para digitar o placar">
      <span id="<%= input_id %>_display" class="transition-colors duration-200">0</span>
    </div>

    <!-- Control Buttons -->
    <div class="flex items-center <%= compact_mobile ? 'gap-1 sm:gap-2 p-1 sm:p-2' : 'gap-2 p-2' %> bg-base-200 rounded-xl">
      <button
        type="button"
        onclick="decrementScore('<%= input_id %>')"
        class="btn btn-ghost <%= compact_mobile ? 'btn-xs sm:btn-sm' : 'btn-sm' %> btn-circle text-2xl leading-none font-black hover:bg-error/20 hover:text-error transition">
        −
      </button>
      
      <!-- Hidden number input for direct typing -->
      <input
        type="number"
        id="<%= input_id %>"
        name="<%= input_name %>"
        min="0"
        max="99"
        value="<%= value || 0 %>"
        inputmode="numeric"
        pattern="[0-9]*"
        class="input input-bordered input-sm <%= compact_mobile ? 'w-12 sm:w-16' : 'w-16' %> text-center text-lg font-black focus:ring-2 focus:ring-primary/50 transition-all"
        onchange="updateScoreDisplay('<%= input_id %>')"
        oninput="updateScoreDisplay('<%= input_id %>')"
        onfocus="highlightDisplay('<%= input_id %>', true)"
        onblur="highlightDisplay('<%= input_id %>', false)" />
      
      <button
        type="button"
        onclick="incrementScore('<%= input_id %>')"
        class="btn btn-ghost <%= compact_mobile ? 'btn-xs sm:btn-sm' : 'btn-sm' %> btn-circle text-2xl leading-none font-black hover:bg-success/20 hover:text-success transition">
        +
      </button>
    </div>

    <!-- Quick buttons for common scores -->
    <div class="<%= compact_mobile ? 'grid grid-cols-3 sm:flex' : 'flex flex-wrap' %> gap-1 justify-center w-full">
      <% [0, 1, 2, 3, 4, 5].each do |num| %>
        <button
          type="button"
          onclick="setScore('<%= input_id %>', <%= num %>)"
          class="btn btn-xs btn-ghost border-base-300 hover:border-primary hover:text-primary">
          <%= num %>
        </button>
      <% end %>
    </div>
  </div>
</div>

<script>
  function focusScoreInput(inputId) {
    const input = document.getElementById(inputId);
    if (input) {
      input.focus();
      input.select();
    }
  }

  function highlightDisplay(inputId, isFocused) {
    const container = document.getElementById(inputId + '_display_container');
    const display = document.getElementById(inputId + '_display');
    if (container && display) {
      if (isFocused) {
        container.classList.add('scale-110');
        display.classList.add('text-primary');
      } else {
        container.classList.remove('scale-110');
        display.classList.remove('text-primary');
      }
    }
  }

  function updateScoreDisplay(inputId) {
    const input = document.getElementById(inputId);
    const display = document.getElementById(inputId + '_display');
    let value = parseInt(input.value) || 0;
    
    // Limita entre 0 e 99
    if (value < 0) value = 0;
    if (value > 99) value = 99;
    
    input.value = value;
    display.textContent = value;
  }

  function incrementScore(inputId) {
    const input = document.getElementById(inputId);
    let value = parseInt(input.value) || 0;
    if (value < 99) {
      input.value = value + 1;
      updateScoreDisplay(inputId);
    }
  }

  function decrementScore(inputId) {
    const input = document.getElementById(inputId);
    let value = parseInt(input.value) || 0;
    if (value > 0) {
      input.value = value - 1;
      updateScoreDisplay(inputId);
    }
  }

  function setScore(inputId, score) {
    const input = document.getElementById(inputId);
    input.value = score;
    updateScoreDisplay(inputId);
  }

  // Inicializa o display na primeira carga
  document.addEventListener('turbo:load', () => {
    updateScoreDisplay('<%= input_id %>');
  });

  // Garante que o display está atualizado ao carregar a página
  updateScoreDisplay('<%= input_id %>');
</script>
