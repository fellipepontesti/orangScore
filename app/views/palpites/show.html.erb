<% content_for :title, "Detalhes do Palpite" %>

<div class="w-full max-w-4xl mx-auto p-4 sm:p-8">
  <% if notice.present? %>
    <p class="alert alert-success mb-5" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <h1 class="font-bold text-3xl sm:text-4xl">Detalhes do Palpite</h1>

    <%= link_to "Voltar para palpites", palpites_path, class: "btn btn-ghost bg-base-300" %>
  </div>

  <%= render "palpite_card", palpite: @palpite, pontos: @pontos %>
</div>
