<% content_for :title, "Detalhes do Palpite" %>

<div class="w-full max-w-4xl mx-auto p-4 sm:p-8">
  <% if notice.present? %>
    <p class="alert alert-success mb-5" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <%= link_to palpites_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar para palpites
    <% end %>
  </div>

  <%= render "palpite_card", palpite: @palpite, pontos: @pontos %>
</div>
