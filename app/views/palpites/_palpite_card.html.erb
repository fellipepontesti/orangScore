<div id="<%= dom_id palpite %>" class="rounded-box shadow-lg bg-base-100 p-4 sm:p-6 transition overflow-hidden border border-base-200">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center justify-between gap-2 text-sm uppercase font-semibold opacity-70 mb-3">
        <span>Palpite #<%= palpite.id %></span>
        <% if current_user.root? %>
          <span class="normal-case truncate max-w-full badge badge-neutral text-xs">
            <%= palpite.user.name %>
          </span>
        <% end %>
      </div>

      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 sm:gap-4 mb-2 text-center bg-base-200/40 p-3 rounded-2xl">
        
        <div class="min-w-0 w-full">
          <% if palpite.jogo.mandante.present? %>
            <%= link_to selecao_path(palpite.jogo.mandante), onclick: "event.stopPropagation();", class: "group flex flex-col items-center justify-center w-full" do %>
              <div class="avatar mb-1">
                <div class="mask mask-squircle h-9 w-9 sm:h-12 sm:w-12 transition duration-300 group-hover:scale-105 bg-base-100 flex items-center justify-center overflow-hidden">
                  <% if palpite.jogo.mandante.logo.present? %>
                    <%= image_tag "selecoes/#{palpite.jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                  <% else %>
                    <span class="text-xs font-bold">?</span>
                  <% end %>
                </div>
              </div>
              <span class="font-bold text-xs sm:text-sm truncate w-full group-hover:underline">
                <%= palpite.jogo.mandante.nome %>
              </span>
            <% end %>
          <% else %>
            <div class="flex flex-col items-center justify-center opacity-60 w-full">
              <div class="avatar mb-1">
                <div class="mask mask-squircle h-9 w-9 sm:h-12 sm:w-12 bg-base-300 flex items-center justify-center text-xs font-bold">
                  ?
                </div>
              </div>
              <span class="font-bold text-xs sm:text-sm truncate w-full">
                <%= palpite.jogo.nome_provisorio_mandante.presence || "A definir" %>
              </span>
            </div>
          <% end %>
        </div>

        <div class="flex flex-col items-center justify-center px-1 min-w-[70px] sm:min-w-[120px]">
          <div class="text-[9px] sm:text-xs uppercase font-black tracking-wider opacity-40 mb-0.5">
            Seu Placar
          </div>
          <div class="text-xl sm:text-3xl font-black font-mono bg-base-100 px-2.5 py-1 rounded-xl shadow-sm border border-base-300/40 tracking-tight whitespace-nowrap">
            <%= palpite.gols_casa %>
            <span class="mx-0.5 sm:mx-1 opacity-40 text-sm sm:text-xl font-medium">x</span>
            <%= palpite.gols_fora %>
          </div>
          <% if palpite.vencedor_penaltis_id.present? %>
            <div class="text-[10px] font-bold text-primary mt-1">
              (<%= palpite.vencedor_penaltis.nome %>)
            </div>
          <% end %>
        </div>

        <div class="min-w-0 w-full">
          <% if palpite.jogo.visitante.present? %>
            <%= link_to selecao_path(palpite.jogo.visitante), onclick: "event.stopPropagation();", class: "group flex flex-col items-center justify-center w-full" do %>
              <div class="avatar mb-1">
                <div class="mask mask-squircle h-9 w-9 sm:h-12 sm:w-12 transition duration-300 group-hover:scale-105 bg-base-100 flex items-center justify-center overflow-hidden">
                  <% if palpite.jogo.visitante.logo.present? %>
                    <%= image_tag "selecoes/#{palpite.jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                  <% else %>
                    <span class="text-xs font-bold">?</span>
                  <% end %>
                </div>
              </div>
              <span class="font-bold text-xs sm:text-sm truncate w-full group-hover:underline">
                <%= palpite.jogo.visitante.nome %>
              </span>
            <% end %>
          <% else %>
            <div class="flex flex-col items-center justify-center opacity-60 w-full">
              <div class="avatar mb-1">
                <div class="mask mask-squircle h-9 w-9 sm:h-12 sm:w-12 bg-base-300 flex items-center justify-center text-xs font-bold">
                  ?
                </div>
              </div>
              <span class="font-bold text-xs sm:text-sm truncate w-full">
                <%= palpite.jogo.nome_provisorio_visitante.presence || "A definir" %>
              </span>
            </div>
          <% end %>
        </div>

      </div>

      <% if palpite.jogo.prob_mandante.present? && !current_user.esconder_odds %>
        <div class="w-full mb-4 mt-3 px-1">
          <div class="flex justify-between text-[9px] font-black uppercase tracking-wider text-slate-500 mb-1">
            <span class="text-success"><%= palpite.jogo.mandante&.nome&.truncate(10) || 'Mandante' %>: <%= palpite.jogo.prob_mandante %>%</span>
            <span class="text-slate-400">Empate: <%= palpite.jogo.prob_empate %>%</span>
            <span class="text-error"><%= palpite.jogo.visitante&.nome&.truncate(10) || 'Visitante' %>: <%= palpite.jogo.prob_visitante %>%</span>
          </div>
          <div class="flex h-2 w-full rounded-full overflow-hidden bg-base-300 shadow-inner">
            <div class="bg-success" style="width: <%= palpite.jogo.prob_mandante %>%;"></div>
            <div class="bg-slate-400" style="width: <%= palpite.jogo.prob_empate %>%;"></div>
            <div class="bg-error" style="width: <%= palpite.jogo.prob_visitante %>%;"></div>
          </div>
        </div>
      <% end %>

      <div class="text-center text-xs opacity-50 font-medium mb-4 truncate px-2">
        <%= palpite.jogo.estadio.presence || "Estádio a definir" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="rounded-box bg-base-200 p-3 text-center">
          <div class="text-xs uppercase font-semibold opacity-60">Data</div>
          <div class="font-bold text-sm">
            <%= palpite.jogo.data.strftime("%d/%m/%Y %H:%M") %>
          </div>
        </div>

        <div class="rounded-box bg-base-200 p-3 text-center">
          <div class="text-xs uppercase font-semibold opacity-60">Status</div>
          <div class="flex items-center justify-center gap-2 font-bold text-sm">
            <div class="inline-grid *:[grid-area:1/1]">
              <% if palpite.jogo.programado? %>
                <div class="status status-info animate-ping"></div>
                <div class="status status-info"></div>
              <% elsif palpite.jogo.em_andamento? %>
                <div class="status status-success animate-ping"></div>
                <div class="status status-success"></div>
              <% elsif palpite.jogo.suspenso? %>
                <div class="status status-warning animate-ping"></div>
                <div class="status status-warning"></div>
              <% elsif palpite.jogo.finalizado? %>
                <div class="status status-error animate-ping"></div>
                <div class="status status-error"></div>
              <% elsif palpite.jogo.times_a_definir? %>
                <div class="status status-primary animate-ping"></div>
                <div class="status status-primary"></div>
              <% end %>
            </div>
            <span><%= palpite.jogo.status&.humanize %></span>
          </div>
        </div>
      </div>

      <% if palpite.jogo.finalizado? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">
          <div class="rounded-box bg-success/10 border border-success/20 p-3 text-center">
            <div class="text-xs uppercase font-semibold opacity-60">Resultado final</div>
            <div class="font-black text-xl text-success font-mono">
              <%= palpite.jogo.gols_mandante.to_i %>
              <span class="mx-1 opacity-60 font-sans font-medium text-sm">x</span>
              <%= palpite.jogo.gols_visitante.to_i %>
            </div>
          </div>

          <div class="rounded-box bg-warning/10 border border-warning/20 p-3 text-center">
            <div class="text-xs uppercase font-semibold opacity-60">Pontuação</div>
            <div class="font-black text-xl text-warning">
              <%= pontos.to_i %> pts
            </div>
          </div>
        </div>
      <% else %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">
          <div class="rounded-box bg-base-200/50 border border-base-300 p-3 flex flex-col items-center justify-center min-h-[76px]">
            <div class="flex items-center justify-center gap-2 text-base-content/60 font-bold text-xs sm:text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 animate-spin [animation-duration:3s] text-info shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <span>Aguardando resultado</span>
            </div>
          </div>

          <div class="rounded-box bg-base-200/50 border border-base-300 p-3 flex flex-col items-center justify-center min-h-[76px]">
            <div class="text-xs uppercase font-semibold opacity-40">Pontuação</div>
            <div class="font-black text-xl opacity-40">
              -- pts
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex justify-center gap-3 pt-6 border-t border-dashed border-base-300 mt-4">
    <% if palpite.jogo.palpitavel? %>
      <%= link_to "Editar",
        edit_palpite_path(palpite),
        class: "btn btn-warning text-white btn-sm sm:btn-md font-bold" %>
    <% end %>
  </div>
</div>