<div class="rounded-box shadow-lg bg-base-100 p-4 sm:p-6 transition overflow-hidden">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center justify-between gap-2 text-sm uppercase font-semibold opacity-70 mb-3">
        <span>Palpite #<%= palpite.id %></span>
        <% if current_user.root? %>
          <span class="normal-case truncate max-w-full">
            <%= palpite.user.name %>
          </span>
        <% end %>
      </div>

      <!-- Grid Principal do Placar -->
      <div class="grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center justify-items-center gap-4 sm:gap-4 mb-2 text-center">
        
        <!-- Mandante -->
        <div class="flex flex-col items-center justify-center min-w-0 w-full">
          <% if palpite.jogo.mandante.present? %>
            <%= link_to selecao_path(palpite.jogo.mandante), onclick: "event.stopPropagation();", class: "group flex flex-col items-center justify-center w-full" do %>
              <div class="avatar mb-2">
                <div class="mask mask-squircle h-10 w-10 sm:h-12 sm:w-12 transition duration-300 group-hover:scale-105 bg-base-200 flex items-center justify-center overflow-hidden">
                  <% if palpite.jogo.mandante.logo.present? %>
                    <%= image_tag "selecoes/#{palpite.jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                  <% else %>
                    <span class="text-xs font-bold">?</span>
                  <% end %>
                </div>
              </div>
              <span class="font-bold text-sm sm:text-base max-w-full break-words group-hover:underline">
                <%= palpite.jogo.mandante.nome %>
              </span>
            <% end %>
          <% else %>
            <div class="flex flex-col items-center justify-center opacity-60 w-full">
              <div class="avatar mb-2">
                <div class="mask mask-squircle h-10 w-10 sm:h-12 sm:w-12 bg-base-300 flex items-center justify-center text-xs font-bold">
                  ?
                </div>
              </div>
              <span class="font-bold text-sm sm:text-base max-w-full break-words">
                <%= palpite.jogo.nome_provisorio_mandante.presence || "[ A definir ]" %>
              </span>
            </div>
          <% end %>
        </div>

        <!-- Placar do Palpite -->
        <div class="flex flex-col items-center justify-center min-w-[86px] sm:min-w-[120px] py-2 sm:py-0">
          <div class="text-xs uppercase font-semibold opacity-60 mb-1">
            Seu placar
          </div>
          <div class="text-2xl sm:text-3xl font-bold whitespace-nowrap">
            <%= palpite.gols_casa %>
            <span class="mx-1 sm:mx-2 opacity-60">x</span>
            <%= palpite.gols_fora %>
          </div>
        </div>

        <!-- Visitante -->
        <div class="flex flex-col items-center justify-center min-w-0 w-full">
          <% if palpite.jogo.visitante.present? %>
            <%= link_to selecao_path(palpite.jogo.visitante), onclick: "event.stopPropagation();", class: "group flex flex-col items-center justify-center w-full" do %>
              <div class="avatar mb-2">
                <div class="mask mask-squircle h-10 w-10 sm:h-12 sm:w-12 transition duration-300 group-hover:scale-105 bg-base-200 flex items-center justify-center overflow-hidden">
                  <% if palpite.jogo.visitante.logo.present? %>
                    <%= image_tag "selecoes/#{palpite.jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                  <% else %>
                    <span class="text-xs font-bold">?</span>
                  <% end %>
                </div>
              </div>
              <span class="font-bold text-sm sm:text-base max-w-full break-words group-hover:underline">
                <%= palpite.jogo.visitante.nome %>
              </span>
            <% end %>
          <% else %>
            <div class="flex flex-col items-center justify-center opacity-60 w-full">
              <div class="avatar mb-2">
                <div class="mask mask-squircle h-10 w-10 sm:h-12 sm:w-12 bg-base-300 flex items-center justify-center text-xs font-bold">
                  ?
                </div>
              </div>
              <span class="font-bold text-sm sm:text-base max-w-full break-words">
                <%= palpite.jogo.nome_provisorio_visitante.presence || "[ A definir ]" %>
              </span>
            </div>
          <% end %>
        </div>

      </div>

      <!-- Nome do Estádio por extenso abaixo das seleções -->
      <div class="text-center text-xs opacity-50 font-medium mb-4 truncate px-4">
        <%= palpite.jogo.estadio.presence || "Estádio a definir" %>
      </div>

      <!-- Grid de Informações (Apenas Data e Status) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="rounded-box bg-base-200 p-3 text-center">
          <div class="text-xs uppercase font-semibold opacity-60">Data</div>
          <div class="font-bold">
            <%= palpite.jogo.data.strftime("%d/%m/%Y %H:%M") %>
          </div>
        </div>

        <div class="rounded-box bg-base-200 p-3 text-center">
          <div class="text-xs uppercase font-semibold opacity-60">Status</div>
          <div class="flex items-center justify-center gap-2 font-bold">
            <div class="inline-grid *:[grid-area:1/1]">
              <% if palpite.jogo.programado? %>
                <div class="status status-info animate-ping"></div>
                <div class="status status-info"></div>
              <% elsif palpite.jogo.em_andamento? %>
                <div class="status status-success animate-ping"></div>
                <div class="status status-success"></div>
              <% elsif palpite.jogo.finalizado? %>
                <div class="status status-error animate-ping"></div>
                <div class="status status-error"></div>
              <% elsif palpite.jogo.times_a_definir? %>
                <div class="status status-primary animate-ping"></div>
                <div class="status status-primary"></div>
              <% end %>
            </div>
            <span><%= palpite.jogo.status.humanize %></span>
          </div>
        </div>
      </div>

      <% if palpite.jogo.finalizado? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">
          <div class="rounded-box bg-success/10 border border-success/20 p-3 text-center">
            <div class="text-xs uppercase font-semibold opacity-60">Resultado final</div>
            <div class="font-black text-xl text-success">
              <%= palpite.jogo.gols_mandante.to_i %>
              <span class="mx-2 opacity-60">x</span>
              <%= palpite.jogo.gols_visitante.to_i %>
            </div>
          </div>

          <div class="rounded-box bg-warning/10 border border-warning/20 p-3 text-center">
            <div class="text-xs uppercase font-semibold opacity-60">Pontuação</div>
            <div class="font-black text-xl text-warning">
              <%= pontos.to_i %> pts
            </div>
          </div>
        </div>
      <% else %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">
          <!-- Card Resultado Provisório / Aguardando -->
          <div class="rounded-box bg-base-200/50 border border-base-300 p-3 flex flex-col items-center justify-center min-h-[76px]">
            <div class="flex items-center justify-center gap-2 text-base-content/60 font-bold text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 animate-spin [animation-duration:3s] text-info">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <span>Aguardando resultado</span>
            </div>
          </div>

          <!-- Card Pontuação Aguardando -->
          <div class="rounded-box bg-base-200/50 border border-base-300 p-3 flex flex-col items-center justify-center min-h-[76px]">
            <div class="text-xs uppercase font-semibold opacity-40">Pontuação</div>
            <div class="font-black text-xl opacity-40">
              -- pts
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Botões de Ação -->
  <div class="flex flex-wrap justify-center gap-3 pt-6">
    <%= link_to "Detalhes",
      palpite_path(palpite),
      class: "btn btn-ghost bg-base-300" %>

    <% if palpite.jogo.programado? || palpite.jogo.times_a_definir? %>
      <%= link_to "Editar",
        edit_palpite_path(palpite),
        class: "btn btn-warning text-white" %>
    <% end %>
  </div>
</div>