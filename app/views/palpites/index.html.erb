<% content_for :title, "Palpites" %>

<div class="flex-1 flex flex-col w-full">
  <div class="flex items-center justify-between p-8">
    <h1 class="font-bold text-4xl">Palpites</h1>

    <%= link_to "Criar palpite",
      jogos_path,
      class: "rounded-md px-4 py-4 bg-primary hover:bg-primary/80 font-bold text-white" %>
  </div>

  <div class="w-full px-4 pb-8">
    <% if @palpites.any? %>
      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <% @palpites.each do |palpite| %>
          <%= render "palpite_card", palpite: palpite %>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-box shadow-lg bg-base-100 p-10 text-center">
        <h2 class="text-2xl font-bold mb-2">Nenhum palpite encontrado</h2>
        <p class="opacity-70 mb-6">Você ainda não fez nenhum palpite.</p>

        <%= link_to "Ir para jogos",
          jogos_path,
          class: "rounded-md px-5 py-3 bg-primary hover:bg-primary/80 font-bold text-white" %>
      </div>
    <% end %>
  </div>
</div>