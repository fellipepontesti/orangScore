<div class="w-full max-w-3xl mx-auto px-4 pb-8">
  <div class="card bg-base-100 shadow-2xl border border-base-200">
    <div class="card-body p-4 sm:p-8 md:p-12">
      <%= form_with(model: palpite, class: "space-y-6 sm:space-y-10") do |form| %>
        <%= form.hidden_field :jogo_id, value: @jogo&.uuid %>

        <% if palpite.errors.any? %>
          <div class="alert alert-error shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <ul class="list-disc ml-5 text-sm font-medium">
              <% palpite.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= hidden_field_tag :quick_mode, params[:quick_mode] %>
        <%= hidden_field_tag :return_to, params[:return_to] %>

        <% if @jogo.present? %>
          <div class="text-center mb-8">
            <h2 class="text-sm uppercase tracking-widest font-bold opacity-50 mb-1">Jogo Selecionado</h2>
            <div class="badge badge-primary badge-outline text-xs mb-4"><%= @jogo.data.strftime("%d/%m/%Y às %H:%M") %></div>
            <% if @jogo.estadio.present? %>
              <div class="text-xs opacity-50 mt-1"><%= @jogo.estadio %></div>
            <% end %>

            <% if @jogo.prob_mandante.present? && !current_user.esconder_odds %>
              <div class="mt-4 max-w-md mx-auto bg-base-200/60 p-4 rounded-xl border border-base-200 shadow-inner">
                <h3 class="text-xs uppercase font-extrabold tracking-widest text-slate-500 mb-2">Probabilidades de Resultado</h3>
                <div class="flex justify-between text-xs font-bold mb-1.5 px-1">
                  <span class="text-success"><%= @jogo.mandante&.nome || 'Casa' %>: <%= @jogo.prob_mandante %>%</span>
                  <span class="text-slate-500">Empate: <%= @jogo.prob_empate %>%</span>
                  <span class="text-error"><%= @jogo.visitante&.nome || 'Fora' %>: <%= @jogo.prob_visitante %>%</span>
                </div>
                <div class="flex h-3 w-full rounded-full overflow-hidden shadow-inner bg-base-300">
                  <div class="bg-success" style="width: <%= @jogo.prob_mandante %>%;"></div>
                  <div class="bg-slate-400" style="width: <%= @jogo.prob_empate %>%;"></div>
                  <div class="bg-error" style="width: <%= @jogo.prob_visitante %>%;"></div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- VERSUS BOARD -->
        <div class="grid grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] md:flex md:flex-row items-start md:items-center justify-center gap-3 md:gap-12 relative">
          
          <!-- Mandante -->
          <%= render "components/score_input",
              input_id: "gols_casa",
              input_name: "palpite[gols_casa]",
              value: form.object.gols_casa,
              avatar_class: "ring ring-primary",
              image_path: @jogo.mandante&.logo.present? ? "selecoes/#{@jogo.mandante.logo}" : nil,
              team_name: @jogo.mandante&.nome || @jogo.nome_provisorio_mandante.presence || "Mandante",
              compact_mobile: true %>

          <!-- VS Badge -->
          <div class="flex flex-col items-center justify-start md:justify-center pt-20 md:pt-0">
            <div class="w-9 h-9 md:w-12 md:h-12 rounded-full bg-base-300 flex items-center justify-center shadow-inner font-black text-base md:text-xl opacity-70 z-10">
              X
            </div>
          </div>

          <!-- Visitante -->
          <%= render "components/score_input",
              input_id: "gols_fora",
              input_name: "palpite[gols_fora]",
              value: form.object.gols_fora,
              avatar_class: "ring ring-secondary",
              image_path: @jogo.visitante&.logo.present? ? "selecoes/#{@jogo.visitante.logo}" : nil,
              team_name: @jogo.visitante&.nome || @jogo.nome_provisorio_visitante.presence || "Visitante",
              compact_mobile: true %>

        </div>

        <% if @jogo.present? && !@jogo.grupo? %>
          <!-- Container de Vencedor nos Pênaltis -->
          <div id="vencedor-penaltis-container" class="<%= 'hidden' unless form.object.gols_casa.present? && form.object.gols_fora.present? && form.object.gols_casa.to_i == form.object.gols_fora.to_i %> bg-warning/5 border border-warning/20 rounded-3xl p-5 max-w-md mx-auto text-center space-y-3.5 shadow-inner">
            <div class="flex items-center justify-center gap-2 text-warning font-black text-xs uppercase tracking-wider">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 21l8.982-2.246M18 19.086L18 21M21 15v4.5m-3-12h.008v.008H18V7.5Zm-3 3h.008v.008H15v-.008Zm6 0h.008v.008H21v-.008Zm-3 3h.008v.008H18v-.008Zm-3 3h.008v.008H15v-.008Z" />
              </svg>
              Decisão nos Pênaltis (+1 Ponto Extra)
            </div>
            <p class="text-xs opacity-75">Seu palpite é de empate! Escolha quem avança de fase nos pênaltis:</p>
            
            <div class="flex items-center justify-center gap-3">
              <!-- Mandante -->
              <label class="btn btn-outline btn-warning btn-sm rounded-xl cursor-pointer flex-1 font-bold h-10 px-4">
                <%= form.radio_button :vencedor_penaltis_id, @jogo.mandante_id, class: "hidden" %>
                <span><%= @jogo.mandante&.nome || 'Mandante' %></span>
              </label>

              <!-- Visitante -->
              <label class="btn btn-outline btn-warning btn-sm rounded-xl cursor-pointer flex-1 font-bold h-10 px-4">
                <%= form.radio_button :vencedor_penaltis_id, @jogo.visitante_id, class: "hidden" %>
                <span><%= @jogo.visitante&.nome || 'Visitante' %></span>
              </label>
            </div>
          </div>
        <% end %>

        <div class="divider my-4"></div>

        <script>
          (function() {
            function setupPenaltis() {
              const inputCasa = document.getElementById('gols_casa');
              const inputFora = document.getElementById('gols_fora');
              const container = document.getElementById('vencedor-penaltis-container');
              if (!inputCasa || !inputFora || !container) return;

              function checkValues() {
                const valCasa = inputCasa.value;
                const valFora = inputFora.value;

                if (valCasa !== '' && valFora !== '' && parseInt(valCasa) === parseInt(valFora)) {
                  container.classList.remove('hidden');
                } else {
                  container.classList.add('hidden');
                  // Limpa seleções de pênaltis se não for empate
                  const radios = container.querySelectorAll('input[type="radio"]');
                  radios.forEach(r => r.checked = false);
                  atualizarBotoesEstilo();
                }
              }

              function atualizarBotoesEstilo() {
                const labels = container.querySelectorAll('label');
                labels.forEach(label => {
                  const radio = label.querySelector('input[type="radio"]');
                  if (radio && radio.checked) {
                    label.classList.add('bg-warning', 'text-warning-content');
                    label.classList.remove('btn-outline');
                  } else {
                    label.classList.remove('bg-warning', 'text-warning-content');
                    label.classList.add('btn-outline');
                  }
                });
              }

              inputCasa.addEventListener('input', checkValues);
              inputFora.addEventListener('input', checkValues);

              container.querySelectorAll('input[type="radio"]').forEach(radio => {
                radio.addEventListener('change', atualizarBotoesEstilo);
              });

              // Executa inicialmente
              checkValues();
              atualizarBotoesEstilo();
            }

            document.addEventListener("turbo:load", setupPenaltis);
            setupPenaltis();
          })();
        </script>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
          <% if params[:return_to] == 'dashboard' %>
            <%= link_to "Voltar ao Início",
              authenticated_root_path,
              class: "btn btn-ghost" %>
          <% else %>
            <%= link_to "Voltar aos Jogos",
              jogos_path(tipo: @jogo&.tipo || params[:tipo]),
              class: "btn btn-ghost" %>
          <% end %>

          <% se_quick_mode = params[:quick_mode].present? || params[:quick_mode] == 'true' %>
          <%= form.submit se_quick_mode ? "Salvar e Próximo Jogo ➔" : "Confirmar Palpite",
            class: "btn btn-primary btn-lg px-12 shadow-lg #{se_quick_mode ? 'animate-pulse' : ''}" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
