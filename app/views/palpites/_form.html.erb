<div class="w-full max-w-3xl mx-auto px-4 pb-8">
  <div class="card bg-base-100 shadow-2xl border border-base-200">
    <div class="card-body p-8 md:p-12">
      <%= form_with(model: palpite, class: "space-y-10") do |form| %>
        <%= form.hidden_field :jogo_id %>

        <% if palpite.errors.any? %>
          <div class="alert alert-error shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <ul class="list-disc ml-5 text-sm font-medium">
              <% palpite.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <% if @jogo.present? %>
          <div class="text-center mb-8">
            <h2 class="text-sm uppercase tracking-widest font-bold opacity-50 mb-1">Jogo Selecionado</h2>
            <div class="badge badge-primary badge-outline text-xs mb-4"><%= @jogo.data.strftime("%d/%m/%Y às %H:%M") %></div>
            <% if @jogo.estadio.present? %>
              <div class="text-xs opacity-50 mt-1"><%= @jogo.estadio %></div>
            <% end %>
          </div>
        <% end %>

        <!-- VERSUS BOARD -->
        <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-12 relative">
          
          <!-- Mandante -->
          <div class="flex flex-col items-center gap-4 w-full md:w-1/3">
            <div class="avatar">
              <div class="w-24 h-24 rounded-full ring ring-primary ring-offset-base-100 ring-offset-4 shadow-xl bg-base-200 flex items-center justify-center overflow-hidden">
                <% if @jogo.mandante&.logo.present? %>
                  <%= image_tag "selecoes/#{@jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                <% else %>
                  <span class="text-3xl font-black opacity-30">?</span>
                <% end %>
              </div>
            </div>
            
            <span class="text-xl font-bold text-center">
              <%= @jogo.mandante&.nome || @jogo.nome_provisorio_mandante.presence || "Mandante" %>
            </span>

            <div class="form-control w-24">
              <%= form.number_field :gols_casa,
                min: 0,
                max: 99,
                value: form.object.gols_casa || 0,
                class: "input input-bordered input-lg text-center text-4xl font-black h-20 shadow-inner bg-base-200 #{palpite.errors[:gols_casa].any? ? 'input-error' : 'focus:border-primary focus:ring-2 focus:ring-primary/20'}" %>
            </div>
          </div>

          <!-- VS Badge -->
          <div class="hidden md:flex flex-col items-center justify-center">
            <div class="w-12 h-12 rounded-full bg-base-300 flex items-center justify-center shadow-inner font-black text-xl opacity-70 z-10">
              X
            </div>
          </div>

          <div class="md:hidden w-full flex justify-center py-2">
            <div class="badge badge-neutral">VS</div>
          </div>

          <!-- Visitante -->
          <div class="flex flex-col items-center gap-4 w-full md:w-1/3">
            <div class="avatar">
              <div class="w-24 h-24 rounded-full ring ring-secondary ring-offset-base-100 ring-offset-4 shadow-xl bg-base-200 flex items-center justify-center overflow-hidden">
                <% if @jogo.visitante&.logo.present? %>
                  <%= image_tag "selecoes/#{@jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                <% else %>
                  <span class="text-3xl font-black opacity-30">?</span>
                <% end %>
              </div>
            </div>
            
            <span class="text-xl font-bold text-center">
              <%= @jogo.visitante&.nome || @jogo.nome_provisorio_visitante.presence || "Visitante" %>
            </span>

            <div class="form-control w-24">
              <%= form.number_field :gols_fora,
                min: 0,
                max: 99,
                value: form.object.gols_fora || 0,
                class: "input input-bordered input-lg text-center text-4xl font-black h-20 shadow-inner bg-base-200 #{palpite.errors[:gols_fora].any? ? 'input-error' : 'focus:border-secondary focus:ring-2 focus:ring-secondary/20'}" %>
            </div>
          </div>

        </div>

        <div class="divider my-4"></div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8">
          <%= link_to "Voltar aos Jogos",
            jogos_path(tipo: @jogo&.tipo || params[:tipo]),
            class: "btn btn-ghost" %>

          <%= form.submit "Confirmar Palpite",
            class: "btn btn-primary btn-lg px-12 shadow-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>