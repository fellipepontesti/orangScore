<% content_for :title, "Perfil" %>

<div class="w-full max-w-3xl mx-auto px-4">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8 py-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Perfil</span>
        <span>/</span>
        <span>Meu Perfil</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Meu Perfil
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Confira suas informações no OrangScore.</p>
    </div>

    <div class="flex flex-wrap gap-2 items-center">
      <%= link_to "Editar perfil", edit_perfil_path, class: "btn btn-primary btn-sm sm:btn-md font-bold text-white rounded-2xl" %>
      <button type="button" class="btn btn-outline btn-sm sm:btn-md rounded-2xl" onclick="modal_alterar_senha.showModal()">Alterar senha</button>
    </div>
  </div>

  <div class="bg-base-100 shadow-lg rounded-box p-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mb-8">
      <div class="bg-base-300 text-neutral-content w-20 h-20 rounded-full flex items-center justify-center shrink-0">
        <span class="font-black text-3xl"><%= @usuario.name.first.upcase %></span>
      </div>

      <div>
        <h2 class="text-2xl font-bold"><%= @usuario.name %></h2>
        <p class="text-base-content/60"><%= @usuario.email %></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="rounded-box border border-base-300 p-5">
        <p class="text-sm text-base-content/60 mb-1">Plano</p>
        <p class="font-bold uppercase"><%= @usuario.assinatura&.plano || "basic" %></p>
      </div>

      <div class="rounded-box border border-base-300 p-5">
        <p class="text-sm text-base-content/60 mb-1">Pontos</p>
        <p class="font-bold"><%= @usuario.total_pontos %></p>
      </div>

      <div class="rounded-box border border-base-300 p-5 sm:col-span-2">
        <p class="text-sm text-base-content/60 mb-3">Seleção que torce</p>
        
        <% if @usuario.selecao.present? %>
          <%= link_to selecao_path(@usuario.selecao), class: "flex items-center gap-3 group w-fit" do %>
            <div class="avatar shrink-0">
              <div class="mask mask-squircle h-10 w-10 bg-base-200 flex items-center justify-center overflow-hidden transition duration-200 group-hover:scale-105">
                <% if @usuario.logo_selecao.present? %>
                  <%= image_tag "selecoes/#{@usuario.logo_selecao}", class: "object-cover w-full h-full" %>
                <% else %>
                  <span class="text-xs font-bold opacity-40">?</span>
                <% end %>
              </div>
            </div>
            <p class="font-bold group-hover:underline text-base-content"><%= @usuario.selecao.nome %></p>
          <% end %>
        <% else %>
          <div class="flex items-center gap-3 opacity-50 italic text-sm">
            <div class="mask mask-squircle h-10 w-10 bg-base-200 flex items-center justify-center font-bold text-xs">?</div>
            <span>Nenhuma seleção selecionada</span>
          </div>
        <% end %>

      </div>
    </div>
  </div>

  <%# MODAL ALTERAR SENHA %>
  <dialog id="modal_alterar_senha" class="modal">
    <div class="modal-box max-w-md bg-base-100 border border-base-300 shadow-2xl">
      <h3 class="font-bold text-2xl mb-6 text-center text-white">
        Alterar Senha
      </h3>

      <%= form_with model: @usuario, url: update_password_path, method: :patch, local: true do |f| %>
        <div class="form-control mb-4">
          <label class="label">
            <span class="label-text font-medium text-slate-300">Senha atual</span>
          </label>
          <%= f.password_field :current_password,
            class: "input input-bordered w-full bg-base-200 text-white",
            required: true %>
        </div>

        <div class="form-control mb-4">
          <label class="label">
            <span class="label-text font-medium text-slate-300">Nova senha</span>
          </label>
          <%= f.password_field :password,
            class: "input input-bordered w-full bg-base-200 text-white",
            required: true %>
          <label class="label">
            <span class="label-text-alt text-slate-400">Min. 8 caracteres, incluindo maiúscula, minúscula, número e símbolo.</span>
          </label>
        </div>

        <div class="form-control mb-6">
          <label class="label">
            <span class="label-text font-medium text-slate-300">Confirmação da nova senha</span>
          </label>
          <%= f.password_field :password_confirmation,
            class: "input input-bordered w-full bg-base-200 text-white",
            required: true %>
        </div>

        <div class="modal-action flex justify-between gap-2">
          <button
            type="button"
            class="btn btn-ghost"
            onclick="modal_alterar_senha.close()">
            Cancelar
          </button>

          <%= f.submit "Atualizar Senha", class: "btn btn-primary font-bold" %>
        </div>
      <% end %>
    </div>
  </dialog>
</div>