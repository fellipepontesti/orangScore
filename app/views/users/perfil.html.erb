<% content_for :title, "Perfil" %>

<div class="w-full max-w-3xl mx-auto px-4">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8 py-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Perfil</span>
        <span>/</span>
        <span>Meu Perfil</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Meu Perfil
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Confira suas informações no OrangScore.</p>
    </div>

    <div class="flex flex-wrap gap-2 items-center">
      <button type="button" class="btn btn-outline btn-sm sm:btn-md rounded-2xl gap-1.5" onclick="modal_conquistas.showModal()">🏅 Conquistas</button>
      <%= link_to "Editar perfil", edit_perfil_path, class: "btn btn-primary btn-sm sm:btn-md font-bold text-white rounded-2xl" %>
      <button type="button" class="btn btn-outline btn-sm sm:btn-md rounded-2xl" onclick="modal_alterar_senha.showModal()">Alterar senha</button>
    </div>
  </div>

  <div class="bg-base-100 shadow-lg rounded-box p-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mb-8">
      <div class="bg-base-300 text-neutral-content w-20 h-20 rounded-full flex items-center justify-center shrink-0">
        <span class="font-black text-3xl"><%= @usuario.name.first.upcase %></span>
      </div>

      <div>
        <div class="flex flex-wrap items-center gap-2.5">
          <h2 class="text-2xl font-bold"><%= @usuario.name %></h2>
          
          <!-- Conquistas em Destaque -->
          <div class="flex items-center gap-1">
            <% @usuario.user_conquistas.where(destacada: true).includes(:conquista).each do |uc| %>
              <div class="badge <%= uc.conquista.cor %> border-none p-1.5 h-8 w-8 text-base flex items-center justify-center rounded-lg shadow-sm" title="<%= uc.conquista.nome %>: <%= uc.conquista.descricao %>">
                <%= uc.conquista.icon %>
              </div>
            <% end %>
          </div>
        </div>
        <p class="text-base-content/60"><%= @usuario.email %></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="rounded-box border border-base-300 p-5">
        <p class="text-sm text-base-content/60 mb-1">Plano</p>
        <p class="font-bold uppercase"><%= @usuario.assinatura&.plano || "basic" %></p>
      </div>

      <div class="rounded-box border border-base-300 p-5">
        <p class="text-sm text-base-content/60 mb-1">Pontos</p>
        <p class="font-bold"><%= @usuario.total_pontos %></p>
      </div>

      <div class="rounded-box border border-base-300 p-5 sm:col-span-2">
        <p class="text-sm text-base-content/60 mb-3">Seleção que torce</p>
        
        <% if @usuario.selecao.present? %>
          <%= link_to selecao_path(@usuario.selecao), class: "flex items-center gap-3 group w-fit" do %>
            <div class="avatar shrink-0">
              <div class="mask mask-squircle h-10 w-10 bg-base-200 flex items-center justify-center overflow-hidden transition duration-200 group-hover:scale-105">
                <% if @usuario.logo_selecao.present? %>
                  <%= image_tag "selecoes/#{@usuario.logo_selecao}", class: "object-cover w-full h-full" %>
                <% else %>
                  <span class="text-xs font-bold opacity-40">?</span>
                <% end %>
              </div>
            </div>
            <p class="font-bold group-hover:underline text-base-content"><%= @usuario.selecao.nome %></p>
          <% end %>
        <% else %>
          <div class="flex items-center gap-3 opacity-50 italic text-sm">
            <div class="mask mask-squircle h-10 w-10 bg-base-200 flex items-center justify-center font-bold text-xs">?</div>
            <span>Nenhuma seleção selecionada</span>
          </div>
        <% end %>

      </div>
    </div>
  </div>

  <%# MODAL ALTERAR SENHA %>
  <dialog id="modal_alterar_senha" class="modal">
    <div class="modal-box max-w-md bg-base-100 border border-base-300 shadow-2xl">
      <h3 class="font-bold text-2xl mb-6 text-center text-white">
        Alterar Senha
      </h3>

      <%= form_with model: @usuario, url: update_password_path, method: :patch, local: true do |f| %>
        <div class="form-control mb-4">
          <label class="label">
            <span class="label-text font-medium text-slate-300">Senha atual</span>
          </label>
          <%= f.password_field :current_password,
            class: "input input-bordered w-full bg-base-200 text-white",
            required: true %>
        </div>

        <div class="form-control mb-4">
          <label class="label">
            <span class="label-text font-medium text-slate-300">Nova senha</span>
          </label>
          <%= f.password_field :password,
            class: "input input-bordered w-full bg-base-200 text-white",
            required: true %>
          <label class="label">
            <span class="label-text-alt text-slate-400">Min. 8 caracteres, incluindo maiúscula, minúscula, número e símbolo.</span>
          </label>
        </div>

        <div class="form-control mb-6">
          <label class="label">
            <span class="label-text font-medium text-slate-300">Confirmação da nova senha</span>
          </label>
          <%= f.password_field :password_confirmation,
            class: "input input-bordered w-full bg-base-200 text-white",
            required: true %>
        </div>

        <div class="modal-action flex justify-between gap-2">
          <button
            type="button"
            class="btn btn-ghost"
            onclick="modal_alterar_senha.close()">
            Cancelar
          </button>

          <%= f.submit "Atualizar Senha", class: "btn btn-primary font-bold" %>
        </div>
      <% end %>
    </div>
  </dialog>

  <%# MODAL GERENCIAR CONQUISTAS %>
  <dialog id="modal_conquistas" class="modal">
    <div class="modal-box max-w-2xl bg-base-100 border border-base-300 shadow-2xl">
      <h3 class="font-bold text-2xl mb-2 text-center text-white">
        🏅 Gerenciar Conquistas
      </h3>
      <p class="text-sm text-base-content/60 text-center mb-6">
        Seu plano atual (<span class="font-bold uppercase text-primary"><%= @usuario.assinatura&.plano || "basic" %></span>) permite destacar até 
        <span class="font-black text-white"><%= @usuario.premium? ? 3 : 1 %></span> 
        <%= @usuario.premium? ? "conquistas" : "conquista" %> no seu perfil.
      </p>

      <%= form_with url: update_perfil_conquistas_path, method: :patch, local: true do |f| %>
        <%# Ordena as conquistas: desbloqueadas primeiro %>
        <%
          conquistas_ordenadas = @todas_conquistas.sort_by do |c|
            @conquistas_desbloqueadas[c.id].present? ? 0 : 1
          end
        %>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-h-[60vh] overflow-y-auto pr-2 mb-2">
          <% conquistas_ordenadas.each do |c| %>
            <% user_conquista = @conquistas_desbloqueadas[c.id] %>
            <% is_unlocked = user_conquista.present? %>
            
            <div class="flex items-center gap-3 p-3 rounded-xl border border-base-300 bg-base-200/50 <%= 'opacity-50 select-none' unless is_unlocked %>">
              <!-- Ícone/Badge -->
              <div class="flex items-center justify-center w-12 h-12 rounded-xl text-2xl shrink-0 <%= is_unlocked ? c.cor : 'bg-base-300 text-base-content/30 border border-dashed border-base-content/20' %>">
                <%= is_unlocked ? c.icon : '🔒' %>
              </div>
              
              <!-- Texto -->
              <div class="flex-1 min-w-0">
                <p class="font-bold text-sm text-white truncate"><%= c.nome %></p>
                <p class="text-xs text-base-content/60 leading-tight"><%= c.descricao %></p>
                <% if is_unlocked %>
                  <p class="text-[9px] text-success font-semibold mt-1">Conquistado em <%= user_conquista.created_at.strftime("%d/%m/%y") %></p>
                <% end %>
              </div>
              
              <!-- Checkbox (apenas para desbloqueadas) -->
              <% if is_unlocked %>
                <div class="form-control">
                  <label class="label cursor-pointer">
                    <input type="checkbox" name="featured_ids[]" value="<%= user_conquista.id %>" <%= 'checked' if user_conquista.destacada? %> class="checkbox checkbox-primary checkbox-sm rounded-md" />
                  </label>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Indicativo de rolagem para baixo -->
        <div class="text-center text-xs text-base-content/40 mt-1 mb-4 flex items-center justify-center gap-1 select-none">
          <span>Role para baixo para ver mais conquistas</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 animate-bounce">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </div>

        <div class="modal-action flex justify-between gap-2 border-t border-base-200 pt-4">
          <button type="button" class="btn btn-ghost" onclick="modal_conquistas.close()">Cancelar</button>
          <%= f.submit "Salvar Destaques", class: "btn btn-primary font-bold text-white px-6" %>
        </div>
      <% end %>
    </div>
  </dialog>

</div>

<script>
  function setupAchievementCheckboxes() {
    const checkboxes = document.querySelectorAll('input[type="checkbox"][name="featured_ids[]"]');
    const limit = <%= @usuario.premium? ? 3 : 1 %>;

    checkboxes.forEach(cb => {
      cb.removeEventListener("change", handleCheckboxChange);
      cb.addEventListener("change", handleCheckboxChange);
    });

    function handleCheckboxChange(e) {
      const checkedCount = document.querySelectorAll('input[type="checkbox"][name="featured_ids[]"]:checked').length;
      if (checkedCount > limit) {
        e.target.checked = false;
        alert(`Você só pode destacar até ${limit} conquista(s) no seu plano.`);
      }
    }
  }

  document.addEventListener("turbo:load", setupAchievementCheckboxes);
  document.addEventListener("DOMContentLoaded", setupAchievementCheckboxes);
</script>