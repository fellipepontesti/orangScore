<% content_for :title, "Usuários" %>

<div class="w-full max-w-6xl mx-auto px-4">
  <h1 class="font-bold text-4xl text-center mb-8 p-4 pb-8 pt-8">
    Usuários
  </h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body items-center text-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Total de Usuários</h2>
        <p class="text-4xl font-black text-primary"><%= @total_usuarios %></p>
      </div>
    </div>
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body items-center text-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Usuários Plus</h2>
        <p class="text-4xl font-black text-secondary"><%= @total_plus %></p>
      </div>
    </div>
    <div class="card bg-base-100 shadow border border-base-200">
      <div class="card-body items-center text-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Usuários Premium</h2>
        <p class="text-4xl font-black text-warning"><%= @total_premium %></p>
      </div>
    </div>
  </div>

  <dialog id="modal_filtros_usuarios" class="modal">
    <div class="modal-box max-w-lg">

      <h3 class="font-bold text-lg mb-4 text-center">
        Filtrar usuários
      </h3>

      <%= form_with url: users_path, method: :get do |f| %>

        <div class="space-y-4">

          <div class="form-control">
            <label class="label">
              <span class="label-text">Nome</span>
            </label>
            <%= f.text_field :nome,
              value: params[:nome],
              class: "input input-bordered w-full",
              placeholder: "Digite o nome" %>
          </div>

          <div class="form-control">
            <label class="label">
              <span class="label-text">Email</span>
            </label>
            <%= f.text_field :email,
              value: params[:email],
              class: "input input-bordered w-full",
              placeholder: "Digite o email" %>
          </div>

          <div class="form-control">
            <label class="label">
              <span class="label-text">Seleção</span>
            </label>
            <%= f.select :selecao,
              options_for_select(User.distinct.pluck(:logo_selecao), params[:selecao]),
              { include_blank: "Todas" },
              class: "select select-bordered w-full" %>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="form-control">
              <label class="label">
                <span class="label-text">Ordenar por</span>
              </label>
              <%= f.select :order,
                options_for_select(@ordenacao_usuarios.map { |value, label| [label, value] }, params[:order].presence || "created_at"),
                {},
                class: "select select-bordered w-full" %>
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text">Direção</span>
              </label>
              <%= f.select :direction,
                options_for_select(@direcoes_ordenacao.map { |value, label| [label, value] }, params[:direction].presence || "desc"),
                {},
                class: "select select-bordered w-full" %>
            </div>
          </div>

        </div>

        <div class="modal-action flex justify-between mt-6">

          <%= link_to "Limpar",
            users_path,
            class: "btn btn-ghost bg-error text-white" %>

          <div class="flex gap-2">
            <button type="button"
              class="btn"
              onclick="modal_filtros_usuarios.close()">
              Cancelar
            </button>

            <%= f.submit "Aplicar",
              class: "btn btn-primary" %>
          </div>

        </div>

      <% end %>

    </div>
  </dialog>

  <div class="flex justify-end mb-4">
    <button
      class="btn btn-primary p-6"
      onclick="modal_filtros_usuarios.showModal()">
      Filtros
    </button>
  </div>

  <% if @usuarios.any? %>
    <ul class="bg-base-100 rounded-box shadow-md w-full p-4 sm:p-8">
      <% @usuarios.each_with_index do |usuario, i| %>
        <li class="flex flex-col lg:flex-row items-start justify-between hover:bg-base-300/50 cursor-pointer p-4 gap-4 border-b border-base-300 last:border-b-0"
            onclick="window.location='<%= edit_user_path(usuario) %>'">
          
          <div class="flex items-center gap-4 w-full min-w-0">
            <div class="font-bold text-gray-500 w-8 shrink-0">
              <%= usuario.id %>
            </div>

            <div class="avatar shrink-0">
              <% if usuario.logo_selecao.present? && usuario.selecao.present? %>
                <%= link_to selecao_path(usuario.selecao), onclick: "event.stopPropagation();", class: "group block" do %>
                  <div class="mask mask-squircle h-12 w-12 bg-base-200 flex items-center justify-center overflow-hidden transition duration-200 group-hover:scale-110">
                    <%= image_tag "selecoes/#{usuario.logo_selecao}", class: "object-cover w-full h-full" %>
                  </div>
                <% end %>
              <% else %>
                <div class="mask mask-squircle h-12 w-12 bg-base-200 flex items-center justify-center text-xs font-bold opacity-40">
                  ?
                </div>
              <% end %>
            </div>

            <div class="flex flex-col flex-1 min-w-0">
              <div class="font-medium text-lg truncate">
                <%= usuario.name %>
              </div>
              <div class="flex flex-wrap items-center gap-2 mt-1">
                <%= conta_status_badge(usuario) %>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 md:flex items-end gap-4 w-full md:w-auto mt-2 sm:mt-0">
            <div class="flex flex-col items-start">
              <span class="text-xs uppercase font-semibold opacity-60">Criado em</span>
              <span class="font-bold text-sm text-base-content/80 whitespace-nowrap">
                <%= usuario.created_at.in_time_zone("America/Sao_Paulo").strftime("%d/%m/%Y") %>
              </span>
            </div>

            <div class="flex flex-col items-start">
              <span class="text-xs uppercase font-semibold opacity-60">Logins</span>
              <span class="font-bold text-lg text-accent"><%= usuario.sign_in_count.to_i %></span>
            </div>

            <div class="flex flex-col items-start">
              <span class="text-xs uppercase font-semibold opacity-60">Palpites</span>
              <span class="font-bold text-lg text-primary"><%= usuario.total_palpites %></span>
            </div>

            <div class="flex flex-col items-start">
              <span class="text-xs uppercase font-semibold opacity-60">Pontos</span>
              <span class="font-bold text-lg text-primary"><%= usuario.total_pontos %></span>
            </div>

            <div class="flex flex-col items-start col-span-2">
              <span class="text-xs uppercase font-semibold opacity-60">Plano</span>
              <%= form_with url: change_plan_user_path(usuario), method: :patch, class: "m-0 p-0", data: { turbo: false } do |f| %>
                <%= f.select :plano, 
                    options_for_select([['Basic', 'basic'], ['Semi-Plus', 'semi_plus'], ['Plus', 'plus'], ['Premium', 'premium']], usuario.assinatura&.plano), 
                    {}, 
                    { class: "select select-sm select-bordered w-full mt-1", onchange: "this.form.submit()", onclick: "event.stopPropagation()" } %>
              <% end %>
            </div>

            <div class="flex justify-end gap-2 shrink-0 col-span-2">
              <%= link_to edit_user_path(usuario),
                class: "btn btn-sm btn-ghost hover:scale-110 transition flex items-center justify-center",
                onclick: "event.stopPropagation()" do %>
                <div class="avatar">
                  <div class="mask mask-squircle h-5 w-5 invert transition">
                    <%= image_tag "icons/editar.png", class: "object-contain w-full h-full" %>
                  </div>
                </div>
              <% end %>

              <%= button_to user_path(usuario),
                method: :delete,
                form: {
                  data: {
                    turbo_confirm: "Remover usuário?"
                  }
                },
                class: "btn btn-sm btn-ghost bg-transparent hover:scale-110 transition flex items-center justify-center",
                onclick: "event.stopPropagation()" do %>
                <div class="avatar">
                  <div class="mask mask-squircle h-5 w-5 invert">
                    <%= image_tag "icons/delete.png", class: "object-contain w-full h-full" %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-center text-gray-500 mt-10">
      Nenhum usuário encontrado.
    </p>
  <% end %>

  <div class="mt-8 mb-4 flex justify-center">
    <%= will_paginate @usuarios, renderer: TailwindLinkRenderer, previous_label: "Anterior", next_label: "Próxima" %>
  </div>
</div>