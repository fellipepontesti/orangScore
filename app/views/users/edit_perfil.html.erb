<% content_for :title, "Editar perfil" %>

<div class="w-full max-w-3xl mx-auto px-4 py-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <div class="space-y-1">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <%= link_to "Perfil", perfil_path, class: "hover:underline" %>
        <span>/</span>
        <span>Editar Perfil</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Editar Perfil
      </h1>
    </div>

    <%= link_to perfil_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <div class="bg-base-100 shadow-lg rounded-box p-8">
    <% if @usuario.errors.any? %>
      <div class="alert alert-error mb-6">
        <span><%= @usuario.errors.full_messages.to_sentence %></span>
      </div>
    <% end %>

    <%= form_with model: @usuario, url: perfil_path, method: :patch do |f| %>
      <div class="form-control mb-5">
        <label class="label mb-4">
          <span class="label-text">Nome</span>
        </label>
        <%= f.text_field :name,
          class: "input input-bordered w-full",
          required: true,
          pattern: "[A-Za-zÀ-ÖØ-öø-ÿ\\s]+",
          title: "Use apenas letras e espaços" %>
        <p class="text-xs text-base-content/50 mt-2">Use apenas letras e espaços.</p>
      </div>

      <div class="form-control mb-4">
        <label class="label mb-4">
          <span class="label-text">Seleção que torce</span>
        </label>

        <% if @usuario.selecao_editavel? %>
          <%= f.collection_select :selecao_id,
            @selecoes,
            :id,
            :nome,
            {},
            class: "select select-bordered w-full" %>
        <% else %>
          <input class="input input-bordered w-full" value="<%= @usuario.selecao&.nome %>" disabled>
          <p class="text-xs text-base-content/50 mt-2">
            A seleção só pode ser alterada antes do primeiro jogo da Copa.
          </p>
        <% end %>
      </div>

      <div class="flex justify-between">
        <%= f.submit "Salvar alterações", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
