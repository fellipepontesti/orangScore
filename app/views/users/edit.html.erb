<% content_for :title, "Editar usuário" %>

<div class="w-full max-w-3xl mx-auto px-4 py-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <%= link_to "Usuários", users_path, class: "hover:underline" %>
        <span>/</span>
        <span>Editar Usuário</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Editar Usuário
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Altere informações cadastrais e pontuação do usuário.</p>
    </div>

    <%= link_to users_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <div class="bg-base-100 shadow-lg rounded-box p-8">

    <%= form_with model: @usuario do |f| %>

      <!-- 🔹 Nome -->
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text">Nome</span>
        </label>
        <%= f.text_field :name,
          class: "input input-bordered w-full rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500" %>
      </div>

      <!-- 🔹 Email -->
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text">Email</span>
        </label>
        <%= f.email_field :email,
          class: "input input-bordered w-full rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500" %>
      </div>

      <!-- 🔹 Pontos -->
      <div class="form-control mb-4">
        <label class="label">
          <span class="label-text">Pontos</span>
        </label>
        <%= f.number_field :pontos,
          class: "input input-bordered w-full rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500" %>
      </div>

      <!-- 🔹 Seleção -->
      <div class="form-control mb-6">
        <label class="label">
          <span class="label-text">Seleção favorita</span>
        </label>
        <%= f.select :logo_selecao,
          options_for_select(User.distinct.pluck(:logo_selecao), @usuario.logo_selecao),
          {},
          class: "select select-bordered w-full rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500" %>
      </div>

      <div class="flex justify-between">

        <%= f.submit "Salvar alterações",
          class: "btn btn-primary rounded-2xl font-bold" %>

      </div>

    <% end %>

  </div>

</div>