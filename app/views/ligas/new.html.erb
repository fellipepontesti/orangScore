<% content_for :title, "Criar liga" %>

<div class="space-y-8 max-w-3xl mx-auto py-8 px-4">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6">
    <div class="space-y-1">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <%= link_to "Ligas", ligas_path, class: "hover:underline" %>
        <span>/</span>
        <span>Criar liga</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent">
        Criar Nova Liga
      </h1>
      <p class="text-slate-400 text-sm sm:text-base">
        Crie uma liga e convide seus amigos para disputar quem tem os melhores palpites.
      </p>
    </div>
    
    <%= link_to ligas_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <%= render "form", liga: @liga %>
</div>
