<li
  class="list-row flex items-center justify-between gap-4 p-3 hover:bg-base-300/50! cursor-pointer rounded-xl transition-colors"
  data-url="<%= liga_path(liga) %>"
>
  <div class="flex items-center gap-4 min-w-0 flex-1">
    <div class="avatar avatar-placeholder shrink-0">
      <div class="bg-base-300 text-neutral-content w-12 rounded-full">
        <span class="font-bold"><%= liga.nome.first.upcase %></span>
      </div>
    </div>

    <div class="min-w-0 flex-1">
      <div class="font-bold text-base sm:text-lg text-white break-words pr-2">
        <%= liga.nome %>
      </div>
      <div class="text-xs uppercase font-semibold opacity-60 mt-0.5">
        <%= liga.liga_membros.count %> membros
      </div>
    </div>
  </div>

  <% if current_user.root? || current_user.id == liga.owner_id %>
    <div class="hidden md:flex gap-2 shrink-0" onclick="event.stopPropagation()">
      <%= link_to edit_liga_path(liga),
        class: "rounded-md p-2 bg-base-300 hover:bg-warning/80! flex items-center justify-center transition-colors" do %>
        <div class="h-5 w-5 invert">
          <%= image_tag "icons/editar.png" %>
        </div>
      <% end %>

      <%= button_to liga,
        method: :delete,
        class: "rounded-md p-2 bg-base-300 hover:bg-error/80! flex items-center justify-center transition-colors",
        data: { turbo_confirm: "Você tem certeza?" } do %>
        <div class="mask mask-squircle h-5 w-5 invert">
          <%= image_tag "icons/delete.png" %>
        </div>
      <% end %>
    </div>

    <div class="dropdown dropdown-end md:hidden shrink-0" onclick="event.stopPropagation()">
      <div tabindex="0" role="button" class="btn btn-ghost btn-sm btn-square hover:bg-base-300">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5zM12 12.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5zM12 18.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5z" />
        </svg>
      </div>
      <ul tabindex="0" class="dropdown-content menu bg-base-200 rounded-box z-50 w-40 p-2 shadow-2xl border border-white/5 mt-1">
        <li>
          <%= link_to edit_liga_path(liga), class: "flex items-center gap-2 text-warning font-semibold py-3" do %>
            <div class="h-4 w-4 invert"><%= image_tag "icons/editar.png" %></div>
            Editar
          <% end %>
        </li>
        <li>
          <%= button_to liga,
            method: :delete,
            class: "flex items-center gap-2 text-error font-semibold w-full text-left py-3",
            data: { turbo_confirm: "Você tem certeza?" } do %>
            <div class="h-4 w-4 invert"><%= image_tag "icons/delete.png" %></div>
            Excluir
          <% end %>
        </li>
      </ul>
    </div>
  <% end %>
</li>
