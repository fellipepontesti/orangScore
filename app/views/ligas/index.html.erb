<% content_for :title, "Ligas" %>

<div class="flex-1 flex flex-col w-full px-4 py-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-6">
    <div class="flex flex-col gap-1">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Ligas</span>
        <span>/</span>
        <span>Minhas Ligas</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Ligas
      </h1>
    </div>

    <div class="flex flex-wrap gap-2 items-center">
      <% if current_user.root? %>
        <button class="btn btn-outline btn-sm sm:btn-md rounded-2xl" onclick="modal_filtros_ligas.showModal()">
          Filtros
        </button>
      <% end %>

      <%= link_to "Ver ligas públicas",
        publicas_ligas_path,
        class: "btn btn-outline btn-primary btn-sm sm:btn-md font-bold rounded-2xl"
      %>

      <% if !current_user.atingiu_limite_de_ligas? || current_user.root? %>
        <%= link_to "Criar nova liga",
          new_liga_path,
          class: "btn btn-primary btn-sm sm:btn-md font-bold text-white rounded-2xl"
        %>
      <% end %>
    </div>
  </div>

  <% if current_user.atingiu_limite_de_ligas? %>
    <div class="mb-8 mt-4 relative group">
      <div class="absolute -inset-1 bg-linear-to-r from-orange-600 to-yellow-500 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>

      <div class="relative flex flex-col md:flex-row items-center justify-between gap-6 p-4 bg-base-200 border border-white/5 rounded-2xl shadow-xl">
        <div class="flex items-center gap-4 pl-8">
          <div>
            <h3 class="text-white font-bold text-lg">Você atingiu o limite de ligas do seu plano!</h3>
            <p class="text-slate-400 text-sm">Faça o upgrade para adicionar mais ligas e criar novas competições.</p>
          </div>
        </div>

        <%= link_to planos_path, 
            class: "btn border-none bg-linear-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white px-8 rounded-xl font-bold shadow-lg shadow-orange-500/20 inline-flex items-center justify-center" do %>
          Fazer Upgrade Agora
        <% end %>
      </div>
    </div>
  <% end %>

  <dialog id="modal_filtros_ligas" class="modal">
    <div class="modal-box max-w-lg">
      <h3 class="font-bold text-lg mb-4 text-center">Filtrar Ligas</h3>
      <%= form_with url: ligas_path, method: :get, local: true do |f| %>
        <div class="form-control">
          <label class="label"><span class="label-text">Nome</span></label>
          <%= f.text_field :nome, value: params[:nome], class: "input input-bordered w-full", placeholder: "Buscar por nome..." %>
        </div>
        <div class="modal-action flex justify-between mt-6">
          <%= link_to "Limpar", ligas_path, class: "btn btn-ghost bg-error text-white" %>
          <div class="flex gap-2">
            <button type="button" class="btn" onclick="modal_filtros_ligas.close()">Cancelar</button>
            <%= f.submit "Aplicar", class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </dialog>

  <div id="ligas" class="w-full space-y-8">
    <section>
      <div class="flex items-center gap-4 mb-3 px-2">
        <h2 class="text-xl font-bold whitespace-nowrap">Minhas ligas</h2>
        <div class="h-px bg-base-300 flex-1"></div>
      </div>

      <ul class="list bg-base-100 rounded-box shadow-md w-full p-4 sm:p-8 space-y-2">
        <% if @ligas_do_usuario.any? %>
          <% @ligas_do_usuario.each do |liga| %>
            <%= render "list_item", liga: liga %>
          <% end %>
        <% else %>
          <p class="text-center my-10 opacity-60">Você não possui ligas criadas.</p>
        <% end %>
      </ul>
    </section>

    <section>
      <div class="flex items-center gap-4 mb-3 px-2">
        <h2 class="text-xl font-bold whitespace-nowrap">
          <%= current_user.root? ? "Outras ligas do sistema" : "Ligas de terceiros" %>
        </h2>
        <div class="h-px bg-base-300 flex-1"></div>
      </div>

      <ul class="list bg-base-100 rounded-box shadow-md w-full p-4 sm:p-8 space-y-2">
        <% if @outras_ligas.any? %>
          <% @outras_ligas.each do |liga| %>
            <%= render "list_item", liga: liga %>
          <% end %>
        <% else %>
          <p class="text-center my-10 opacity-60">Você ainda não participa de outras ligas.</p>
        <% end %>
      </ul>
    </section>
  </div>
</div>
