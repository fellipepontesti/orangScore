<% content_for :title, "Detalhes liga" %>

<div class="w-full max-w-6xl mx-auto px-4">
  <h1 class="font-bold text-4xl text-center mb-8 p-4 pb-8 pt-8">
    Liga: <%= @liga.nome %>
  </h1>

  <dialog id="modal_users_pending" class="modal">
    <div class="modal-box max-w-3xl">
      <h3 class="text-lg font-bold mb-4">
        Gestão de Pendências
      </h3>

      <div role="tablist" class="tabs tabs-bordered">

        <!-- ========================= -->
        <!-- ABA CONVIDADOS -->
        <!-- ========================= -->

        <input type="radio"
              name="tabs_pendencias"
              role="tab"
              class="tab"
              aria-label="Convidados (<%= @membros_pendentes.count %>)"
              checked />

        <div role="tabpanel" class="tab-content p-4 border-base-300 bg-base-100">

          <% if @membros_pendentes.any? %>

            <% @membros_pendentes.each do |liga_membro| %>
              <div class="flex justify-between items-center border-b py-2">

                <div>
                  <p class="font-medium">
                    <%= liga_membro.user.name %>
                  </p>
                  <p class="text-sm text-gray-500">
                    Convidado em
                    <%= liga_membro.created_at.strftime("%d/%m/%Y às %H:%M") %>
                  </p>
                </div>

                <%= button_to remove_member_liga_path(
                        @liga,
                        liga_membro_id: liga_membro.id
                      ),
                      method: :delete,
                      form: {
                        data: {
                          turbo_confirm: "Cancelar este convite?"
                        }
                      },
                      class: "btn btn-error btn-sm" do %>
                  Remover
                <% end %>

              </div>
            <% end %>

          <% else %>
            <p class="text-sm text-gray-500">
              Nenhum convite pendente.
            </p>
          <% end %>

        </div>


        <!-- ========================= -->
        <!-- ABA SOLICITAÇÕES DE EXCLUSÃO -->
        <!-- ========================= -->

        <input type="radio"
              name="tabs_pendencias"
              role="tab"
              class="tab"
              aria-label="Solicitações de Exclusão (<%= @membros_excluir.count %>)" />

        <div role="tabpanel" class="tab-content p-4 border-base-300 bg-base-100">

          <% if @membros_excluir.any? %>

            <% @membros_excluir.each do |liga_membro| %>
              <div class="flex justify-between items-center border-b py-2">

                <div>
                  <p class="font-medium">
                    <%= liga_membro.user.name %>
                  </p>
                  <p class="text-sm text-gray-500">
                    Solicitação feita em
                    <%= liga_membro.updated_at.strftime("%d/%m/%Y às %H:%M") %>
                  </p>
                </div>

                <%= button_to remove_member_liga_path(
                        @liga,
                        liga_membro_id: liga_membro.id
                      ),
                      method: :delete,
                      form: {
                        data: {
                          turbo_confirm: "Confirmar exclusão deste membro?"
                        }
                      },
                      class: "btn btn-error btn-sm" do %>
                  Confirmar Exclusão
                <% end %>

              </div>
            <% end %>

          <% else %>
            <p class="text-sm text-gray-500">
              Nenhuma solicitação de exclusão.
            </p>
          <% end %>

        </div>

      </div>

      <div class="modal-action">
        <form method="dialog">
          <button class="btn">Fechar</button>
        </form>
      </div>

    </div>
  </dialog>

  <% if @membros_ativos.any? %>
    <ul class="list bg-base-100 rounded-box shadow-md w-full p-4 sm:p-8">
      <% @membros_ativos.each_with_index do |liga_membro, i| %>
        <li class="list-row flex flex-col sm:flex-row items-start sm:items-center justify-between hover:bg-base-300/50! p-4 gap-4 border-b last:border-b-0 border-base-200">
          
          <div class="flex items-center gap-4 w-full sm:w-auto">
            <div class="font-bold text-lg w-8 flex items-center justify-center shrink-0">
              <%= i + 1 %>°
              <% if i == 0 %>
                <span class="ml-1 text-yellow-500">👑</span>
              <% end %>
            </div>

            <div class="avatar">
              <div class="mask mask-squircle h-12 w-12">
                <%= image_tag "selecoes/#{liga_membro.user.logo_selecao}" %>
              </div>
            </div>

            <div class="flex flex-col flex-1">
              <div class="font-medium text-lg flex items-center gap-2">
                <%= liga_membro.user.name %>
                <span class="uppercase text-[10px] font-semibold opacity-70 bg-base-200 px-2 py-1 rounded-full">
                  <%= role_icon(liga_membro.role) %>
                </span>
              </div>
              <div class="text-sm font-semibold mt-1">
                Status: <%= status_icon(liga_membro.status) %>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-between w-full sm:w-auto gap-6 mt-2 sm:mt-0">
            <div class="flex flex-col items-start sm:items-end w-full sm:w-auto">
              <span class="text-xs uppercase font-semibold opacity-60">Pontuação</span>
              <span class="font-bold text-xl text-primary"><%= liga_membro.user.pontos %></span>
            </div>

            <% if liga_membro.role != "owner" %>
              <% is_owner = @meu_vinculo&.role == "owner" %>
              <% is_admin_allowed =
                  @meu_vinculo&.role == "admin" &&
                  liga_membro.status.in?(%w[invited accepted]) %>

              <% if current_user.root? || is_owner || is_admin_allowed %>
                <div class="flex justify-end gap-2 shrink-0">

                  <% if is_owner || current_user.root? %>
                    <% if liga_membro.role == "admin"%>
                      <% img_name="adm_red"%>
                      <% message="Tem certeza que deseja remover o usuário #{liga_membro.user.name} da função de administrador da sua liga?"%>
                    <%else%>
                      <% message="Tem certeza que deseja adicionar o usuário #{liga_membro.user.name} como administrador da sua liga?"%>
                      <% img_name="adm"%>
                    <%end%>
                    <%= button_to set_admin_liga_path(
                          @liga,
                          liga_membro_id: liga_membro.id
                        ),
                        method: :post,
                        form: { data: { turbo_confirm: message } },
                        class: "btn btn-sm btn-ghost hover:scale-110 transition" do %>

                      <div class="avatar">
                        <div class="mask mask-squircle h-5 w-5">
                          <%= image_tag "icons/#{img_name}.png" %>
                        </div>
                      </div>

                    <% end %>
                  <% end %>

                  <% method = is_owner ? :delete : :patch %>
                  <% confirm_message =
                      is_owner ?
                        "Remover este membro da liga?" :
                        "Solicitar exclusão deste membro? O dono da liga precisará aprovar." %>
                  <% if current_user.root? || is_owner || current_user.id != liga_membro.user_id %>
                    <%= button_to remove_member_liga_path(
                          @liga,
                          liga_membro_id: liga_membro.id
                        ),
                        method: method,
                        form: { data: { turbo_confirm: confirm_message } },
                        class: "btn btn-sm btn-ghost hover:scale-110 transition" do %>

                      <div class="avatar">
                        <div class="mask mask-squircle h-5 w-5 invert">
                          <%= image_tag "icons/delete.png" %>
                        </div>
                      </div>
                    <% end %>
                  <% end %>

                </div>
              <% end %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-center text-gray-500 mt-10">
      Nenhum outro membro nesta liga.
    </p>
  <% end %>

  <div class="mt-10 flex flex-wrap justify-center gap-4">
    <%= link_to "Voltar", ligas_path,
      class: "rounded-md px-5 py-3 bg-accent hover:bg-accent/80 font-medium" %>
    
    <% if @pode_convidar %>
      <button
        type="button"
        class="rounded-md px-5 py-3 bg-success hover:bg-success/90! font-medium"
        onclick="copyInviteLink('<%= liga_convite_url(@liga.invite_token) %>')">
        Copiar convite da liga
      </button>
      <button
        type="button"
        class="rounded-md px-5 py-3 bg-success hover:bg-success/90! font-medium"
        onclick="add_member_modal.showModal()">
        Adicionar membro
      </button>
    <% end %>

    <% if @meu_vinculo&.role == "owner" %>
      <button class="rounded-md px-5 py-3 bg-warning hover:bg-warning/80 font-medium" onclick="modal_users_pending.showModal()">
        Gerenciar pendências
      </button>
    <%end%>

    <%= button_to "Sair da liga",
      quit_liga_path(@liga),
      method: :delete,
      class: "rounded-md px-5 py-3 text-white bg-red-600 hover:bg-red-600/80 font-medium",
      data: { turbo_confirm: "Tem certeza que deseja sair dessa liga?" } %>
  </div>

  <dialog id="add_member_modal" class="modal">
    <div class="modal-box max-w-md">
      <h3 class="font-bold text-lg text-center mb-4">
        Convidar membro
      </h3>

      <%= form_with url: invite_member_liga_path(@liga), method: :post do |f| %>
        <div class="form-control mb-4">
          <label class="label p-4">
            <span class="label-text font-medium">Email do usuário</span>
          </label>

          <%= f.email_field :email,
            class: "input input-ghost input-bordered w-full",
            placeholder: "email@exemplo.com",
            required: true %>
        </div>

        <div class="modal-action flex justify-between">
          <button
            type="button"
            class="btn btn-ghost bg-error"
            onclick="add_member_modal.close()">
            Cancelar
          </button>

          <%= f.submit "Enviar convite", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </dialog>
  <div
    id="copy-alert"
    class="alert alert-success fixed bottom-4 right-4 shadow-lg hidden w-fit z-50">
    <span>Link copiado com sucesso!</span>
  </div>
  <script>
    function copyInviteLink(link) {
      navigator.clipboard.writeText(link)

      const alert = document.getElementById('copy-alert')

      alert.classList.remove('hidden')

      setTimeout(() => {
        alert.classList.add('hidden')
      }, 2500)
    }
  </script>
</div>
