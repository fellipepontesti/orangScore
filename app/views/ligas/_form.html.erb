<div id="<%= dom_id liga %>" class="w-full max-w-3xl mx-auto">
  <div class="bg-base-100 rounded-box shadow-lg p-8 space-y-6">
    <% if liga.errors.any? %>
      <div class="rounded-box bg-error/50 text-white border border-error p-4">
        <h3 class="font-semibold mb-2">
          <%= pluralize(liga.errors.count, "erro") %> ao salvar a liga
        </h3>

        <ul class="list-disc list-inside text-sm space-y-1">
          <% liga.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with(model: liga) do |form| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="stat rounded-box sm:col-span-2">
          <div class="stat-title">Nome da liga</div>
          <div class="stat-value">
            <%= form.text_field :nome,
              class: [
                "input input-bordered input-ghost bg-base-200 w-full",
                liga.errors[:nome].any? ? "input-error" : ""
              ],
              placeholder: "Digite o nome da liga" %>
          </div>
        </div>

        <div class="stat rounded-box sm:col-span-2">
          <div class="form-control mb-4">
            <label class="cursor-pointer label justify-start gap-4">
              <%= form.check_box :publica, class: "toggle toggle-success", id: "toggle_publica" %>
              <span class="label-text font-bold">Liga Pública (Qualquer pessoa pode encontrar)</span>
            </label>
          </div>

          <div class="form-control mb-4" id="container_entrada_livre" style="<%= liga.publica ? '' : 'display: none;' %>">
            <label class="cursor-pointer label justify-start gap-4">
              <%= form.check_box :entrada_livre, class: "toggle toggle-success" %>
              <span class="label-text font-bold">Entrada Livre (Usuários entram diretamente sem precisar de aprovação)</span>
            </label>
          </div>

          <div class="form-control">
            <label class="cursor-pointer label justify-start gap-4 w-full">
              <%= form.check_box :pontuacao_zerada, class: "toggle toggle-success shrink-0", disabled: liga.persisted? %>
              <div class="flex flex-col flex-1 min-w-0">
                <span class="label-text font-bold whitespace-normal">Começar com pontuação zerada</span>
                <span class="label-text-alt opacity-70 whitespace-normal">Os pontos e palpites dos membros só começam a contar a partir do momento em que eles entram na liga. (Não editável após a criação)</span>
              </div>
            </label>
          </div>
        </div>

        <div class="stat sm:col-span-2 rounded-box flex flex-col sm:flex-row gap-4 items-center justify-center">
          <%= form.submit(
            liga.persisted? ? "Salvar alterações" : "Criar liga",
            class: "rounded-md px-5 py-3 bg-primary hover:bg-primary/80! font-medium text-white"
          ) %>

        </div>

      </div>
    <% end %>

  </div>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    const togglePublica = document.getElementById('toggle_publica');
    const containerEntradaLivre = document.getElementById('container_entrada_livre');
    
    if(togglePublica && containerEntradaLivre) {
      togglePublica.addEventListener('change', function() {
        if(this.checked) {
          containerEntradaLivre.style.display = 'block';
        } else {
          containerEntradaLivre.style.display = 'none';
        }
      });
    }
  });
</script>
