<div
  id="referral-rules-notice"
  class="w-full bg-base-100 border border-primary/30 rounded-box shadow-lg p-4"
  data-notice-key="orangscore-referral-rules-dismissed">
  <div class="flex flex-col lg:flex-row lg:items-center gap-4">
    <div class="shrink-0 rounded-full bg-primary/10 text-primary p-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.73 21a2 2 0 0 1-3.46 0" />
      </svg>
    </div>
  </div>
</div>

<script>
  function dismissReferralRulesNotice() {
    const notice = document.getElementById('referral-rules-notice')
    if (!notice) return

    localStorage.setItem(notice.dataset.noticeKey, 'true')
    notice.classList.add('hidden')
  }

  document.addEventListener('turbo:load', () => {
    const notice = document.getElementById('referral-rules-notice')
    if (!notice) return

    if (localStorage.getItem(notice.dataset.noticeKey) === 'true') {
      notice.classList.add('hidden')
    }
  })
</script>
