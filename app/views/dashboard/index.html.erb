<div class="space-y-8 w-full max-w-7xl mx-auto overflow-x-hidden">
  <!-- Cabeçalho -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-base-200 pb-6">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Home</span>
        <span>/</span>
        <span>Resumo</span>
      </div>
      <div class="flex flex-wrap items-center gap-3 min-w-0">
        <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent break-words min-w-0 pb-1">
          Olá, <%= current_user.name %>
        </h1>
        <% if current_user.assinatura&.premium? %>
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-r from-amber-400 via-yellow-300 to-amber-500 text-slate-950 border border-yellow-200/50 scale-105 shadow-sm" title="Usuário Premium">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 drop-shadow-[0_1px_2px_rgba(0,0,0,0.3)]">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
            </svg>
          </div>
        <% end %>
      </div>
      <p class="opacity-70 text-base sm:text-lg">Aqui está um resumo do seu OrangScore</p>
    </div>

    <% if current_user.assinatura&.basic? %>
      <%= link_to planos_path, class: "btn btn-warning btn-outline btn-sm gap-2 rounded-2xl" do %>
        <span>Upgrade para Premium</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
      <% end %>
    <% end %>
  </div>

  <%= render "shared/quick_bet_banner", next_jogo: @next_jogo_rapido, pendentes: @jogos_pendentes %>  <!-- Partidas do Dia -->
  <div class="space-y-8">
    
    <!-- Seção 1: Jogos em Andamento -->
    <% if @jogos_em_andamento.any? %>
      <section class="space-y-4">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold flex items-center gap-2">
              <span class="w-3.5 h-3.5 rounded-full bg-emerald-500 animate-pulse shrink-0"></span>
              Jogos em Andamento
            </h2>
            <p class="text-sm opacity-70 mt-1">Partidas acontecendo agora em tempo real.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4">
          <% @jogos_em_andamento.each do |jogo| %>
            <% palpite = @palpites_por_jogo_id[jogo.id] %>
            <div class="bg-base-100 rounded-2xl border border-base-200 p-4 flex flex-col sm:flex-row items-center justify-between gap-4 hover:shadow-md transition duration-200 cursor-pointer w-full"
                 onclick="if(event.target.tagName !== 'A' && event.target.tagName !== 'BUTTON' && !event.target.closest('a') && !event.target.closest('button')) window.location='<%= jogo_path(jogo) %>'">
              
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 flex-1 w-full min-w-0">
                <!-- Esquerda: AO VIVO -->
                <div class="text-xs font-semibold shrink-0 text-center border-b sm:border-b-0 sm:border-r border-base-200 pb-2 sm:pb-0 sm:pr-4 sm:w-24 sm:min-w-[96px] w-full flex sm:flex-col justify-between sm:justify-center items-center gap-1">
                  <p class="text-success font-black uppercase tracking-wider animate-pulse">AO VIVO</p>
                </div>

                <!-- Meio: Confronto com Placar -->
                <div class="flex items-center gap-3 sm:gap-6 flex-1 min-w-0 w-full justify-between sm:justify-start">
                  <!-- Mandante -->
                  <div class="flex items-center gap-2 font-bold text-sm min-w-0 flex-1 justify-end text-right">
                    <span class="truncate" title="<%= jogo.mandante&.nome || jogo.nome_provisorio_mandante %>">
                      <% if jogo.mandante.present? %>
                        <%= link_to jogo.mandante.nome, selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                      <% else %>
                        <%= jogo.nome_provisorio_mandante || 'Mandante' %>
                      <% end %>
                    </span>
                    <div class="mask mask-squircle h-6 w-6 bg-base-200 overflow-hidden flex items-center justify-center shrink-0">
                      <% if jogo.mandante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    </div>
                  </div>

                  <!-- Placar -->
                  <div class="flex items-center gap-2 shrink-0 justify-center min-w-[70px]">
                    <span class="font-mono font-black text-base px-2 py-0.5 rounded-sm bg-base-200/60">
                      <%= jogo.gols_mandante.to_i %>
                    </span>
                    <span class="opacity-30 text-xs font-black">x</span>
                    <span class="font-mono font-black text-base px-2 py-0.5 rounded-sm bg-base-200/60">
                      <%= jogo.gols_visitante.to_i %>
                    </span>
                  </div>

                  <!-- Visitante -->
                  <div class="flex items-center gap-2 font-bold text-sm min-w-0 flex-1 justify-start">
                    <div class="mask mask-squircle h-6 w-6 bg-base-200 overflow-hidden flex items-center justify-center shrink-0">
                      <% if jogo.visitante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    </div>
                    <span class="truncate" title="<%= jogo.visitante&.nome || jogo.nome_provisorio_visitante %>">
                      <% if jogo.visitante.present? %>
                        <%= link_to jogo.visitante.nome, selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                      <% else %>
                        <%= jogo.nome_provisorio_visitante || 'Visitante' %>
                      <% end %>
                    </span>
                  </div>
                </div>
              </div>

              <!-- Direita: Ações -->
              <div class="shrink-0 w-full sm:w-64 sm:min-w-[256px] flex flex-col sm:flex-row items-center gap-2 sm:gap-3 justify-end border-t sm:border-t-0 border-base-200 pt-3 sm:pt-0">
                <% if palpite.present? %>
                  <span class="text-[10px] font-bold text-slate-400">
                    Seu palpite: <%= palpite.gols_casa %> - <%= palpite.gols_fora %>
                  </span>
                <% end %>
                <div class="flex gap-2 w-full sm:w-auto justify-end">
                  <%= link_to "Ver Palpites", palpites_jogo_path(jogo), class: "btn btn-sm btn-success text-white font-bold px-4 py-2 hover:scale-105 transition" %>
                </div>
              </div>

            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <!-- Seção 2: Jogos Pendentes (Suspensos) -->
    <% if @jogos_suspensos.any? %>
      <section class="space-y-4">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold flex items-center gap-2 text-warning">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
              </svg>
              Jogos Pendentes
            </h2>
            <p class="text-sm opacity-70 mt-1">Partidas atualmente suspensas — acompanhe os placares parciais.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4">
          <% @jogos_suspensos.each do |jogo| %>
            <% palpite = @palpites_por_jogo_id[jogo.id] %>
            <div class="bg-base-100 rounded-2xl border border-base-200 p-4 flex flex-col sm:flex-row items-center justify-between gap-4 hover:shadow-md transition duration-200 cursor-pointer w-full"
                 onclick="if(event.target.tagName !== 'A' && event.target.tagName !== 'BUTTON' && !event.target.closest('a') && !event.target.closest('button')) window.location='<%= jogo_path(jogo) %>'">
              
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 flex-1 w-full min-w-0">
                <!-- Esquerda: SUSPENSO -->
                <div class="text-xs font-semibold shrink-0 text-center border-b sm:border-b-0 sm:border-r border-base-200 pb-2 sm:pb-0 sm:pr-4 sm:w-24 sm:min-w-[96px] w-full flex sm:flex-col justify-between sm:justify-center items-center gap-1">
                  <p class="text-warning font-black uppercase tracking-wider">SUSPENSO</p>
                </div>

                <!-- Meio: Confronto com Placar -->
                <div class="flex items-center gap-3 sm:gap-6 flex-1 min-w-0 w-full justify-between sm:justify-start">
                  <!-- Mandante -->
                  <div class="flex items-center gap-2 font-bold text-sm min-w-0 flex-1 justify-end text-right">
                    <span class="truncate" title="<%= jogo.mandante&.nome || jogo.nome_provisorio_mandante %>">
                      <% if jogo.mandante.present? %>
                        <%= link_to jogo.mandante.nome, selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                      <% else %>
                        <%= jogo.nome_provisorio_mandante || 'Mandante' %>
                      <% end %>
                    </span>
                    <div class="mask mask-squircle h-6 w-6 bg-base-200 overflow-hidden flex items-center justify-center shrink-0">
                      <% if jogo.mandante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    </div>
                  </div>

                  <!-- Placar -->
                  <div class="flex items-center gap-2 shrink-0 justify-center min-w-[70px]">
                    <span class="font-mono font-black text-base px-2 py-0.5 rounded-sm bg-base-200/60">
                      <%= jogo.gols_mandante.to_i %>
                    </span>
                    <span class="opacity-30 text-xs font-black">x</span>
                    <span class="font-mono font-black text-base px-2 py-0.5 rounded-sm bg-base-200/60">
                      <%= jogo.gols_visitante.to_i %>
                    </span>
                  </div>

                  <!-- Visitante -->
                  <div class="flex items-center gap-2 font-bold text-sm min-w-0 flex-1 justify-start">
                    <div class="mask mask-squircle h-6 w-6 bg-base-200 overflow-hidden flex items-center justify-center shrink-0">
                      <% if jogo.visitante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    </div>
                    <span class="truncate" title="<%= jogo.visitante&.nome || jogo.nome_provisorio_visitante %>">
                      <% if jogo.visitante.present? %>
                        <%= link_to jogo.visitante.nome, selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                      <% else %>
                        <%= jogo.nome_provisorio_visitante || 'Visitante' %>
                      <% end %>
                    </span>
                  </div>
                </div>
              </div>

              <!-- Direita: Ações -->
              <div class="shrink-0 w-full sm:w-64 sm:min-w-[256px] flex flex-col sm:flex-row items-center gap-2 sm:gap-3 justify-end border-t sm:border-t-0 border-base-200 pt-3 sm:pt-0">
                <% if palpite.present? %>
                  <span class="text-[10px] font-bold text-slate-400">
                    Seu palpite: <%= palpite.gols_casa %> - <%= palpite.gols_fora %>
                  </span>
                <% end %>
                <div class="flex gap-2 w-full sm:w-auto justify-end">
                  <%= link_to "Ver Palpites", palpites_jogo_path(jogo), class: "btn btn-sm btn-success text-white font-bold px-4 py-2 hover:scale-105 transition" %>
                </div>
              </div>

            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <!-- Seção 3: Jogos de Hoje -->
    <section class="space-y-4">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
        <div>
          <h2 class="text-2xl font-bold flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Jogos de hoje
          </h2>
          <p class="text-sm opacity-70 mt-1">Partidas programadas e finalizadas para o dia de hoje.</p>
        </div>

        <%= link_to "Ver todos os jogos", jogos_path(data: Time.zone.today), class: "btn btn-ghost bg-base-100 w-full sm:w-auto" %>
      </div>

      <% if @jogos_de_hoje.any? %>
        <div class="grid grid-cols-1 gap-4">
          <% @jogos_de_hoje.each do |jogo| %>
            <% palpite = @palpites_por_jogo_id[jogo.id] %>
            <div class="bg-base-100 rounded-2xl border border-base-200 p-4 flex flex-col sm:flex-row items-center justify-between gap-4 hover:shadow-md transition duration-200 cursor-pointer w-full"
                 onclick="if(event.target.tagName !== 'A' && event.target.tagName !== 'BUTTON' && !event.target.closest('a') && !event.target.closest('button')) window.location='<%= jogo_path(jogo) %>'">
              
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 flex-1 w-full min-w-0">
                <!-- Esquerda: Horário -->
                <div class="text-xs font-semibold shrink-0 text-center border-b sm:border-b-0 sm:border-r border-base-200 pb-2 sm:pb-0 sm:pr-4 sm:w-24 sm:min-w-[96px] w-full flex sm:flex-col justify-between sm:justify-center items-center gap-1">
                  <p class="opacity-50">Horário</p>
                  <p class="text-warning font-black text-sm">
                    <%= jogo.data.strftime('%H:%M') %>
                  </p>
                </div>

                <!-- Meio: Confronto com Placar/VS -->
                <div class="flex items-center gap-3 sm:gap-6 flex-1 min-w-0 w-full justify-between sm:justify-start">
                  <!-- Mandante -->
                  <div class="flex items-center gap-2 font-bold text-sm min-w-0 flex-1 justify-end text-right">
                    <span class="truncate" title="<%= jogo.mandante&.nome || jogo.nome_provisorio_mandante %>">
                      <% if jogo.mandante.present? %>
                        <%= link_to jogo.mandante.nome, selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                      <% else %>
                        <%= jogo.nome_provisorio_mandante || 'Mandante' %>
                      <% end %>
                    </span>
                    <div class="mask mask-squircle h-6 w-6 bg-base-200 overflow-hidden flex items-center justify-center shrink-0">
                      <% if jogo.mandante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    </div>
                  </div>

                  <!-- Placar ou VS -->
                  <div class="flex flex-col items-center justify-center min-w-[75px] gap-1 select-none">
                    <div class="flex items-center gap-2 shrink-0 justify-center">
                      <% if jogo.finalizado? %>
                        <span class="font-mono font-black text-base px-2 py-0.5 rounded-sm bg-base-200/60">
                          <%= jogo.gols_mandante.to_i %>
                        </span>
                        <span class="opacity-30 text-xs font-black">x</span>
                        <span class="font-mono font-black text-base px-2 py-0.5 rounded-sm bg-base-200/60">
                          <%= jogo.gols_visitante.to_i %>
                        </span>
                      <% else %>
                        <span class="opacity-30 text-xs font-black">x</span>
                      <% end %>
                    </div>
                    <% if jogo.finalizado? && jogo.gols_penaltis_mandante.present? && jogo.gols_penaltis_visitante.present? %>
                      <span class="text-[9px] font-black text-warning uppercase tracking-wider bg-warning/10 px-1.5 py-0.5 rounded border border-warning/20">
                        Pen: <%= jogo.gols_penaltis_mandante %>x<%= jogo.gols_penaltis_visitante %>
                      </span>
                    <% end %>
                  </div>

                  <!-- Visitante -->
                  <div class="flex items-center gap-2 font-bold text-sm min-w-0 flex-1 justify-start">
                    <div class="mask mask-squircle h-6 w-6 bg-base-200 overflow-hidden flex items-center justify-center shrink-0">
                      <% if jogo.visitante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    </div>
                    <span class="truncate" title="<%= jogo.visitante&.nome || jogo.nome_provisorio_visitante %>">
                      <% if jogo.visitante.present? %>
                        <%= link_to jogo.visitante.nome, selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                      <% else %>
                        <%= jogo.nome_provisorio_visitante || 'Visitante' %>
                      <% end %>
                    </span>
                  </div>
                </div>
              </div>

              <!-- Direita: Ações -->
              <div class="shrink-0 w-full sm:w-64 sm:min-w-[256px] flex flex-col sm:flex-row items-center gap-2 sm:gap-3 justify-end border-t sm:border-t-0 border-base-200 pt-3 sm:pt-0">
                <% if palpite.present? %>
                  <span class="text-[11px] font-bold text-slate-400 flex items-center gap-1 whitespace-nowrap shrink-0">
                    Seu palpite: <strong class="font-mono text-slate-200 bg-base-200 px-1.5 py-0.5 rounded"><%= palpite.gols_casa %> - <%= palpite.gols_fora %></strong>
                    <% if jogo.finalizado? %>
                      <% user_point = @pontos_por_jogo_id[jogo.id] %>
                      <% pontos = user_point ? user_point.pontos.to_i : 0 %>
                      <% badge_class = case pontos
                         when 10 then "bg-emerald-500 hover:bg-emerald-600 text-white font-black animate-pulse hover:scale-105 transition-all duration-300 cursor-default"
                         when 7, 5, 2 then "bg-emerald-500 hover:bg-emerald-600 text-white font-black hover:scale-105 transition-all duration-300 cursor-default"
                         else "bg-slate-800 text-slate-400 font-medium hover:scale-105 transition-all duration-300 cursor-default"
                         end
                      %>
                      <span class="badge <%= badge_class %> badge-sm py-2 px-2 ml-1 border-none shadow-sm rounded-md font-mono whitespace-nowrap shrink-0" title="<%= user_point&.motivo || 'Nenhum ponto obtido' %>">
                        <%= pontos > 0 ? "+#{pontos} pts" : "0 pts" %>
                      </span>
                    <% end %>
                  </span>
                <% end %>

                <div class="flex gap-2 w-full sm:w-auto justify-end">
                  <% if jogo.finalizado? %>
                    <%= link_to "Detalhes", jogo_path(jogo), class: "btn btn-sm btn-ghost bg-base-200 font-bold px-4" %>
                  <% elsif palpite.present? %>
                    <%= link_to "Editar Palpite", edit_palpite_path(palpite, return_to: 'dashboard'), class: "btn btn-sm btn-warning text-white font-bold px-4 py-2 hover:scale-105 transition" %>
                  <% else %>
                    <%= link_to "Palpitar", new_palpite_path(jogo_id: jogo.uuid, return_to: 'dashboard'), class: "btn btn-sm btn-primary text-white font-bold px-4 py-2 hover:scale-105 transition" %>
                  <% end %>
                </div>
              </div>

            </div>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-box bg-base-100 border border-base-200 shadow-xl p-6 text-center">
          <p class="font-bold">Nenhum jogo programado ou finalizado para hoje.</p>
        </div>
      <% end %>
    </section>
  </div>

  <!-- Cards de Resumo -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
    <!-- Card 1: Jogos de Hoje -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" onclick="window.location='<%= jogos_path(data: Time.zone.today) %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Jogos de Hoje</h2>
        <p class="text-6xl font-black text-secondary"><%= @jogos_de_hoje.size %></p>
      </div>
    </div>

    <!-- Card 2: Seus Pontos -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" onclick="window.location='<%= pontuacao_users_path %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Seus Pontos</h2>
        <p class="text-6xl font-black text-warning"><%= current_user.total_pontos %></p>
      </div>
    </div>

    <!-- Card 3: Ligas Ativas -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" 
         onclick="window.location='<%= @liga_principal ? liga_path(@liga_principal) : ligas_path %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Minhas Ligas</h2>
        <p class="text-6xl font-black text-primary"><%= @ligas_ativas %></p>
      </div>
    </div>
  </div>

  <!-- Gráfico de Evolução no Ranking -->
  <% if current_user.premium? || current_user.root? %>
    <% if @dados_grafico.present? && @dados_grafico.any? %>
      <div onclick="window.location='<%= ranking_users_path(periodo: 'global') %>'" 
           class="bg-base-100 shadow-xl border border-base-200 hover:border-primary/40 rounded-3xl p-6 sm:p-8 cursor-pointer group transition-all duration-300 hover:shadow-2xl relative overflow-hidden">
        
        <div class="absolute top-6 right-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </div>

        <h3 class="text-xl font-bold mb-1 flex items-center gap-2 text-white group-hover:text-primary transition-colors">
          <span>📈 Sua Evolução no Ranking</span>
        </h3>
        <p class="text-xs opacity-60 mb-6">Acompanhe a sua posição no ranking geral após cada um dos seus palpites finalizados. Clique para ver o ranking completo!</p>
        
        <div class="w-full h-[300px] relative">
          <canvas id="rankingHistoryChart"></canvas>
        </div>
      </div>
    <% end %>
  <% else %>
    <div onclick="window.location='<%= planos_path %>'" 
