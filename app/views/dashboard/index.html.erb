<div class="space-y-8 w-full max-w-7xl mx-auto overflow-x-hidden">
  <!-- Cabeçalho -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-base-200 pb-6">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Home</span>
        <span>/</span>
        <span>Resumo</span>
      </div>
      <div class="flex flex-wrap items-center gap-3 min-w-0">
        <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent break-words min-w-0 pb-1">
          Olá, <%= current_user.name %>
        </h1>
        <% if current_user.assinatura&.premium? %>
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-r from-amber-400 via-yellow-300 to-amber-500 text-slate-950 border border-yellow-200/50 scale-105 shadow-sm" title="Usuário Premium">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 drop-shadow-[0_1px_2px_rgba(0,0,0,0.3)]">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
            </svg>
          </div>
        <% end %>
      </div>
      <p class="opacity-70 text-base sm:text-lg">Aqui está um resumo do seu OrangScore</p>
    </div>

    <% if current_user.assinatura&.basic? %>
      <%= link_to planos_path, class: "btn btn-warning btn-outline btn-sm gap-2 rounded-2xl" do %>
        <span>Upgrade para Premium</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
      <% end %>
    <% end %>
  </div>

  <%= render "shared/quick_bet_banner", next_jogo: @next_jogo_rapido, pendentes: @jogos_pendentes %>
  
  <!-- Jogos de Hoje -->
  <section class="space-y-4">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-3">
      <div>
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Jogos de hoje
        </h2>
        <p class="text-sm opacity-70 mt-1">Partidas em andamento e próximas para você acompanhar ou palpitar.</p>
      </div>

      <%= link_to "Ver todos os jogos", jogos_path(data: Time.zone.today), class: "btn btn-ghost bg-base-100 w-full sm:w-auto" %>
    </div>

    <% if @jogos_de_hoje.any? %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <% @jogos_de_hoje.each do |jogo| %>
          <% palpite = @palpites_por_jogo_id[jogo.id] %>
          <div class="rounded-box bg-base-100 border border-base-200 shadow-xl p-4 overflow-hidden hover:shadow-2xl hover:border-primary/20 transition cursor-pointer"
               onclick="if(event.target.tagName !== 'A' && event.target.tagName !== 'BUTTON' && !event.target.closest('a') && !event.target.closest('button')) window.location='<%= jogo_path(jogo) %>'">
            <div class="flex items-center justify-between gap-3 mb-4">
              <div class="min-w-0">
                <p class="text-[10px] uppercase font-black opacity-50">
                  <% if jogo.data.to_date == Time.zone.today %>
                    Hoje às <%= horario_jogo(jogo, "%H:%M") %>
                  <% else %>
                    Início: <%= horario_jogo(jogo, "%d/%m %H:%M") %>
                  <% end %>
                </p>
                <p class="text-xs opacity-60 truncate"><%= jogo.estadio.presence || "Estádio não definido" %></p>
              </div>

              <div class="badge <%= if jogo.finalizado?
                                      'badge-error'
                                    elsif jogo.em_andamento?
                                      'badge-success'
                                    else
                                      'badge-info'
                                    end %> badge-outline shrink-0 font-bold">
                <%= if jogo.finalizado?
                      "Finalizado"
                    elsif jogo.em_andamento?
                      "Em andamento"
                    else
                      "Programado"
                    end %>
              </div>
            </div>

            <div class="grid grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-2 sm:gap-3 rounded-box bg-base-200/50 p-3">
              
              <!-- MANDANTE (JOGOS DE HOJE) -->
              <div class="flex flex-col items-center text-center min-w-0">
                <div class="avatar mb-2">
                  <div class="mask mask-squircle h-10 w-10 bg-base-200 flex items-center justify-center overflow-hidden">
                    <% if jogo.mandante&.logo.present? %>
                      <%= link_to selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "w-full h-full flex items-center justify-center hover:opacity-80 transition" do %>
                        <%= image_tag "selecoes/#{jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center font-bold text-xs">?</div>
                    <% end %>
                  </div>
                </div>
                <span class="font-bold text-sm break-words max-w-full">
                  <% if jogo.mandante.present? %>
                    <%= link_to jogo.mandante.nome, selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                  <% else %>
                    <%= jogo.nome_provisorio_mandante || "A definir" %>
                  <% end %>
                </span>
              </div>

              <div class="flex flex-col items-center min-w-[92px]">
                <% if jogo.finalizado? %>
                  <span class="text-[10px] uppercase font-black text-error mb-1">Finalizado</span>
                  <span class="text-2xl font-black font-mono whitespace-nowrap">
                    <%= jogo.gols_mandante.to_i %> - <%= jogo.gols_visitante.to_i %>
                  </span>
                <% elsif jogo.em_andamento? %>
                  <span class="text-[10px] uppercase font-black text-success mb-1">Placar</span>
                  <span class="text-2xl font-black font-mono whitespace-nowrap">
                    <%= jogo.gols_mandante.to_i %> - <%= jogo.gols_visitante.to_i %>
                  </span>
                <% else %>
                  <span class="text-[10px] uppercase font-black opacity-50 mb-1">Início</span>
                  <span class="text-xl font-black font-mono whitespace-nowrap"><%= horario_jogo(jogo, "%H:%M") %></span>
                <% end %>

                <% if palpite.present? %>
                  <span class="mt-2 text-[10px] font-bold text-primary whitespace-nowrap">
                    Seu palpite: <%= palpite.gols_casa %> - <%= palpite.gols_fora %>
                  </span>
                <% end %>
              </div>

              <!-- VISITANTE (JOGOS DE HOJE) -->
              <div class="flex flex-col items-center text-center min-w-0">
                <div class="avatar mb-2">
                  <div class="mask mask-squircle h-10 w-10 bg-base-200 flex items-center justify-center overflow-hidden">
                    <% if jogo.visitante&.logo.present? %>
                      <%= link_to selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "w-full h-full flex items-center justify-center hover:opacity-80 transition" do %>
                        <%= image_tag "selecoes/#{jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center font-bold text-xs">?</div>
                    <% end %>
                  </div>
                </div>
                <span class="font-bold text-sm break-words max-w-full">
                  <% if jogo.visitante.present? %>
                    <%= link_to jogo.visitante.nome, selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                  <% else %>
                    <%= jogo.nome_provisorio_visitante || "A definir" %>
                  <% end %>
                </span>
              </div>
            </div>

            <div class="flex flex-wrap justify-end gap-2 mt-4">
              <%= link_to "Detalhes", jogo_path(jogo), class: "btn btn-sm btn-ghost bg-base-200" %>

              <% if jogo.finalizado? %>
                <% # Sem opções de palpites quando finalizado %>
              <% elsif jogo.em_andamento? %>
                <%= link_to "Ver todos os palpites", palpites_jogo_path(jogo), class: "btn btn-sm btn-success btn-outline" %>
              <% elsif palpite.present? %>
                <%= link_to "Editar palpite", edit_palpite_path(palpite), class: "btn btn-sm btn-warning text-white" %>
              <% else %>
                <%= link_to "Palpitar", new_palpite_path(jogo_id: jogo.uuid), class: "btn btn-sm btn-primary" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-box bg-base-100 border border-base-200 shadow-xl p-6 text-center">
        <p class="font-bold">Nenhum jogo em andamento ou programado para hoje.</p>
        <p class="text-sm opacity-70 mt-1">Quando houver partida no dia, ela aparece aqui primeiro.</p>
      </div>
    <% end %>
  </section>

  <!-- Cards de Resumo -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
    <!-- Card 1: Jogos de Hoje -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" onclick="window.location='<%= jogos_path(data: Time.zone.today) %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Jogos de Hoje</h2>
        <p class="text-6xl font-black text-secondary"><%= @jogos_de_hoje.size %></p>
      </div>
    </div>

    <!-- Card 2: Seus Pontos -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" onclick="window.location='<%= pontuacao_users_path %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Seus Pontos</h2>
        <p class="text-6xl font-black text-warning"><%= current_user.total_pontos %></p>
      </div>
    </div>

    <!-- Card 3: Ligas Ativas -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" 
         onclick="window.location='<%= @liga_principal ? liga_path(@liga_principal) : ligas_path %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Minhas Ligas</h2>
        <p class="text-6xl font-black text-primary"><%= @ligas_ativas %></p>
      </div>
    </div>
  </div>

  <!-- Conteúdo Principal em 3 Colunas -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
    
    <!-- Coluna 1: Próximos Jogos -->
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        Próximos Jogos
      </h2>
      
      <% if @proximos_jogos.any? %>
        <ul class="list bg-base-100 shadow-xl rounded-box border border-base-200 w-full overflow-hidden">
          <% @proximos_jogos.each do |jogo| %>
            <li class="list-row p-3 sm:p-4 border-b last:border-b-0 border-base-200 grid grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] gap-2 sm:gap-3 items-center hover:bg-base-200/50 transition cursor-pointer" onclick="window.location='<%= jogo_path(jogo) %>'">
              
              <!-- MANDANTE (PRÓXIMOS JOGOS) -->
              <div class="flex items-center gap-2 sm:gap-3 min-w-0">
                <div class="avatar shrink-0">
                  <div class="mask mask-squircle w-8 h-8 bg-base-200 flex items-center justify-center overflow-hidden">
                    <% if jogo.mandante&.logo.present? %>
                      <%= link_to selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "w-full h-full flex items-center justify-center hover:opacity-80 transition" do %>
                        <%= image_tag "selecoes/#{jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center font-bold text-xs">?</div>
                    <% end %>
                  </div>
                </div>
                <span class="font-bold text-sm min-w-0 break-words">
                  <% if jogo.mandante.present? %>
                    <%= link_to jogo.mandante.nome, selecao_path(jogo.mandante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                  <% else %>
                    <%= jogo.nome_provisorio_mandante || "A definir" %>
                  <% end %>
                </span>
              </div>

              <div class="flex flex-col items-center justify-center min-w-[64px]">
                <span class="text-[10px] font-bold opacity-60 uppercase mb-1"><%= horario_jogo(jogo) %></span>
                <span class="text-lg font-black font-mono opacity-20">VS</span>
              </div>

              <!-- VISITANTE (PRÓXIMOS JOGOS) -->
              <div class="flex items-center gap-2 sm:gap-3 justify-end text-right min-w-0">
                <span class="font-bold text-sm min-w-0 break-words">
                  <% if jogo.visitante.present? %>
                    <%# CORRIGIDO: mudado @jogo.visitante para jogo.visitante %>
                    <%= link_to jogo.visitante.nome, selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "hover:underline" %>
                  <% else %>
                    <%= jogo.nome_provisorio_visitante || "A definir" %>
                  <% end %>
                </span>
                <div class="avatar shrink-0">
                  <div class="mask mask-squircle w-8 h-8 bg-base-200 flex items-center justify-center overflow-hidden">
                    <% if jogo.visitante&.logo.present? %>
                      <%= link_to selecao_path(jogo.visitante), onclick: "event.stopPropagation();", class: "w-full h-full flex items-center justify-center hover:opacity-80 transition" do %>
                        <%= image_tag "selecoes/#{jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                      <% end %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center font-bold text-xs">?</div>
                    <% end %>
                  </div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="bg-base-100 p-8 rounded-box shadow text-center border border-base-200">
          <p class="opacity-70">Nenhum jogo programado.</p>
        </div>
      <% end %>
    </div>

    <!-- Coluna 2: Ligas Públicas -->
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
        Ligas Públicas
      </h2>

      <% if @ligas_publicas.any? %>
        <ul class="list bg-base-100 shadow-xl rounded-box border border-base-200 w-full overflow-hidden">
          <% @ligas_publicas.each_with_index do |liga, index| %>
            <li class="list-row p-4 border-b last:border-b-0 border-base-200 flex items-center justify-between gap-3 <%= 'bg-warning/5' if index == 0 %> hover:bg-base-200/50 transition cursor-pointer" onclick="window.location='<%= preview_liga_path(liga) %>'">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-8 text-center font-black text-xl <%= index == 0 ? 'text-warning' : 'opacity-40' %>">
                  <%= index + 1 %>º
                </div>
                <div class="flex flex-col min-w-0">
                  <span class="font-bold text-sm truncate max-w-[150px]"><%= liga.nome %></span>
                  <span class="text-xs opacity-60"><%= liga.owner.name %></span>
                </div>
              </div>
              <div class="flex items-center gap-4 text-right">
                <div class="flex flex-col items-end w-20">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter text-warning">Membros</span>
                  <span class="text-2xl font-black text-warning"><%= liga.total_participantes %></span>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
        <div class="mt-2 text-right">
          <%= link_to "Ver todas as ligas públicas →", publicas_ligas_path, class: "text-sm font-bold text-primary hover:underline" %>
        </div>
      <% else %>
        <div class="bg-base-100 p-8 rounded-box shadow text-center border border-base-200 h-full flex flex-col justify-center items-center gap-4">
          <p class="opacity-70">Nenhuma liga pública encontrada no momento.</p>
          <%= link_to "Criar uma Liga", new_liga_path, class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>
    </div>

    <!-- Coluna 3: Ranking Global -->
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2 cursor-pointer hover:text-secondary transition" onclick="window.location='<%= ranking_users_path %>'">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
        Ranking Global
      </h2>

      <% if current_user.premium? %>
        <ul class="list bg-base-100 shadow-xl rounded-box border border-base-200 w-full overflow-hidden">
          <% @ranking_global.each_with_index do |user, index| %>
            <li class="list-row p-4 border-b last:border-b-0 border-base-200 grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-center">
              <div class="flex items-center gap-3 min-w-0 overflow-hidden">
                <div class="w-8 shrink-0 text-center font-black text-xl <%= index < 3 ? 'text-secondary' : 'opacity-40' %>">
                  <%= index + 1 %>º
                </div>
                <div class="flex flex-col min-w-0 overflow-hidden">
                  <span class="font-bold text-sm truncate"><%= user.name %></span>
                  <% if user.id == current_user.id %>
                    <span class="badge badge-secondary badge-xs mt-1 w-fit">Você</span>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-3 sm:gap-4 text-right shrink-0">
                <div class="flex flex-col items-end min-w-[50px] sm:min-w-[64px]">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter whitespace-nowrap">Palpites</span>
                  <span class="font-bold text-sm sm:text-md text-slate-300"><%= user.try(:total_palpites) || 0 %></span>
                </div>
                <div class="flex flex-col items-end min-w-[56px] sm:min-w-[76px]">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter text-secondary whitespace-nowrap">Pontos</span>
                  <span class="text-lg sm:text-2xl font-black text-secondary leading-none"><%= user.try(:total_pontos_ranking) || user.total_pontos || 0 %></span>
                </div>
              </div>
            </li>
          <% end %>

          <% if @user_global_rank.is_a?(Integer) && @user_global_rank > 5 %>
            <li class="p-2 flex justify-center opacity-30">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
            </li>
            <li class="list-row p-4 bg-secondary/5 border-t border-secondary/20 grid grid-cols-[minmax(0,1fr)_auto] gap-3 items-center">
              <div class="flex items-center gap-3 min-w-0 overflow-hidden">
                <div class="w-8 shrink-0 text-center font-black text-xl text-secondary">
                  <%= @user_global_rank %>º
                </div>
                <div class="flex flex-col min-w-0 overflow-hidden">
                  <span class="font-bold text-sm truncate"><%= current_user.name %></span>
                  <span class="badge badge-secondary badge-xs mt-1 w-fit">Sua Posição</span>
                </div>
              </div>
              <div class="flex items-center gap-3 sm:gap-4 text-right shrink-0">
                <div class="flex flex-col items-end min-w-[50px] sm:min-w-[64px]">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter whitespace-nowrap">Palpites</span>
                  <span class="font-bold text-sm sm:text-md text-slate-300"><%= current_user.palpites.count %></span>
                </div>
                <div class="flex flex-col items-end min-w-[56px] sm:min-w-[76px]">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter text-secondary whitespace-nowrap">Pontos</span>
                  <span class="text-lg sm:text-2xl font-black text-secondary leading-none"><%= current_user.total_pontos %></span>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
        <div class="mt-2 text-right">
          <%= link_to "Ver o ranking completo →", ranking_users_path, class: "text-sm font-bold text-secondary hover:underline" %>
        </div>
      <% else %>
        <div class="relative group h-full">
          <div class="bg-base-100 p-8 rounded-box shadow border border-base-200 filter blur-sm select-none opacity-50 space-y-6 h-full">
            <div class="flex items-center justify-between py-2 border-b"><span>Usuário Exemplo 1</span><span>500</span></div>
            <div class="flex items-center justify-between py-2 border-b"><span>Usuário Exemplo 2</span><span>450</span></div>
            <div class="flex items-center justify-between py-2"><span>Usuário Exemplo 3</span><span>400</span></div>
          </div>
          <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-secondary mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            <p class="font-bold text-secondary uppercase tracking-widest mb-3">Ranking Global</p>
            <%= link_to "Liberar Agora", planos_path, class: "btn btn-secondary btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>

  </div>
</div>

<!-- Botão Flutuante de Doação -->
<div class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 dropdown dropdown-top dropdown-end">
  <div tabindex="0" role="button" class="btn btn-primary btn-circle btn-lg shadow-2xl hover:scale-110 transition-transform animate-pulse hover:animate-none">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
    </svg>
  </div>
  <div tabindex="0" class="dropdown-content w-[calc(100vw-2rem)] sm:w-64 max-w-[16rem] bg-base-100 p-4 rounded-2xl shadow-2xl border border-primary/20 z-[1] mb-2 cursor-default">
    <div class="flex flex-col gap-2">
      <h3 class="font-bold text-primary flex items-center gap-2">
        Apoie o OrangScore ❤️
      </h3>
      <p class="text-xs opacity-70 leading-relaxed">
        Sua doação ajuda a manter o servidor online e trazer novas funcionalidades para todos!
      </p>
      
      <%= form_with url: "#", method: :post, id: "donation-form", class: "mt-2 space-y-2", data: { turbo: false } do |f| %>
        <%= f.hidden_field :plano, value: "doacao" %>
        <%= f.hidden_field :payment_method, value: "pix", id: "donation-payment-method" %>
        <input type="hidden" name="cpf" id="donation-cpf">
        
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs font-bold opacity-50">R$</span>
          <%= f.text_field :valor, value: "5,00", id: "donation-amount", class: "input input-bordered input-sm w-full pl-8 font-bold text-primary focus:border-primary", placeholder: "0,00" %>
        </div>

        <div class="w-full">
          <button type="button" 
                  onclick="modal_doacao_cpf.showModal()"
                  class="btn btn-primary btn-sm w-full gap-2 justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-bold">Apoiar via Pix</span>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Modal para CPF do Pix -->
<dialog id="modal_doacao_cpf" class="modal">
  <div class="modal-box border border-primary/20 bg-base-100">
    <h3 class="font-bold text-lg text-primary mb-2">Quase lá!</h3>
    <p class="text-sm opacity-70 mb-4">Para gerar o QR Code do Pix, o Banco Central exige um CPF válido associado ao pagamento.</p>
    
    <div class="form-control w-full mb-6">
      <label class="label">
        <span class="label-text font-bold mb-4">Qual o seu CPF?</span>
      </label>
      <input type="text" id="input_modal_cpf" placeholder="000.000.000-00" class="input input-ghost w-full" maxlength="14" />
    </div>

    <div class="flex justify-end gap-2">
      <form method="dialog">
        <button class="btn btn-ghost">Cancelar</button>
      </form>
      <button type="button" class="btn btn-primary" onclick="submeterDoacaoPix(event)">
        Gerar Pix Agora
      </button>
    </div>
  </div>
</dialog>

<script>
  function submeterDoacaoPix(event) {
    const cpfInput = document.getElementById('input_modal_cpf');
    const amountInput = document.getElementById('donation-amount');
    
    const btnModal = event ? event.target : document.querySelector('#modal_doacao_cpf .btn-primary');
    const cpfValue = cpfInput.value.replace(/\D/g, '');
    const amountValue = amountInput.value; 

    if (cpfValue.length !== 11) {
      alert("Por favor, digite um CPF válido com 11 números.");
      return;
    }

    btnModal.disabled = true;
    btnModal.innerText = "Processando...";

    const formData = new FormData();
    formData.append('plano', 'doacao');
    formData.append('payment_method', 'pix');
    formData.append('cpf', cpfValue);
    formData.append('valor', amountValue);
    formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

    fetch('<%= checkout_mercado_pago_pix_direto_path %>', {
      method: 'POST',
      body: formData,
      headers: {
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      }
    })
    .then(async response => {
      if (response.redirected) {
        window.location.href = response.url;
      } else {
        const data = await response.json();
        if (data.redirect_url) {
          window.location.href = data.redirect_url;
        } else if (data.error) {
          alert("Erro: " + data.error);
          btnModal.disabled = false;
          btnModal.innerText = "Gerar Pix Agora";
        }
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert("Houve um erro ao processar o Pix.");
      btnModal.disabled = false;
      btnModal.innerText = "Gerar Pix Agora";
    });
  }

  document.addEventListener('turbo:load', () => {
    const amountInput = document.getElementById('donation-amount');
    
    if (amountInput) {
      amountInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\D/g, '');
        value = (value / 100).toFixed(2) + '';
        value = value.replace(".", ",");
        value = value.replace(/(\d)(?=(\d{3})+(?!\d))/g, "$1.");
        e.target.value = value;
      });
    }

    const cpfInput = document.getElementById('input_modal_cpf');
    if (cpfInput) {
      cpfInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\D/g, '');
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
        e.target.value = value;
      });
    }
  });
</script>