<div class="space-y-8 max-w-7xl mx-auto">

  <!-- Cabeçalho -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
  <div class="flex flex-col gap-2">
    <div class="flex items-center gap-3">
      <h1 class="text-4xl font-bold">Olá, <%= current_user.name %></h1>
      <% if current_user.assinatura&.plus? %>

        <div class="flex items-center gap-2 px-4 py-2 rounded-full
                    bg-gradient-to-b from-orange-300 via-orange-500 to-orange-700
                    text-white
                    border border-orange-300
                    shadow-[inset_0_1px_1px_rgba(255,255,255,0.35),0_2px_6px_rgba(0,0,0,0.35)]">

          <svg xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>

          <span class="text-xs font-black tracking-wide">
            PLUS
          </span>
        </div>

      <% elsif current_user.assinatura&.premium? %>

        <div class="flex items-center gap-2 px-4 py-2 rounded-full
                    bg-gradient-to-b from-yellow-300 via-yellow-500 to-yellow-700
                    text-white
                    border border-yellow-300
                    shadow-[inset_0_1px_1px_rgba(255,255,255,0.35),0_2px_6px_rgba(0,0,0,0.35)]">

          <svg xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>

          <span class="text-xs font-black tracking-wide">
            PREMIUM
          </span>
        </div>

      <% else %>

        <div class="flex items-center gap-2 px-4 py-2 rounded-full
                    bg-gradient-to-b from-slate-300 via-slate-500 to-slate-700
                    text-white
                    border border-slate-300
                    shadow-[inset_0_1px_1px_rgba(255,255,255,0.25),0_2px_6px_rgba(0,0,0,0.35)]">

          <svg xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7" />
          </svg>

          <span class="text-xs font-black tracking-wide">
            FREE
          </span>
        </div>

      <% end %>
    </div>
    <p class="opacity-70 text-lg">Aqui está um resumo do seu OrangScore</p>
  </div>

  <% if current_user.assinatura&.basic? %>
    <%= link_to planos_path, class: "btn btn-warning btn-outline btn-sm gap-2" do %>
      <span>Upgrade para Plus</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
    <% end %>
  <% end %>
  <% if current_user.assinatura&.plus? %>
    <%= link_to planos_path, class: "btn btn-premium btn-outline btn-sm gap-2" do %>
      <span>Upgrade para Premium</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
    <% end %>
  <% end %>
</div>

  <!-- Cards de Resumo -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Card 1: Sua Seleção -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" onclick="window.location='<%= jogos_path(grupo: current_user.selecao.grupo_id) %>'">
      <div class="card-body items-center text-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider mb-2">Sua Seleção</h2>
        <div class="flex flex-col items-center gap-3">
          <div class="avatar">
            <div class="w-16 h-16 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2 overflow-hidden bg-base-200">
              <%= image_tag "selecoes/#{current_user.logo_selecao}", class: "w-full h-full object-cover", alt: current_user.selecao.nome if current_user.logo_selecao.present? %>
            </div>
          </div>
          <span class="text-xl font-bold">
            <%= current_user.selecao.nome %>
          </span>
        </div>
      </div>
    </div>

    <!-- Card 2: Seus Pontos -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" onclick="window.location='<%= pontuacao_users_path %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Seus Pontos</h2>
        <p class="text-6xl font-black text-warning"><%= current_user.total_pontos %></p>
      </div>
    </div>

    <!-- Card 3: Ligas Ativas -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" 
         onclick="window.location='<%= @liga_principal ? liga_path(@liga_principal) : ligas_path %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Ligas Ativas</h2>
        <p class="text-6xl font-black text-primary"><%= @ligas_ativas %></p>
      </div>
    </div>

    <!-- Card 4: Jogos Hoje -->
    <div class="card bg-base-100 shadow-xl border border-base-200 hover:shadow-2xl transition cursor-pointer" onclick="window.location='<%= jogos_path(data: Date.today) %>'">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Jogos Hoje</h2>
        <p class="text-6xl font-black text-secondary"><%= @jogos_hoje %></p>
      </div>
    </div>
  </div>

  <!-- Conteúdo Principal em 3 Colunas -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Coluna 1: Próximos Jogos -->
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        Próximos Jogos
      </h2>
      
      <% if @proximos_jogos.any? %>
        <ul class="list bg-base-100 shadow-xl rounded-box border border-base-200 w-full overflow-hidden">
          <% @proximos_jogos.each do |jogo| %>
            <li class="list-row p-4 border-b last:border-b-0 border-base-200 flex justify-between items-center hover:bg-base-200/50 transition cursor-pointer" onclick="window.location='<%= jogo_path(jogo) %>'">
              <div class="flex items-center gap-3 w-[40%]">
                <div class="avatar shrink-0">
                  <div class="mask mask-squircle w-8 h-8">
                    <% if jogo.mandante&.logo.present? %>
                      <%= image_tag "selecoes/#{jogo.mandante.logo}" %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center font-bold text-xs">?</div>
                    <% end %>
                  </div>
                </div>
                <span class="font-bold text-sm truncate"><%= jogo.mandante&.nome || jogo.nome_provisorio_mandante || "A definir" %></span>
              </div>

              <div class="flex flex-col items-center justify-center w-[20%]">
                <span class="text-[10px] font-bold opacity-60 uppercase mb-1"><%= jogo.data.strftime("%d/%m %H:%M") %></span>
                <span class="text-lg font-black font-mono opacity-20">VS</span>
              </div>

              <div class="flex items-center gap-3 w-[40%] justify-end text-right">
                <span class="font-bold text-sm truncate"><%= jogo.visitante&.nome || jogo.nome_provisorio_visitante || "A definir" %></span>
                <div class="avatar shrink-0">
                  <div class="mask mask-squircle w-8 h-8">
                    <% if jogo.visitante&.logo.present? %>
                      <%= image_tag "selecoes/#{jogo.visitante.logo}" %>
                    <% else %>
                      <div class="w-full h-full bg-base-300 flex items-center justify-center font-bold text-xs">?</div>
                    <% end %>
                  </div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="bg-base-100 p-8 rounded-box shadow text-center border border-base-200">
          <p class="opacity-70">Nenhum jogo programado.</p>
        </div>
      <% end %>
    </div>

    <!-- Coluna 2: Ranking da Liga Principal -->
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
        Sua Liga
      </h2>

      <% if @liga_principal && @ranking_liga.any? %>
        <ul class="list bg-base-100 shadow-xl rounded-box border border-base-200 w-full overflow-hidden cursor-pointer" onclick="window.location='<%= liga_path(@liga_principal) %>'">
          <% @ranking_liga.each_with_index do |membro, index| %>
            <li class="list-row p-4 border-b last:border-b-0 border-base-200 flex items-center justify-between <%= 'bg-warning/5' if index == 0 %>">
              <div class="flex items-center gap-4">
                <div class="w-8 text-center font-black text-xl <%= index == 0 ? 'text-warning' : 'opacity-40' %>">
                  <%= index + 1 %>º
                </div>
                <div class="flex flex-col">
                  <span class="font-bold text-sm truncate max-w-[150px]"><%= membro.user.name %></span>
                  <% if membro.user.id == current_user.id %>
                    <span class="badge badge-primary badge-xs mt-1">Você</span>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-4 text-right">
                <div class="flex flex-col items-end w-16">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter">Palpites</span>
                  <span class="font-bold text-md text-slate-300"><%= membro.user.palpites.count %></span>
                </div>
                <div class="flex flex-col items-end w-20">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter text-warning">Pontuação</span>
                  <span class="text-2xl font-black text-warning"><%= membro.user.total_pontos || 0 %></span>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
        <div class="mt-2 text-right">
          <%= link_to "Ver ranking completo →", liga_path(@liga_principal), class: "text-sm font-bold text-primary hover:underline" %>
        </div>
      <% else %>
        <div class="bg-base-100 p-8 rounded-box shadow text-center border border-base-200 h-full flex flex-col justify-center items-center gap-4">
          <p class="opacity-70">Você ainda não está em nenhuma liga.</p>
          <%= link_to "Encontrar Ligas", ligas_path, class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>
    </div>

    <!-- Coluna 3: Ranking Global -->
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
        Ranking Global
      </h2>

      <% if current_user.plus? || current_user.premium? %>
        <ul class="list bg-base-100 shadow-xl rounded-box border border-base-200 w-full overflow-hidden">
          <% @ranking_global.each_with_index do |user, index| %>
            <li class="list-row p-4 border-b last:border-b-0 border-base-200 flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-8 text-center font-black text-xl <%= index < 3 ? 'text-secondary' : 'opacity-40' %>">
                  <%= index + 1 %>º
                </div>
                <div class="flex flex-col">
                  <span class="font-bold text-sm truncate max-w-[150px]"><%= user.name %></span>
                  <% if user.id == current_user.id %>
                    <span class="badge badge-secondary badge-xs mt-1">Você</span>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-4 text-right">
                <div class="flex flex-col items-end w-16">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter">Palpites</span>
                  <span class="font-bold text-md text-slate-300"><%= user.try(:total_palpites) || 0 %></span>
                </div>
                <div class="flex flex-col items-end w-20">
                  <span class="text-[8px] uppercase font-black opacity-30 tracking-tighter text-secondary">Pontuação</span>
                  <span class="text-2xl font-black text-secondary"><%= user.try(:total_pontos_ranking) || user.total_pontos || 0 %></span>
                </div>
              </div>
            </li>
          <% end %>

          <% if @user_global_rank > 5 %>
            <li class="p-2 flex justify-center opacity-30">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
            </li>
            <li class="list-row p-4 bg-secondary/5 border-t border-secondary/20 flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-8 text-center font-black text-xl text-secondary">
                  <%= @user_global_rank %>º
                </div>
                <div class="flex flex-col">
                  <span class="font-bold text-sm truncate max-w-[150px]"><%= current_user.name %></span>
                  <span class="badge badge-secondary badge-xs mt-1">Sua Posição</span>
                </div>
              </div>
              <div class="flex flex-col items-end">
                <span class="text-2xl font-black text-secondary"><%= current_user.total_pontos %></span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="relative group h-full">
          <div class="bg-base-100 p-8 rounded-box shadow border border-base-200 filter blur-sm select-none opacity-50 space-y-6 h-full">
            <div class="flex items-center justify-between py-2 border-b"><span>Usuário Exemplo 1</span><span>500</span></div>
            <div class="flex items-center justify-between py-2 border-b"><span>Usuário Exemplo 2</span><span>450</span></div>
            <div class="flex items-center justify-between py-2"><span>Usuário Exemplo 3</span><span>400</span></div>
          </div>
          <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-secondary mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            <p class="font-bold text-secondary uppercase tracking-widest mb-3">Ranking Global</p>
            <%= link_to "Liberar Agora", planos_path, class: "btn btn-secondary btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>

  </div>
</div>

<!-- Botão Flutuante de Doação (Aberto para todos os usuários) -->
<div class="fixed bottom-6 right-6 z-50 group">
  <!-- Popup: bottom-full garante que abre pra CIMA. pb-10 + -mb-10 cria a ponte invisível -->
  <div class="absolute bottom-full right-0 w-64 bg-base-100 p-4 rounded-2xl shadow-2xl border border-primary/20 opacity-0 group-hover:opacity-100 transition-all pointer-events-none group-hover:pointer-events-auto scale-90 group-hover:scale-100 transform origin-bottom-right duration-300 pb-10 -mb-6">
    <div class="flex flex-col gap-2">
      <h3 class="font-bold text-primary flex items-center gap-2">
        Apoie o OrangScore ❤️
      </h3>
      <p class="text-xs opacity-70 leading-relaxed">
        Sua doação ajuda a manter o servidor online e trazer novas funcionalidades para todos!
      </p>
      
      <%= form_with url: "#", method: :post, id: "donation-form", class: "mt-2 space-y-2", data: { turbo: false } do |f| %>
        <%= f.hidden_field :plano, value: "doacao" %>
        <%= f.hidden_field :payment_method, value: "pix", id: "donation-payment-method" %>
        <input type="hidden" name="cpf" id="donation-cpf">
        
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs font-bold opacity-50">R$</span>
          <%= f.text_field :valor, value: "5,00", id: "donation-amount", class: "input input-bordered input-sm w-full pl-8 font-bold text-primary focus:border-primary", placeholder: "0,00" %>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <!-- Botão Pix abre o modal -->
          <button type="button" 
                  onclick="modal_doacao_cpf.showModal()"
                  class="btn btn-primary btn-sm gap-1 px-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Doar Pix
          </button>
          
          <!-- Botão Cartão envia direto pro Stripe -->
          <button type="submit" 
                  formaction="<%= checkout_stripe_path %>"
                  onclick="document.getElementById('donation-payment-method').value='card'"
                  class="btn btn-secondary btn-sm gap-1 px-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
            Doar Cartão
          </button>
        </div>
      <% end %>
    </div>
  </div>
  <button class="btn btn-primary btn-circle btn-lg shadow-2xl hover:scale-110 transition-transform animate-pulse hover:animate-none">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
    </svg>
  </button>
</div>

<!-- Modal para CPF do Pix -->
<dialog id="modal_doacao_cpf" class="modal">
  <div class="modal-box border border-primary/20 bg-base-100">
    <h3 class="font-bold text-lg text-primary mb-2">Quase lá!</h3>
    <p class="text-sm opacity-70 mb-4">Para gerar o QR Code do Pix, o Banco Central exige um CPF válido associado ao pagamento.</p>
    
    <div class="form-control w-full mb-6">
      <label class="label">
        <span class="label-text font-bold">Qual o seu CPF?</span>
      </label>
      <input type="text" id="input_modal_cpf" placeholder="000.000.000-00" class="input input-bordered w-full" maxlength="14" />
    </div>

    <div class="flex justify-end gap-2">
      <form method="dialog">
        <button class="btn btn-ghost">Cancelar</button>
      </form>
      <button type="button" class="btn btn-primary" onclick="submeterDoacaoPix()">
        Gerar Pix Agora
      </button>
    </div>
  </div>
</dialog>
<script>
  // Adicionamos o parâmetro 'event' para capturar o botão clicado corretamente
  function submeterDoacaoPix(event) {
    const cpfInput = document.getElementById('input_modal_cpf');
    const amountInput = document.getElementById('donation-amount');
    
    // Captura o botão através do evento ou fallback
    const btnModal = event ? event.target : document.querySelector('#modal_doacao_cpf .btn-primary');

    const cpfValue = cpfInput.value.replace(/\D/g, '');
    
    // TRATAMENTO DO VALOR:
    // Remove pontos de milhar e troca a vírgula decimal por ponto.
    // parseFloat + toFixed(2) garante que o envio seja "0.50" e não "50"
    let amountRaw = amountInput.value.replace(/\./g, '').replace(',', '.');
    let amountValue = parseFloat(amountRaw).toFixed(2);

    if (cpfValue.length !== 11) {
      alert("Por favor, digite um CPF válido com 11 números.");
      return;
    }

    if (isNaN(amountValue) || amountValue <= 0) {
      alert("Por favor, insira um valor válido para doação.");
      return;
    }

    // Feedback visual e bloqueio de cliques duplos
    btnModal.disabled = true;
    const originalText = btnModal.innerText;
    btnModal.innerText = "Processando...";

    const formData = new FormData();
    formData.append('plano', 'doacao');
    formData.append('payment_method', 'pix');
    formData.append('cpf', cpfValue);
    formData.append('valor', amountValue); 
    formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

    fetch('<%= checkout_mercado_pago_pix_direto_path %>', {
      method: 'POST',
      body: formData,
      headers: {
        'Accept': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      }
    })
    .then(async response => {
      if (response.redirected) {
        window.location.href = response.url;
      } else {
        const data = await response.json();
        if (data.redirect_url) {
          window.location.href = data.redirect_url;
        } else if (data.error) {
          alert("Erro: " + data.error);
          btnModal.disabled = false;
          btnModal.innerText = originalText;
        }
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert("Houve um erro ao processar o Pix.");
      btnModal.disabled = false;
      btnModal.innerText = originalText;
    });
  }

  // Inicialização de máscaras e eventos após o carregamento do Turbo
  document.addEventListener('turbo:load', () => {
    const amountInput = document.getElementById('donation-amount');
    const cpfInput = document.getElementById('input_modal_cpf');
    
    // Máscara Monetária (Transforma 50 em 0,50 enquanto digita)
    if (amountInput) {
      amountInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\D/g, '');
        if (value === '') value = '0';
        value = (parseInt(value) / 100).toFixed(2) + '';
        value = value.replace(".", ",");
        value = value.replace(/(\d)(?=(\d{3})+(?!\d))/g, "$1.");
        e.target.value = value;
      });
    }

    // Máscara de CPF (000.000.000-00)
    if (cpfInput) {
      cpfInput.addEventListener('input', (e) => {
        let value = e.target.value.replace(/\D/g, '');
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d)/, '$1.$2');
        value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
        e.target.value = value;
      });
    }
  });
</script>
