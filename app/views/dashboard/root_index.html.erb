<div class="space-y-8 max-w-7xl mx-auto py-8">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <h1 class="text-4xl font-bold">Olá, <%= current_user.name %></h1>
        <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-linear-to-b from-purple-500 via-purple-700 to-purple-900 text-white border border-purple-300">
          <span class="text-xs font-black tracking-wide">ADMINISTRADOR</span>
        </div>
      </div>
      <p class="opacity-70 text-lg">Visão geral do sistema OrangScore</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Total de Usuários</h2>
        <p class="text-6xl font-black text-primary"><%= @total_usuarios %></p>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Total de Palpites</h2>
        <p class="text-6xl font-black text-primary"><%= @total_palpites %></p>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Total de Jogos</h2>
        <p class="text-6xl font-black text-accent"><%= @total_jogos %></p>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body items-center text-center justify-center">
        <h2 class="card-title text-sm opacity-70 uppercase tracking-wider">Ligas Criadas</h2>
        <p class="text-6xl font-black text-info"><%= @total_ligas %></p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        Últimos Usuários Registrados
      </h2>
      <div class="bg-base-100 shadow-xl rounded-box border border-base-200">
        <ul class="list">
          <% @ultimos_usuarios.each do |user| %>
            <li class="p-4 border-b last:border-b-0 border-base-200 flex justify-between items-center">
              <div>
                <p class="font-bold"><%= user.name %></p>
                <p class="text-xs opacity-60"><%= user.email %></p>
              </div>
              <div class="text-xs opacity-50">
                <%= user.created_at.strftime("%d/%m/%Y %H:%M") %>
              </div>
            </li>
          <% end %>
        </ul>
        <div class="p-4 bg-base-200/30 text-center border-t border-base-200">
          <%= link_to "Gerenciar Usuários", users_path, class: "text-sm font-bold text-primary hover:underline" %>
        </div>
      </div>
    </div>
    
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        Ações Rápidas
      </h2>
      <div class="grid grid-cols-2 gap-4">
        <%= link_to users_path, class: "btn btn-outline btn-primary h-24 flex flex-col gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
          Usuários
        <% end %>
        <%= link_to pagamentos_path, class: "btn btn-outline btn-secondary h-24 flex flex-col gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Pagamentos
        <% end %>
        <%= link_to jogos_path, class: "btn btn-outline btn-accent h-24 flex flex-col gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Jogos
        <% end %>
        <%= link_to ligas_path, class: "btn btn-outline btn-info h-24 flex flex-col gap-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          Ligas
        <% end %>
      </div>
    </div>
  </div>
</div>

<% if @jogos_em_andamento.any? %>
  <div class="bg-base-100 shadow-xl rounded-box border border-base-200 p-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4">
      <div>
        <h2 class="text-2xl font-bold">Jogos em andamento</h2>
        <p class="opacity-70">Atualize o placar oficial rapidamente para partidas que já começaram.</p>
      </div>
      <span class="badge badge-secondary text-sm font-bold"><%= @jogos_em_andamento.size %> partidas ativas</span>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full text-left">
        <thead>
          <tr>
            <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Jogo</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Horário</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Placar</th>
            <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Ação</th>
          </tr>
        </thead>
        <tbody>
          <% @jogos_em_andamento.each do |jogo| %>
            <tr class="border-t border-base-200 hover:bg-base-200/50 transition">
              <td class="px-4 py-4">
                <div class="font-bold"><%= jogo.mandante&.nome || jogo.nome_provisorio_mandante || 'Mandante' %> x <%= jogo.visitante&.nome || jogo.nome_provisorio_visitante || 'Visitante' %></div>
                <div class="text-xs opacity-60"><%= jogo.grupo&.nome || jogo.tipo.humanize %></div>
              </td>
              <td class="px-4 py-4 text-sm text-slate-600"><%= jogo.data.strftime('%d/%m %H:%M') %></td>
              <td class="px-4 py-4">
                <div class="flex items-center gap-2">
                  <span class="font-bold text-lg"><%= jogo.gols_mandante || 0 %></span>
                  <span class="text-slate-400">-</span>
                  <span class="font-bold text-lg"><%= jogo.gols_visitante || 0 %></span>
                </div>
              </td>
              <td class="px-4 py-4">
                <%= form_with model: jogo, url: jogo_path(jogo), method: :patch, local: true, class: 'flex flex-col gap-2' do |f| %>
                  <div class="grid grid-cols-2 gap-2">
                    <%= f.number_field :gols_mandante, min: 0, class: 'input input-bordered input-sm w-full', placeholder: 'Gols M' %>
                    <%= f.number_field :gols_visitante, min: 0, class: 'input input-bordered input-sm w-full', placeholder: 'Gols V' %>
                  </div>
                  <div class="flex items-center gap-2">
                    <%= f.hidden_field :status, value: jogo.status %>
                    <%= f.submit 'Atualizar placar', class: 'btn btn-sm btn-primary w-full' %>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="bg-base-100 shadow-xl rounded-box border border-base-200 p-6 text-center">
    <p class="font-bold">Não há jogos em andamento no momento.</p>
    <p class="opacity-70">Quando um jogo começar, ele vai aparecer aqui para atualização rápida.</p>
  </div>
<% end %>
