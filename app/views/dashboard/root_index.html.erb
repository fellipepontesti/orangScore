            data: { turbo: false, confirm: "Deseja mesmo realocar os placares salvos para os jogos de 28 de Junho para frente?" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-info">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.656 48.656 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M7.5 12l-3 3m3-3 3 3" />
          </svg>
          <span>Realocar Placares (28/Jun+)</span>
        <% end %>

        <button onclick="modal_placares_salvos.showModal()"
                type="button"
                class="btn bg-base-100 hover:bg-base-200 border border-base-200 h-24 flex flex-col gap-2 w-full justify-center items-center text-center text-success shadow-xl">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-success">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
          <span>Ver Placares Salvos</span>
        </button>
      </div>
    </div>
  </div>

  <dialog id="modal_usuarios_online" class="modal">
    <div class="modal-box max-w-md bg-base-100 border border-base-300 shadow-2xl p-6 rounded-3xl">
      <div class="flex justify-between items-start mb-6">
        <div>
          <h3 class="font-black text-2xl text-white flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-emerald-500 animate-pulse"></span>
            Usuários Online Agora
          </h3>
          <p class="text-xs opacity-60 mt-1">Usuários ativos nos últimos 5 minutos</p>
        </div>
        <button class="btn btn-sm btn-circle btn-ghost text-lg" onclick="modal_usuarios_online.close()">✕</button>
      </div>

      <div class="max-h-96 overflow-y-auto pr-1">
        <% if @usuarios_online.any? %>
          <ul class="divide-y divide-base-200">
            <% @usuarios_online.each do |user| %>
              <li class="py-3 flex items-center justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    <span class="font-bold text-sm text-white truncate"><%= user.name %></span>
                    <%= conta_status_badge(user) %>
                  </div>
                  <p class="text-xs opacity-50 truncate mt-0.5"><%= user.email %></p>
                </div>
                <div class="text-right shrink-0">
                  <span class="text-[10px] font-black text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-full uppercase tracking-wider">
                    Ativo <%= time_ago_in_words(user.last_seen_at) %> atrás
                  </span>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="text-center py-8 opacity-55">
            <span class="text-3xl block mb-2">😴</span>
            <p class="text-sm font-semibold">Nenhum usuário online no momento.</p>
          </div>
        <% end %>
      </div>

      <div class="modal-action mt-6">
        <button class="btn btn-primary w-full rounded-2xl font-bold" onclick="modal_usuarios_online.close()">Fechar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  <dialog id="modal_placares_salvos" class="modal">
    <div class="modal-box max-w-2xl bg-base-100 border border-base-300 shadow-2xl p-6 rounded-3xl">
      <div class="flex justify-between items-start mb-6">
        <div>
          <h3 class="font-black text-2xl text-white flex items-center gap-2">
            💾 Placares e Palpites Salvos (28/Jun+)
          </h3>
          <p class="text-xs opacity-60 mt-1">Confrontos, gols oficiais e palpites congelados do dia 28 de Junho em diante</p>
        </div>
        <button class="btn btn-sm btn-circle btn-ghost text-lg" onclick="modal_placares_salvos.close()">✕</button>
      </div>

      <div class="max-h-[60vh] overflow-y-auto pr-1">
        <% if @jogos_salvos.present? && @jogos_salvos.any? %>
          <div class="space-y-6">
            <% @jogos_salvos.each do |j| %>
              <% 
                mandante_nome = if j["definir"] == false && j["mandante_id"].present?
                  @selecoes_map[j["mandante_id"]]&.nome || "ID #{j["mandante_id"]}"
                else
                  j["nome_provisorio_mandante"] || "A definir"
                end

                visitante_nome = if j["definir"] == false && j["visitante_id"].present?
                  @selecoes_map[j["visitante_id"]]&.nome || "ID #{j["visitante_id"]}"
                else
                  j["nome_provisorio_visitante"] || "A definir"
                end
              %>
              <div class="bg-base-200/50 rounded-2xl p-4 border border-base-200">
                <div class="flex items-center justify-between gap-4 border-b border-base-300 pb-2 mb-3">
                  <div class="font-bold text-white flex items-center gap-1.5">
                    <span><%= mandante_nome %></span>
                    <span class="text-primary font-black"><%= j["gols_mandante"] %></span>
                    <span class="text-xs opacity-40">x</span>
                    <span class="text-primary font-black"><%= j["gols_visitante"] %></span>
                    <span><%= visitante_nome %></span>
                  </div>
                  <span class="badge badge-sm uppercase font-extrabold p-1.5 <%= j['status'] == 'finalizado' ? 'badge-success' : 'badge-neutral' %>">
                    <%= j['status'] %>
                  </span>
                </div>

                <div>
                  <h4 class="text-xs font-black uppercase text-warning mb-2">Palpites dos Usuários (<%= (j["palpites"] || []).size %>)</h4>
                  <% if (j["palpites"] || []).any? %>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs">
                      <% j["palpites"].each do |p| %>
                        <% user_nome = @users_map[p["user_id"]]&.name || "Usuário ID #{p["user_id"]}" %>
                        <div class="flex justify-between items-center bg-base-300/40 px-3 py-1.5 rounded-lg border border-base-300/50">
                          <span class="opacity-70 truncate max-w-[120px]" title="<%= user_nome %>"><%= user_nome %></span>
                          <span class="font-bold text-white"><%= p["gols_casa"] %> x <%= p["gols_fora"] %></span>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="text-xs opacity-50 italic">Nenhum palpite registrado para este jogo.</p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 opacity-55">
            <span class="text-3xl block mb-2">📂</span>
            <p class="text-sm font-semibold">Nenhum palpite ou placar do dia 28 de Junho em diante foi salvo até o momento.</p>
          </div>
        <% end %>
      </div>

      <div class="modal-action mt-6">
        <button class="btn btn-primary w-full rounded-2xl font-bold" onclick="modal_placares_salvos.close()">Fechar</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</div>
