<div class="space-y-8 max-w-5xl mx-auto py-8 px-4">
  
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6">
    <div class="space-y-1">
      <div class="flex items-center gap-2 text-sm text-primary font-mono font-bold uppercase tracking-wider">
        <%= link_to "Dashboard", authenticated_root_path, class: "hover:underline" %>
        <span>/</span>
        <span>Numeração de Jogadores</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent">
        Numeração dos Jogadores
      </h1>
      <p class="text-slate-400 text-sm sm:text-base">
        Lista de seleções com jogadores sem número de camisa definido.
      </p>
    </div>
    
    <%= link_to authenticated_root_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar ao Painel
    <% end %>
  </div>

  <% if @selecoes.any? %>
    <div class="alert alert-warning shadow-lg border border-warning/20 bg-warning/5 rounded-3xl p-5 flex items-start gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-warning shrink-0 w-6 h-6 mt-0.5" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <div class="space-y-1">
        <h3 class="font-bold text-warning text-sm sm:text-base">Atenção, Administrador!</h3>
        <p class="text-xs sm:text-sm text-slate-300">
          Encontramos <strong><%= @selecoes.size %></strong> seleções com jogadores sem número de camisa. Preencher a numeração é essencial para que os usuários possam identificar os jogadores corretamente na artilharia e no fluxo de palpites.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
      <% @selecoes.each do |selecao| %>
        <% pendentes = selecao.jogadores.where(numero: nil).count %>
        <div class="card bg-base-100 border border-base-200 shadow-md hover:shadow-xl hover:border-amber-500/20 transition-all duration-300 rounded-3xl overflow-hidden flex flex-row items-center p-6 gap-5">
          
          <div class="avatar shrink-0">
            <div class="mask mask-squircle h-16 w-16 bg-base-200 p-2 shadow-inner flex items-center justify-center overflow-hidden">
              <% if selecao.logo.present? %>
                <%= image_tag "selecoes/#{selecao.logo}", class: "object-cover w-full h-full" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center font-black text-lg">?</div>
              <% end %>
            </div>
          </div>

          <div class="flex-1 min-w-0 space-y-1.5">
            <div class="flex items-center gap-2 flex-wrap">
              <h2 class="text-xl font-bold text-white truncate"><%= selecao.nome %></h2>
              <span class="badge badge-sm badge-ghost opacity-60">Grupo <%= selecao.grupo&.nome&.last || "—" %></span>
            </div>
            <div class="flex items-center gap-1.5 text-xs text-error font-semibold">
              <span class="inline-block w-2 h-2 rounded-full bg-error animate-pulse"></span>
              <%= pendentes %> <%= pendentes == 1 ? "jogador sem número" : "jogadores sem número" %>
            </div>
          </div>

          <div class="shrink-0">
            <%= link_to dashboard_editar_numeracao_jogadores_path(selecao), class: "btn btn-primary btn-sm rounded-xl font-bold gap-1 shadow-md shadow-primary/10" do %>
              Editar ➔
            <% end %>
          </div>

        </div>
      <% end %>
    </div>

  <% else %>
    <div class="card bg-base-100 border border-base-200 shadow-xl rounded-3xl p-12 text-center flex flex-col items-center justify-center space-y-4 max-w-lg mx-auto mt-12">
      <div class="w-20 h-20 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 rounded-full flex items-center justify-center shadow-lg shadow-emerald-500/5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-10 h-10">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.746 3.746 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
        </svg>
      </div>
      
      <h2 class="text-2xl font-black text-white">Tudo Atualizado!</h2>
      <p class="text-xs sm:text-sm text-slate-400 leading-relaxed max-w-sm">
        Excelente! Todas as seleções e jogadores cadastrados no sistema estão com sua numeração oficial completa.
      </p>
      
      <%= link_to "Voltar ao Painel", authenticated_root_path, class: "btn btn-primary rounded-xl font-bold px-6 shadow-lg shadow-primary/20" %>
    </div>
  <% end %>

</div>
