<% content_for :title, "Criar Novo Operador" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6 mb-8">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <span>Painel Root</span>
        <span>/</span>
        <span>Criar Operador</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Novo Operador (Semi-Root)
      </h1>
      <p class="text-base-content/60 text-sm sm:text-base">Cadastre um novo operador com acesso restrito para controle de partidas.</p>
    </div>

    <%= link_to authenticated_root_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <div class="bg-base-100 shadow-2xl rounded-3xl border border-base-200 p-8 sm:p-10 relative overflow-hidden">

    <div class="mb-6 bg-info/10 text-info border border-info/20 p-4 rounded-2xl text-sm flex gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 1 1 1.084-1.083l.083.083a.75.75 0 0 1 0 1.062l-2.25 2.25a.75.75 0 0 1-1.062 0l-1.125-1.125a.75.75 0 1 1 1.062-1.062l.594.594 1.418-1.418ZM12 18.75a6.75 6.75 0 1 0 0-13.5 6.75 6.75 0 0 0 0 13.5Z" />
      </svg>
      <div>
        <span class="font-bold block mb-0.5">Informação Importante:</span>
        O novo operador será cadastrado como **confirmado e ativo para uso imediato**. A senha temporária do usuário será gerada aleatoriamente de forma segura e mostrada na tela após a criação.
      </div>
    </div>

    <%= form_with model: @usuario, url: dashboard_create_user_path, method: :post, local: true, class: "space-y-6" do |f| %>
      <div class="form-control w-full">
        <label class="label pl-1">
          <span class="label-text font-bold text-slate-300">Nome Completo</span>
        </label>
        <%= f.text_field :name,
          class: "input input-bordered w-full bg-base-200 text-white rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition duration-150",
          placeholder: "Digite o nome completo do operador",
          required: true %>
      </div>

      <div class="form-control w-full">
        <label class="label pl-1">
          <span class="label-text font-bold text-slate-300">E-mail</span>
        </label>
        <%= f.email_field :email,
          class: "input input-bordered w-full bg-base-200 text-white rounded-2xl focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition duration-150",
          placeholder: "exemplo@orangscore.com",
          required: true %>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-base-200/50">
        <%= f.submit "Cadastrar Operador", class: "btn btn-primary font-bold rounded-2xl flex-1 py-3" %>
        
        <%= link_to "Cancelar", authenticated_root_path, class: "btn btn-ghost border border-base-200 text-slate-300 font-semibold rounded-2xl flex-1" %>
      </div>
    <% end %>
  </div>
</div>
