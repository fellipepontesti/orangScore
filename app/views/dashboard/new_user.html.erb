<% content_for :title, "Criar Novo Operador" %>

<div class="max-w-2xl mx-auto py-12 px-4">
  <div class="flex flex-col gap-1 mb-8 text-center sm:text-left">
    <h1 class="text-4xl font-extrabold text-white tracking-tight">Criar Novo Operador (Semi-Root)</h1>
    <p class="text-base-content/70">Cadastre um novo operador com acesso restrito para controle de partidas.</p>
  </div>

  <div class="bg-base-100 shadow-2xl rounded-3xl border border-base-200 p-8 sm:p-10 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1.5 bg-linear-to-r from-purple-500 to-indigo-600"></div>

    <div class="mb-6 bg-info/10 text-info border border-info/20 p-4 rounded-2xl text-sm flex gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 1 1 1.084-1.083l.083.083a.75.75 0 0 1 0 1.062l-2.25 2.25a.75.75 0 0 1-1.062 0l-1.125-1.125a.75.75 0 1 1 1.062-1.062l.594.594 1.418-1.418ZM12 18.75a6.75 6.75 0 1 0 0-13.5 6.75 6.75 0 0 0 0 13.5Z" />
      </svg>
      <div>
        <span class="font-bold block mb-0.5">Informação Importante:</span>
        O novo operador será cadastrado como **confirmado e ativo para uso imediato**. A senha temporária do usuário será gerada aleatoriamente de forma segura e mostrada na tela após a criação.
      </div>
    </div>

    <%= form_with model: @usuario, url: dashboard_create_user_path, method: :post, local: true, class: "space-y-6" do |f| %>
      <div class="form-control w-full">
        <label class="label pl-1">
          <span class="label-text font-bold text-slate-300">Nome Completo</span>
        </label>
        <%= f.text_field :name,
          class: "input input-bordered w-full bg-base-200 text-white rounded-xl focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition duration-150",
          placeholder: "Digite o nome completo do operador",
          required: true %>
      </div>

      <div class="form-control w-full">
        <label class="label pl-1">
          <span class="label-text font-bold text-slate-300">E-mail</span>
        </label>
        <%= f.email_field :email,
          class: "input input-bordered w-full bg-base-200 text-white rounded-xl focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition duration-150",
          placeholder: "exemplo@orangscore.com",
          required: true %>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-base-200/50">
        <%= f.submit "Cadastrar Operador", class: "btn btn-primary font-bold rounded-xl flex-1 py-3" %>
        
        <%= link_to "Cancelar", authenticated_root_path, class: "btn btn-ghost border border-base-200 text-slate-300 font-semibold rounded-xl flex-1" %>
      </div>
    <% end %>
  </div>
</div>
