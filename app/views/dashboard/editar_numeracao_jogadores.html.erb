<div class="space-y-8 max-w-5xl mx-auto py-8 px-4">
  
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-base-200 pb-6">
    <div class="flex items-center gap-4">
      <div class="avatar shrink-0">
        <div class="mask mask-squircle h-16 w-16 bg-base-200 p-2 shadow-inner flex items-center justify-center overflow-hidden">
          <% if @selecao.logo.present? %>
            <%= image_tag "selecoes/#{@selecao.logo}", class: "object-cover w-full h-full" %>
          <% else %>
            <div class="w-full h-full flex items-center justify-center font-black text-lg">?</div>
          <% end %>
        </div>
      </div>
      <div class="space-y-1">
        <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
          <%= link_to "Seleções Pendentes", dashboard_editar_numeracao_selecoes_path, class: "hover:underline" %>
          <span>/</span>
          <span>Editar Numeração</span>
        </div>
        <h1 class="text-2xl sm:text-3xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent flex items-center gap-2 flex-wrap pb-1">
          Numeração: <%= @selecao.nome %>
          <span class="badge badge-warning font-black text-xs uppercase py-2.5 text-black">Grupo <%= @selecao.grupo&.nome&.last || "—" %></span>
        </h1>
      </div>
    </div>
    
    <%= link_to dashboard_editar_numeracao_selecoes_path, class: "btn btn-ghost btn-sm sm:btn-md gap-2 rounded-2xl" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
      </svg>
      Voltar
    <% end %>
  </div>

  <div class="alert alert-info shadow-sm border border-info/20 bg-info/5 rounded-3xl p-5 flex items-start gap-4">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-info shrink-0 w-6 h-6 mt-0.5" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.028M12 7.5h.008v.008H12V7.5z" />
    </svg>
    <div class="space-y-0.5">
      <h3 class="font-bold text-info text-sm sm:text-base">Dica de Preenchimento</h3>
      <p class="text-xs sm:text-sm text-slate-300">
        Os jogadores **sem número** foram organizados no topo da lista e possuem um aviso para facilitar a sua localização.
      </p>
    </div>
  </div>

  <%= form_with url: dashboard_salvar_numeracao_jogadores_path(@selecao), method: :patch, local: true, class: "space-y-6" do %>
    
    <div class="card bg-base-100 border border-base-200 shadow-xl rounded-3xl overflow-hidden">
      <div class="overflow-x-auto w-full">
        <table class="table table-md w-full">
          <thead>
            <tr class="bg-base-200/30 text-xs opacity-60 uppercase font-black">
              <th class="w-24 text-center">Nº da Camisa</th>
              <th>Jogador</th>
              <th>Posição</th>
              <th class="hidden md:table-cell">Clube</th>
              <th class="text-center w-24">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @jogadores.each do |jogador| %>
              <% sem_numero = jogador.numero.blank? %>
              <tr class="hover:bg-base-200/30 transition-colors border-b border-base-200/60 <%= 'bg-warning/5' if sem_numero %>">
                
                <td class="p-3 text-center">
                  <div class="flex justify-center">
                    <input type="number" 
                           name="jogadores[<%= jogador.id %>][numero]" 
                           value="<%= jogador.numero %>" 
                           placeholder="—" 
                           min="1" 
                           max="99" 
                           class="input input-bordered input-sm w-20 text-center font-bold font-mono focus:input-primary rounded-xl <%= 'border-warning focus:border-warning' if sem_numero %>" />
                  </div>
                </td>
                
                <td class="font-bold text-slate-100 min-w-[150px]">
                  <div class="flex items-center gap-1.5">
                    <span><%= jogador.nome %></span>
                    <% if jogador.capitao? %>
                      <span class="badge badge-warning badge-xs font-black text-[8px] text-white" title="Capitão">C</span>
                    <% end %>
                  </div>
                </td>

                <td class="text-xs font-semibold text-slate-400">
                  <%= jogador.posicao_pt %>
                </td>

                <td class="text-xs text-slate-400 max-w-[200px] truncate hidden md:table-cell">
                  <%= jogador.clube %>
                  <% if jogador.clube_pais.present? %>
                    <span class="opacity-50 text-[10px] ml-1">(<%= jogador.clube_pais %>)</span>
                  <% end %>
                </td>

                <td class="text-center p-3">
                  <% if sem_numero %>
                    <span class="badge badge-warning font-black text-[10px] uppercase py-2.5 px-3 whitespace-nowrap shadow-sm shadow-warning/5">
                      Sem Número
                    </span>
                  <% else %>
                    <span class="badge badge-success font-black text-[10px] uppercase py-2.5 px-3 whitespace-nowrap shadow-sm shadow-success/5">
                      Definido
                    </span>
                  <% end %>
                </td>

              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-end gap-3 pt-4">
      <%= link_to "Cancelar", dashboard_editar_numeracao_selecoes_path, class: "btn btn-ghost rounded-2xl w-full sm:w-auto font-bold" %>
      <button type="submit" class="btn btn-primary rounded-2xl w-full sm:w-auto px-8 font-black gap-2 shadow-lg shadow-primary/20 hover:scale-105 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        Salvar Numeração
      </button>
    </div>

  <% end %>

</div>
