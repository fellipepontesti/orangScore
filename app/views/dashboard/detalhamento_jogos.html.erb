<% content_for :title, "Detalhamento dos Jogos" %>

<div class="space-y-8 max-w-7xl mx-auto py-8 px-4">
  <!-- Cabeçalho / Breadcrumbs -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-base-200 pb-6">
    <div class="flex flex-col gap-1 min-w-0">
      <div class="flex items-center gap-2 text-sm text-orange-500 font-mono font-bold uppercase tracking-wider">
        <%= link_to "Painel Root", authenticated_root_path, class: "hover:underline" %>
        <span>/</span>
        <span>Detalhamento dos Jogos</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight bg-gradient-to-r from-amber-400 to-orange-500 bg-clip-text text-transparent pb-1">
        Detalhamento e Integridade dos Jogos
      </h1>
      <p class="opacity-70 text-sm sm:text-base">Monitore a consistência dos placares, estatísticas e atribuições de gols da artilharia.</p>
    </div>
    
    <div>
      <%= link_to authenticated_root_path, class: "btn btn-outline btn-sm font-bold gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Voltar ao Painel
      <% end %>
    </div>
  </div>

  <!-- Cards de Resumo Geral -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Card 1: Total Analisado -->
    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body p-6 flex flex-row items-center gap-4 justify-between">
        <div>
          <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Total Analisado</h3>
          <p class="text-4xl font-black mt-2 text-slate-100"><%= @total_jogos_validos %></p>
          <p class="text-[10px] opacity-60 mt-1 font-semibold">Jogos finalizados/em andamento</p>
        </div>
        <div class="p-3.5 rounded-2xl bg-base-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-3-12v.75m0 3v.75m0 3v.75m0 3V18m-3-12v.75m0 3v.75m0 3v.75m0 3V18m-3-12v.75m0 3v.75m0 3v.75m0 3V18" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Card 2: Sincronização -->
    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body p-6 flex flex-row items-center gap-4 justify-between">
        <div>
          <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Estatísticas API</h3>
          <p class="text-4xl font-black mt-2 text-success">
            <%= @total_sincronizados %> / <%= @total_jogos_validos %>
          </p>
          <div class="flex items-center gap-1.5 mt-1.5">
            <% if @total_sincronizados == @total_jogos_validos %>
              <span class="badge badge-success badge-xs"></span>
              <span class="text-[10px] text-success font-bold">100% Sincronizado</span>
            <% else %>
              <span class="badge badge-warning badge-xs"></span>
              <span class="text-[10px] text-warning font-bold"><%= @total_jogos_validos - @total_sincronizados %> Pendentes</span>
            <% end %>
          </div>
        </div>
        <div class="p-3.5 rounded-2xl bg-base-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-success">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Card 3: Conformidade de Placar -->
    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body p-6 flex flex-row items-center gap-4 justify-between">
        <div>
          <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Placares Corretos</h3>
          <p class="text-4xl font-black mt-2 <%= @total_placar_correto == @total_sincronizados ? 'text-success' : 'text-error' %>">
            <%= @total_placar_correto %> / <%= @total_sincronizados %>
          </p>
          <div class="flex items-center gap-1.5 mt-1.5">
            <% if @total_placar_correto == @total_sincronizados %>
              <span class="badge badge-success badge-xs"></span>
              <span class="text-[10px] text-success font-bold">Placares Batem 100%</span>
            <% else %>
              <span class="badge badge-error badge-xs animate-pulse"></span>
              <span class="text-[10px] text-error font-bold"><%= @total_sincronizados - @total_placar_correto %> Divergentes</span>
            <% end %>
          </div>
        </div>
        <div class="p-3.5 rounded-2xl bg-base-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-warning">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Card 4: Artilharia Integridade -->
    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body p-6 flex flex-row items-center gap-4 justify-between">
        <div>
          <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400">Artilharia Geral</h3>
          <p class="text-4xl font-black mt-2 <%= @total_gols_artilharia_banco == @total_gols_artilharia_calculado ? 'text-success' : 'text-warning' %>">
            <%= @total_gols_artilharia_banco %> Gols
          </p>
          <p class="text-[10px] opacity-60 mt-1 font-semibold">
            API calculou: <strong><%= @total_gols_artilharia_calculado %></strong>
            <% if @total_gols_artilharia_banco != @total_gols_artilharia_calculado %>
              <span class="text-warning font-bold">(Discrepância de <%= (@total_gols_artilharia_banco - @total_gols_artilharia_calculado).abs %>)</span>
            <% else %>
              <span class="text-success font-bold">(OK)</span>
            <% end %>
          </p>
        </div>
        <div class="p-3.5 rounded-2xl bg-base-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-amber-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.504-1.125-1.125-1.125h-2.25a1.125 1.125 0 0 0-1.125 1.125V18.75m9 0h-9M12 2.25a3 3 0 0 0-3 3v1.5a3 3 0 0 0 6 0v-1.5a3 3 0 0 0-3-3Z" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Quadro Informativo de Own Goals -->
  <div class="alert bg-base-200/50 border border-base-300 rounded-3xl p-6 flex items-start gap-4">
    <div class="p-2 bg-emerald-500/10 text-emerald-500 rounded-2xl shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 11.518 1.399l-.301-.15a.75.75 0 00-.758.06A.75.75 0 0110.5 12V7.5a.75.75 0 01.75-.75h2.25a.75.75 0 010 1.5H12v.75m-6 3a9 9 0 1118 0 9 9 0 01-18 0z" />
      </svg>
    </div>
    <div class="space-y-1">
      <h4 class="font-extrabold text-sm text-slate-100 uppercase tracking-wide">Regra de Diagnóstico da Artilharia</h4>
      <p class="text-xs opacity-75 leading-relaxed">
        Gols contra (own goals) <strong>não são creditados</strong> a nenhum jogador na artilharia local, mas somam no placar do jogo. 
        A coluna "Artilharia OK?" valida se todos os gols normais (não contra) do JSON da API foram associados corretamente a jogadores no banco de dados e se as estatísticas acumuladas do jogador conferem com o banco.
      </p>
    </div>
  </div>

  <!-- Filtros -->
  <div class="card bg-base-100 border border-base-200 shadow-lg rounded-3xl p-6">
    <%= form_with url: dashboard_detalhamento_jogos_path, method: :get, local: true, class: "flex flex-col md:flex-row items-end gap-4" do |f| %>
      <div class="form-control w-full md:w-64">
        <label class="label pb-1.5">
          <span class="label-text text-xs font-bold text-slate-400 uppercase tracking-wide">Status do Jogo</span>
        </label>
        <%= f.select :status, 
                     options_for_select([
                       ["Todos os Status", ""],
                       ["Programado", "programado"],
                       ["Em Andamento", "em_andamento"],
                       ["Finalizado", "finalizado"]
                     ], params[:status]), 
                     {}, 
                     class: "select select-bordered select-sm w-full bg-base-200 text-sm font-semibold rounded-xl focus:outline-hidden" %>
      </div>

      <div class="form-control w-full md:w-auto flex items-center md:pb-2.5">
        <label class="label cursor-pointer justify-start gap-3 select-none">
          <%= f.check_box :com_diferenca, 
                          { checked: params[:com_diferenca] == "true", class: "checkbox checkbox-primary checkbox-sm rounded-md" }, 
                          "true", "false" %>
          <span class="label-text text-sm font-bold text-slate-300">Apenas com Divergências de Dados</span>
        </label>
      </div>

      <div class="flex gap-2 w-full md:w-auto md:ml-auto">
        <%= f.submit "Filtrar", class: "btn btn-primary btn-sm px-6 font-bold rounded-xl shadow-md shadow-primary/20" %>
        <% if params[:status].present? || params[:com_diferenca] == "true" %>
          <%= link_to "Limpar", dashboard_detalhamento_jogos_path, class: "btn btn-ghost btn-sm px-4 font-bold rounded-xl" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Tabela de Jogos -->
  <div class="bg-base-100 rounded-3xl border border-base-200 shadow-xl overflow-hidden">
    <div class="p-6 border-b border-base-200 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 bg-base-200/20">
      <div>
        <h2 class="text-lg font-black text-white">Listagem de Jogos</h2>
        <p class="text-xs opacity-60 mt-0.5">Clique em qualquer linha para abrir a tela do jogo e realizar ações como sincronizar ou atualizar.</p>
      </div>
      
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-1.5 text-xs font-bold text-slate-400">
          <span class="w-2.5 h-2.5 rounded-full bg-error shrink-0"></span> Inconsistência Detectada
        </div>
        <div class="flex items-center gap-1.5 text-xs font-bold text-slate-400">
          <span class="w-2.5 h-2.5 rounded-full bg-success shrink-0"></span> Dados Consistentes
        </div>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="table w-full border-collapse">
        <thead>
          <tr class="bg-base-200/50 text-slate-400 border-b border-base-200 text-xs font-bold uppercase tracking-wider">
            <th class="py-4 pl-6 text-left">Jogo</th>
            <th class="py-4 text-left">Fase/Data</th>
            <th class="py-4 text-center">Placar Local</th>
            <th class="py-4 text-center">Placar API</th>
            <th class="py-4 text-center">Sincronizado</th>
            <th class="py-4 text-center">Placar Bate</th>
            <th class="py-4 text-center">Artilharia Bate</th>
            <th class="py-4 pr-6 text-center">Diagnóstico</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-base-200">
          <% @jogos.each do |jogo| %>
            <% diag = @diagnostico_jogos[jogo.id] || {} %>
            <% tem_inconsistencia = !diag[:sincronizado] || !diag[:placar_bate] || !diag[:artilharia_ok] %>
            
            <tr class="hover:bg-base-200/30 transition duration-150 cursor-pointer" onclick="window.location.href='<%= jogo_path(jogo) %>'">
              
              <!-- Jogo -->
              <td class="py-4 pl-6">
                <div class="flex items-center gap-3">
                  <div class="flex items-center gap-1">
                    <!-- Mandante -->
                    <div class="mask mask-squircle h-8 w-8 bg-base-200 flex items-center justify-center overflow-hidden shrink-0 shadow-inner">
                      <% if jogo.mandante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.mandante.logo}", class: "object-cover w-full h-full" %>
                      <% else %>
                        <span class="text-[10px] font-bold">?</span>
                      <% end %>
                    </div>
                    <span class="font-extrabold text-sm text-white ml-1">
                      <%= jogo.mandante&.nome || jogo.nome_provisorio_mandante || "Mandante" %>
                    </span>
                  </div>
                  
                  <span class="text-xs opacity-40 font-black">x</span>
                  
                  <div class="flex items-center gap-1">
                    <span class="font-extrabold text-sm text-white mr-1">
                      <%= jogo.visitante&.nome || jogo.nome_provisorio_visitante || "Visitante" %>
                    </span>
                    <!-- Visitante -->
                    <div class="mask mask-squircle h-8 w-8 bg-base-200 flex items-center justify-center overflow-hidden shrink-0 shadow-inner">
                      <% if jogo.visitante&.logo.present? %>
                        <%= image_tag "selecoes/#{jogo.visitante.logo}", class: "object-cover w-full h-full" %>
                      <% else %>
                        <span class="text-[10px] font-bold">?</span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </td>
              
              <!-- Fase/Data -->
              <td class="py-4">
                <div class="text-xs font-semibold">
                  <p class="text-primary uppercase tracking-wider text-[10px]">
                    <%= jogo.grupo&.nome || jogo.tipo.humanize %>
                  </p>
                  <p class="opacity-50 mt-0.5"><%= jogo.data.present? ? jogo.data.strftime('%d/%m/%Y %H:%M') : 'Sem data' %></p>
                </div>
              </td>
              
              <!-- Placar Local -->
              <td class="py-4 text-center">
                <% if jogo.programado? || jogo.times_a_definir? %>
                  <span class="badge badge-ghost font-mono opacity-50">VS</span>
                <% else %>
                  <span class="font-mono font-black text-sm px-2 py-1 bg-base-200 rounded-lg">
                    <%= jogo.gols_mandante %> - <%= jogo.gols_visitante %>
                  </span>
                <% end %>
              </td>
              
              <!-- Placar API -->
              <td class="py-4 text-center">
                <% if diag[:placar_api].present? %>
                  <span class="font-mono font-bold text-sm text-slate-400">
                    <%= diag[:placar_api] %>
                  </span>
                <% else %>
                  <span class="text-xs opacity-40">—</span>
                <% end %>
              </td>
              
              <!-- Sincronizado -->
              <td class="py-4 text-center">
                <% if diag[:sincronizado] %>
                  <span class="badge badge-success text-white text-xs font-bold gap-1 p-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    Sim
                  </span>
                <% else %>
                  <span class="badge badge-warning text-white text-xs font-bold gap-1 p-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Não
                  </span>
                <% end %>
              </td>
              
              <!-- Placar Bate -->
              <td class="py-4 text-center">
                <% if diag[:placar_bate] %>
                  <span class="badge badge-success text-white text-xs font-bold gap-1 p-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    Sim
                  </span>
                <% else %>
                  <span class="badge badge-error text-white text-xs font-bold gap-1 p-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Não
                  </span>
                <% end %>
              </td>
              
              <!-- Artilharia Bate -->
              <td class="py-4 text-center">
                <% if diag[:artilharia_ok] %>
                  <span class="badge badge-success text-white text-xs font-bold gap-1 p-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    Sim
                  </span>
                <% else %>
                  <span class="badge badge-error text-white text-xs font-bold gap-1 p-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Não
                  </span>
                <% end %>
              </td>
              
              <!-- Diagnóstico / Status de Alerta -->
              <td class="py-4 pr-6">
                <div class="flex flex-col items-center justify-center">
                  <% if tem_inconsistencia %>
                    <div class="flex items-center gap-1 text-error bg-error/10 px-3 py-1.5 rounded-xl border border-error/20">
                      <span class="w-2.5 h-2.5 rounded-full bg-error animate-ping shrink-0"></span>
                      <span class="text-xs font-black uppercase tracking-wide">Atenção</span>
                    </div>
                    <% if diag[:erros].any? %>
                      <div class="mt-2 text-[10px] text-error/85 font-semibold text-left max-w-xs space-y-1 bg-error/5 p-2 rounded-lg border border-error/10">
                        <% diag[:erros].first(3).each do |err| %>
                          <p class="leading-tight">• <%= err %></p>
                        <% end %>
                        <% if diag[:erros].size > 3 %>
                          <p class="text-[9px] opacity-60 italic text-center mt-1">+ <%= diag[:erros].size - 3 %> outros erros</p>
                        <% end %>
                      </div>
                    <% end %>
                  <% else %>
                    <div class="flex items-center gap-1 text-success bg-success/10 px-3 py-1.5 rounded-xl border border-success/20">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="text-xs font-black uppercase tracking-wide">Integro</span>
                    </div>
                  <% end %>
                </div>
              </td>
              
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
