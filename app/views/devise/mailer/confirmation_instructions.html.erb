<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Confirme sua conta - OrangScore</title>
  </head>

  <body style="margin: 0; padding: 0; background-color: #0f172a; height: 100%;">
    <table width="100%" height="100%" cellpadding="0" cellspacing="0" role="presentation">
      <tr>
        <td align="center" valign="middle">
          <table width="100%" cellpadding="0" cellspacing="0" style="max-width: 480px; background-color: #111827; border-radius: 16px; padding: 32px; color: #f9fafb; font-family: Arial, Helvetica, sans-serif;">
            <tr>
              <td align="center">
                <h2 style="margin-top: 0; color: #f97316;">Bem-vindo ao OrangScore!</h2>

                <p style="color: #e5e7eb;">
                  Olá, <strong><%= @email %></strong>!
                </p>

                <p style="color: #e5e7eb;">
                  Falta pouco para você começar. Clique no botão abaixo para confirmar seu e-mail e ativar sua conta.
                </p>

                <table cellpadding="0" cellspacing="0" style="margin: 24px 0;">
                  <tr>
                    <td align="center" style="background-color: #f97316; border-radius: 999px;">
                      <%= link_to 'Confirmar minha conta',
                        "#{root_url}confirmation?confirmation_token=#{@token}",
                        style: "display: inline-block; padding: 14px 28px; font-weight: bold; text-decoration: none; color: #111827;" %>
                    </td>
                  </tr>
                </table>

                <p style="font-size: 12px; color: #9ca3af;">
                  Se você não criou esta conta, ignore este e-mail.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>