<div class="min-h-screen flex items-center justify-center bg-base-300 px-4">
  <div class="w-full max-w-md bg-base-100 shadow-lg rounded-2xl p-8">
    
    <h2 class="text-2xl font-bold text-center text-primary mb-6">
      Entrar no OrangScore
    </h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>

      <div class="form-control w-full">
        <%= f.label :email, class: "label" do %>
          <span class="label-text font-medium pb-4">E-mail</span>
        <% end %>
        <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          class: "input input-ghost w-full" %>
      </div>

      <div class="form-control w-full">
        <%= f.label :password, class: "label" do %>
          <span class="label-text font-medium pb-4">Senha</span>
        <% end %>

        <%# O container 'relative' deve envolver apenas o input e o botão %>
        <div class="relative w-full">
          <%= f.password_field :password,
            id: "password",
            autocomplete: "current-password",
            class: "input input-bordered w-full pr-10" %> <%# pr-10 para o texto não sobrepor o ícone %>
          
          <button type="button" 
                  class="absolute inset-y-0 right-0 flex items-center pr-3" 
                  onclick="togglePasswordVisibility('password')">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 opacity-50 hover:opacity-100" id="eye-icon-password">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.399 8.049 7.31 5 12 5s8.601 3.049 9.964 6.678c.07.232.07.467 0 .701C20.601 15.951 16.69 19 12 19s-8.601-3.049-9.964-6.678z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </button>
        </div>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-2">
            <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
            <span class="label-text">Manter-me conectado</span>
          </label>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Entrar",
          class: "btn btn-primary w-full rounded-xl" %>
      </div>

    <% end %>

    <div class="divider my-6"></div>

    <div class="text-center text-sm space-y-2">
      <div class="space-y-2">
        <div class="text-center">
          <%= link_to 'Criar conta',
            new_user_registration_path,
            class: 'btn btn-ghost btn-sm hover:bg-primary' %>
        </div>

        <div class="text-center">
          <%= link_to 'Esqueci minha senha',
            new_password_path,
            class: 'btn btn-ghost btn-sm hover:bg-primary' %>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  function togglePasswordVisibility(id) {
    const input = document.getElementById(id);
    const icon = document.getElementById(`eye-icon-${id}`);
    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.add('text-primary');
    } else {
      input.type = 'password';
      icon.classList.remove('text-primary');
    }
  }
</script>