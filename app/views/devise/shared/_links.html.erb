<div class="flex flex-col gap-3 w-full">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Já tem uma conta?", new_session_path(resource_name), 
        class: "btn btn-outline btn-sm border-gray-600 text-gray-400 hover:text-white" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Criar uma conta", new_registration_path(resource_name), 
        class: "btn btn-primary btn-sm" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), 
        class: "link link-hover text-xs text-gray-500 text-center" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Não recebeu as instruções de confirmação?", new_confirmation_path(resource_name), 
        class: "link link-hover text-xs text-orange-500/80 text-center mt-2" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Não recebeu as instruções de desbloqueio?", new_unlock_path(resource_name), 
        class: "link link-hover text-xs text-gray-500 text-center" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Entrar com #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), 
          data: { turbo: false }, 
          class: "btn btn-outline w-full" %><br />
    <% end %>
  <% end %>
</div>