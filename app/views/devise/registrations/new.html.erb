<div class="min-h-screen flex items-center justify-center bg-base-300">
  <div class="w-full max-w-md bg-base-100 shadow-lg rounded-2xl p-12">
    <h2 class="text-2xl font-bold text-center text-primary mb-6">
      Criar conta no OrangScore
    </h2>

    <ul class="steps w-full mb-8">
      <li class="step step-primary">Dados</li>
      <li class="step">Senha</li>
      <li class="step">Seleção</li>
    </ul>

    <%
      step_with_error =
        if resource.errors[:name].any? || resource.errors[:email].any?
          1
        elsif resource.errors[:password].any? || resource.errors[:password_confirmation].any?
          2
        elsif resource.errors[:selecao_id].any?
          3
        else
          1
        end
    %>

    <%= form_for(
      resource,
      as: resource_name,
      url: registration_path(resource_name),
      html: {
        class: "space-y-5",
        id: "signup-form",
        data: {
          turbo: false,
          has_errors: resource.errors.any?,
          error_step: step_with_error
        }
      }
    ) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div data-step="1" class="space-y-5">
        <div class="form-control w-full">
          <%= f.label :name, class: "label" do %>
            <span class="label-text font-medium pb-4">Nome</span>
          <% end %>

          <%= f.text_field :name,
            id: "user_name",
            value: (resource.errors.any? ? '' : resource.name),
            autofocus: true,
            class: "input input-ghost bg-base-300 w-full",
            placeholder: "Seu nome" %>
        </div>

        <div class="form-control w-full">
          <%= f.label :email, class: "label" do %>
            <span class="label-text font-medium pb-4">E-mail</span>
          <% end %>

          <%= f.email_field :email,
            id: "user_email",
            value: (resource.errors.any? ? '' : resource.email),
            required: true,
            autocomplete: "email",
            placeholder: "seu@email.com",
            class: "input input-ghost  bg-base-300 validator w-full" %>

          <div class="validator-hint text-sm text-error mt-1">
            Informe um endereço de e-mail válido
          </div>
        </div>

        <button
          type="button"
          class="btn btn-primary w-full"
          onclick="nextStep()">
          Continuar
        </button>
      </div>

      <div data-step="2" class="space-y-5 hidden">
        <div class="form-control w-full">
          <%= f.label :password, class: "label" do %>
            <span class="label-text font-medium pb-4">Senha</span>
          <% end %>

          <div class="relative">
            <%= f.password_field :password,
              id: "password",
              placeholder: "Digite sua senha",
              class: "input input-ghost bg-base-300 w-full pr-10",
              required: true,
              autocomplete: "new-password" %>
              <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center" onclick="togglePasswordVisibility('password')">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 opacity-50 hover:opacity-100" id="eye-icon-password">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.399 8.049 7.31 5 12 5s8.601 3.049 9.964 6.678c.07.232.07.467 0 .701C20.601 15.951 16.69 19 12 19s-8.601-3.049-9.964-6.678z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </button>
          </div>

          <div class="text-xs mt-2">
            <p class="opacity-70 mb-1">A senha deve conter:</p>
            <ul class="space-y-1">
              <li id="req-min" class="flex items-center gap-2 text-error transition-colors"><span class="badge badge-xs"></span> Pelo menos 8 caracteres</li>
              <li id="req-upper" class="flex items-center gap-2 text-error transition-colors"><span class="badge badge-xs"></span> Uma letra maiúscula</li>
              <li id="req-lower" class="flex items-center gap-2 text-error transition-colors"><span class="badge badge-xs"></span> Uma letra minúscula</li>
              <li id="req-num" class="flex items-center gap-2 text-error transition-colors"><span class="badge badge-xs"></span> Um número</li>
              <li id="req-sym" class="flex items-center gap-2 text-error transition-colors"><span class="badge badge-xs"></span> Um símbolo</li>
            </ul>
          </div>
        </div>

        <div class="form-control w-full">
          <%= f.label :password_confirmation, class: "label" do %>
            <span class="label-text font-medium pb-4">Confirmar senha</span>
          <% end %>

          <div class="relative">
            <%= f.password_field :password_confirmation,
              id: "password_confirmation",
              placeholder: "Confirme sua senha",
              class: "input bg-base-300 input-ghost w-full pr-10",
              required: true,
              autocomplete: "new-password" %>
            <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center" onclick="togglePasswordVisibility('password_confirmation')">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 opacity-50 hover:opacity-100" id="eye-icon-password_confirmation">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.399 8.049 7.31 5 12 5s8.601 3.049 9.964 6.678c.07.232.07.467 0 .701C20.601 15.951 16.69 19 12 19s-8.601-3.049-9.964-6.678z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </button>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 pt-4">
          <button type="button" class="btn w-full" onclick="prevStep()">Voltar</button>
          <button type="button" class="btn btn-primary w-full" onclick="validatePasswordsAndContinue()">Continuar</button>
        </div>
      </div>

      <div data-step="3" class="space-y-5 hidden">
        <div class="form-control w-full">
          <%= f.label :selecao_id, class: "label" do %>
            <span class="label-text font-medium pb-4">
              Qual seleção você acha que vai ser campeã?
            </span>
          <% end %>

          <%= f.collection_select :selecao_id,
            Selecao.where.not(nome: 'A definir').order(:nome),
            :id,
            :nome,
            {
              prompt: "Selecione sua seleção",
              selected: (resource.errors.any? ? nil : resource.selecao_id)
            },
            {
              id: "user_selecao_id",
              required: true,
              class: "select bg-base-300 select-bordered w-full"
            } %>
        </div>

        <div class="form-control w-full">
          <label class="group flex items-start gap-3 cursor-pointer py-2">
            
            <%# Container do Checkbox: Fixamos a largura para ele nunca mexer %>
            <div class="flex-none pt-0.5">
              <%= f.check_box :terms_of_service, 
                  id: "user_terms_of_service", 
                  required: true, 
                  class: "checkbox checkbox-primary checkbox-sm" %>
            </div>
            
            <%# Container do Texto: Ocupa o restante do espaço %>
            <div class="flex-1">
              <span class="label-text text-[11px] sm:text-xs leading-relaxed opacity-80 group-hover:opacity-100 transition-opacity">
                Eu li e aceito os 
                <%= link_to "Termos de Uso", termos_path, target: "_blank", class: "link link-primary font-bold no-underline hover:underline" %> 
                e a 
                <%= link_to "Política de Privacidade", privacidade_path, target: "_blank", class: "link link-primary font-bold no-underline hover:underline" %> 
                do OrangScore.
              </span>
            </div>

          </label>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <button
            type="button"
            class="btn w-full"
            onclick="prevStep()">
            Voltar
          </button>

          <%= f.submit "Criar conta",
            id: "submit-button",
            disabled: true,
            class: "btn btn-primary w-full disabled:opacity-50 disabled:cursor-not-allowed" %>
        </div>
      </div>

    <% end %>

    <div class="divider my-6"></div>

    <div class="text-center text-sm space-y-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

<script>
  let currentStep = 1
  const totalSteps = 3

  function updateSteps () {
    document.querySelectorAll('[data-step]').forEach(el => {
      el.classList.toggle('hidden', Number(el.dataset.step) !== currentStep)
    })

    document.querySelectorAll('.step').forEach((el, index) => {
      el.classList.toggle('step-primary', index + 1 <= currentStep)
    })
  }

  function nextStep () {
    if (currentStep < totalSteps) {
      currentStep++
      updateSteps()
    }
  }

  function prevStep () {
    if (currentStep > 1) {
      currentStep--
      updateSteps()
    }
  }

  function validatePasswordsAndContinue () {
    const password = document.getElementById('password')
    const confirmation = document.getElementById('password_confirmation')

    if (!password || !confirmation) return

    password.setCustomValidity('')
    confirmation.setCustomValidity('')

    const passwordValue = password.value
    const hasMinLength = passwordValue.length >= 8
    const hasUppercase = /[A-Z]/.test(passwordValue)
    const hasLowercase = /[a-z]/.test(passwordValue)
    const hasNumber = /[0-9]/.test(passwordValue)
    const hasSymbol = /[^A-Za-z0-9]/.test(passwordValue)

    if (!hasMinLength || !hasUppercase || !hasLowercase || !hasNumber || !hasSymbol) {
      password.setCustomValidity('A senha não atende aos requisitos')
      password.reportValidity()
      return
    }

    if (passwordValue !== confirmation.value) {
      confirmation.setCustomValidity('As senhas não coincidem')
      confirmation.reportValidity()
      return
    }

    nextStep()
  }

  function setupFinalStepValidation () {
    const selecao = document.getElementById('user_selecao_id')
    const terms = document.getElementById('user_terms_of_service')
    const submitButton = document.getElementById('submit-button')
    
    if (!submitButton) return

    function toggleButton () {
      const selecaoValid = selecao && selecao.value !== ""
      const termsValid = terms && terms.checked
      
      // Remove o atributo disabled se ambos forem válidos
      if (selecaoValid && termsValid) {
        submitButton.removeAttribute('disabled')
      } else {
        submitButton.setAttribute('disabled', 'true')
      }
    }

    if (selecao) selecao.addEventListener('change', toggleButton)
    if (terms) terms.addEventListener('change', toggleButton)

    // Executa uma vez ao carregar para o caso de o navegador lembrar o check
    toggleButton()
  }

  function initializeSignupForm () {
    const form = document.getElementById('signup-form')
    if (!form) return

    const hasErrors = form.dataset.hasErrors === 'true'
    const errorStep = Number(form.dataset.errorStep || 1)

    currentStep = hasErrors ? errorStep : 1
    updateSteps()
    setupFinalStepValidation() // Chama a validação do botão aqui também
  }

  // Garante que rode em qualquer situação de carregamento do Rails (Turbo ou não)
  document.addEventListener('turbo:load', initializeSignupForm)
  document.addEventListener('DOMContentLoaded', initializeSignupForm)

  function togglePasswordVisibility(id) {
    const input = document.getElementById(id);
    const icon = document.getElementById(`eye-icon-${id}`);
    if (input.type === 'password') {
      input.type = 'text';
      icon.classList.add('text-primary');
    } else {
      input.type = 'password';
      icon.classList.remove('text-primary');
    }
  }

  // Validação em tempo real dos requisitos
  function validatePasswordRequirements() {
    const val = document.getElementById('password').value;
    
    const rules = {
      'req-min': val.length >= 8,
      'req-upper': /[A-Z]/.test(val),
      'req-lower': /[a-z]/.test(val),
      'req-num': /[0-9]/.test(val),
      'req-sym': /[^A-Za-z0-9]/.test(val)
    };

    Object.keys(rules).forEach(id => {
      const el = document.getElementById(id);
      const badge = el.querySelector('.badge');
      if (rules[id]) {
        el.classList.replace('text-error', 'text-success');
        badge.classList.replace('badge-error', 'badge-success'); // Se quiser mudar cor do badge
        el.classList.add('font-bold');
      } else {
        el.classList.replace('text-success', 'text-error');
        el.classList.remove('font-bold');
      }
    });
  }

  // Modifique sua função initializeSignupForm para incluir o listener:
  function initializeSignupForm () {
    const form = document.getElementById('signup-form')
    if (!form) return

    // Adiciona o listener de digitação na senha
    const passwordInput = document.getElementById('password');
    if (passwordInput) {
      passwordInput.addEventListener('input', validatePasswordRequirements);
    }

    // ... (restante do seu código original de initialize)
    const hasErrors = form.dataset.hasErrors === 'true'
    const errorStep = Number(form.dataset.errorStep || 1)
    currentStep = hasErrors ? errorStep : 1
    updateSteps()
    setupFinalStepValidation()
  }
</script>